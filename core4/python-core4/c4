#!/usr/bin/env bash
set -euo pipefail

# c4 — Fast Core4 status reader (event ledger → terminal)
# Reads directly from ~/vault/Core4/.core4/events/YYYY-MM-DD/*.json
# No bridge dependency, no timeout issues.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd -P)"
source "$SCRIPT_DIR/core4-lib.sh" 2>/dev/null || true

usage() {
  cat <<'EOF'
Usage: c4 [YYYY-MM-DD]
       c4 [help|--help|-h]

Fast Core4 status reader (ledger-only, no Bridge dependency).

Examples:
  c4
  c4 2026-02-25

Related:
  c4d          # dashboard
  core4 -d     # tracker score (today)
  core4 -w     # tracker score (week)
  wcore4       # Taskwarrior + core4 week
  core4ctl help
EOF
}

case "${1:-}" in
  help|-h|--help)
    usage
    exit 0
    ;;
esac

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
GRAY='\033[0;90m'
RESET='\033[0m'

# Config
CORE4_STORAGE="${CORE4_STORAGE_DIR:-$HOME/.core4}"
TODAY="${1:-$(date +%Y-%m-%d)}"
WEEK="$(date -d "$TODAY" +%Y-W%V)"

# Find today's aggregate file
DAY_FILE="$CORE4_STORAGE/core4_day_$TODAY.json"

if [[ ! -f "$DAY_FILE" ]]; then
  echo -e "${GRAY}No Core4 data for $TODAY${RESET}"
  echo -e "${GRAY}File: $DAY_FILE${RESET}"
  exit 0
fi

# Load habit order from core4_types.py (single source of truth), fallback to default.
declare -a HABIT_ORDER=()
if command -v python3 >/dev/null 2>&1; then
  while IFS= read -r h; do
    [[ -n "$h" ]] || continue
    HABIT_ORDER+=("$h")
  done < <(python3 - <<'PY'
import os, sys
sys.path.insert(0, os.path.dirname(__file__))
try:
    import core4_types
    for h in core4_types.HABIT_ORDER:
        print(h)
except Exception:
    pass
PY
  )
fi
if [[ ${#HABIT_ORDER[@]} -eq 0 ]]; then
  HABIT_ORDER=(fitness fuel meditation memoirs person1 person2 discover declare)
fi

# Parse entries using jq
declare -A habits=()
for h in "${HABIT_ORDER[@]}"; do
  habits["$h"]=0
done

# Parse entries and mark completed habits
while IFS= read -r entry; do
  task=$(echo "$entry" | jq -r '.task // empty')
  done=$(echo "$entry" | jq -r '.done // false')

  # Map task names to habit keys
  case "$task" in
    person1|partner) habit="person1" ;;
    person2|posterity) habit="person2" ;;
    memoirs) habit="memoirs" ;;
    meditation) habit="meditation" ;;
    fitness) habit="fitness" ;;
    fuel) habit="fuel" ;;
    discover) habit="discover" ;;
    declare|action) habit="declare" ;;
    *) habit="" ;;
  esac

  if [[ -n "$habit" && "$done" == "true" ]]; then
    habits["$habit"]=1
  fi
done < <(jq -c '.entries[]' "$DAY_FILE" 2>/dev/null || echo "")

# Day total from recognized Core4 habits only (ignores test/probe events)
done_count=0
for habit in "${HABIT_ORDER[@]}"; do
  if [[ "${habits[$habit]}" == "1" ]]; then
    ((done_count+=1))
  fi
done
total=$(awk "BEGIN { printf \"%.1f\", $done_count * 0.5 }")

# Output
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "${BLUE}  Core4 Status${RESET} — ${GRAY}$TODAY ($WEEK)${RESET}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo ""

# Habit status
for habit in "${HABIT_ORDER[@]}"; do
  if [[ "${habits[$habit]}" == "1" ]]; then
    echo -e "  ${GREEN}✓${RESET} $habit"
  else
    echo -e "  ${GRAY}○${RESET} $habit"
  fi
done

echo ""
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "  Total: ${GREEN}$total${RESET} / 4.0"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

# Optional: Bridge health check
if command -v curl &>/dev/null; then
  bridge_status=$(curl -s --max-time 1 http://127.0.0.1:8080/health 2>/dev/null || echo "")
  if [[ -n "$bridge_status" ]]; then
    echo -e "${GRAY}Bridge: online${RESET}"
  else
    echo -e "${YELLOW}Bridge: offline (reading from ledger)${RESET}"
  fi
fi
