#!/usr/bin/env bash
set -euo pipefail

# Core4 Dashboard — live display, hotkey logging, auto-refresh

BRIDGE_URL="${AOS_BRIDGE_URL:-http://localhost:8080}"
REFRESH="${CORE4_DASHBOARD_REFRESH:-60}"
SCRIPT_DIR="$(dirname "$(realpath "$0")")"
TRACKER="${CORE4_TRACKER:-${SCRIPT_DIR}/tracker.py}"

# With args → pass through to tracker directly
if [[ $# -gt 0 ]]; then
    exec python3 "$TRACKER" "$@"
fi

log_habit() {
  local habit="$1"
  printf "\n  → %s..." "$habit"
  python3 "$TRACKER" "$habit" >/dev/null 2>&1
}

draw() {
  local response total week_label date_key week_total bars=40 filled

  clear
  echo "════════════════════════════════════════════════════════════════"
  printf "  CORE4  %s\n" "$(date +'%Y-%m-%d %H:%M:%S')"
  echo "════════════════════════════════════════════════════════════════"
  echo ""

  if response=$(curl -sf --connect-timeout 2 --max-time 4 \
      "${BRIDGE_URL}/bridge/core4/today" 2>/dev/null); then

    total=$(printf '%s' "$response" | jq -r '.total // 0')
    week_label=$(printf '%s' "$response" | jq -r '.week // "?"')
    date_key=$(printf '%s' "$response"  | jq -r '.date // "?"')

    # Week total direct from event ledger (tracker is truth)
    week_total=$(python3 "$TRACKER" -w --quiet 2>/dev/null \
      | grep -oE '[0-9]+\.[0-9]+' | head -1 || echo "?")

    printf "  Day %-12s  %s/4    Week %s:  %s/28\n" \
      "$date_key" "$total" "$week_label" "$week_total"
    echo ""

    # Progress bar
    filled=$(awk "BEGIN {printf \"%.0f\", ($total / 4.0) * $bars}")
    printf "  ["
    for ((i=0; i<bars; i++)); do
      if (( i < filled )); then printf "█"; else printf "░"; fi
    done
    LC_NUMERIC=C printf "]  %.1f/4.0\n" "$total"
    echo ""

    # Habits with inline hotkeys
    printf '%s' "$response" | jq -r '
      .habits as $h |
      def mark(key): if ($h[key] // false) then "✓" else "·" end;
      "  BODY      [1] \(mark("fitness")) Fitness     [2] \(mark("fuel")) Fuel",
      "  BEING     [3] \(mark("meditation")) Meditation  [4] \(mark("memoirs")) Memoirs",
      "  BALANCE   [5] \(mark("partner")) Partner     [6] \(mark("posterity")) Posterity",
      "  BUSINESS  [7] \(mark("discover")) Discover    [8] \(mark("declare")) Declare"
    '

  else
    echo "  ⚠  Bridge offline — reading from event ledger"
    echo ""
    python3 "$TRACKER" -d 2>/dev/null || true
    echo ""
    python3 "$TRACKER" -w 2>/dev/null || true
  fi

  echo ""
  echo "────────────────────────────────────────────────────────────────"
  printf "  [1-8] log habit  |  [q] quit  |  refresh every %ss\n" "$REFRESH"
}

while true; do
  draw
  key=""
  read -r -s -n1 -t "$REFRESH" key 2>/dev/null || true
  case "$key" in
    q|Q) printf "\n"; exit 0 ;;
    1) log_habit fitness ;;
    2) log_habit fuel ;;
    3) log_habit meditation ;;
    4) log_habit memoirs ;;
    5) log_habit partner ;;
    6) log_habit posterity ;;
    7) log_habit discover ;;
    8) log_habit declare ;;
  esac
done
