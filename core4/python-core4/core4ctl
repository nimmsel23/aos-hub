#!/usr/bin/env bash
set -euo pipefail

# core4ctl — thin dispatcher
# Keep this file small; real logic lives in:
#   - core4-trackctl  (tracker + taskwarrior wrappers)
#   - core4-syncctl   (rclone/vault sync)
#   - core4-apictl    (bridge/index endpoint probes)
#   - core4-servicectl (systemd mount/timers)
#   - core4-clinctl   (install/doctor)
#   - core4-menuctl   (interactive menu)

APP_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd -P)"

trackctl() { exec "$APP_DIR/core4-trackctl" "$@"; }
syncctl() { exec "$APP_DIR/core4-syncctl" "$@"; }
apictl() { exec "$APP_DIR/core4-apictl" "$@"; }
servicectl() { exec "$APP_DIR/core4-servicectl" "$@"; }
clinctl() { exec "$APP_DIR/core4-clinctl" "$@"; }
menuctl() { exec "$APP_DIR/core4-menuctl" "$@"; }

have_cmd() { command -v "$1" >/dev/null 2>&1; }

shim_notice() {
  [[ -t 1 ]] || return 0
  cat >&2 <<'EOF'
[core4ctl] compatibility shim
  Daily use: `core4`, `c4`, `c4d`, `wcore4`
  Ops/admin: `core4ctl ...` (legacy-compatible)
EOF
}

exec_frontdoor() {
  local bin="$1"
  shift || true
  if have_cmd "$bin"; then
    exec "$bin" "$@"
  fi
  return 1
}

legacy_mount_notice() {
  [[ -t 1 ]] || return 0
  cat >&2 <<'EOF'
[core4ctl] legacy mount command
  Core4 mounts are no longer part of the normal workflow.
  Kept only for backward compatibility.
EOF
}

usage() {
  cat <<EOF
Usage: core4ctl <command>

Compatibility shim (preferred daily commands: \`core4\`, \`c4\`, \`c4d\`, \`wcore4\`)

Frontdoor (daily use):
  core4               # live dashboard (or tracker pass-through)
  c4d                 # explicit dashboard shortcut
  c4                  # fast ledger-only status
  wcore4              # Taskwarrior week + core4 week score

Help / self-discovery:
  core4 --help
  c4 --help
  c4d --help
  wcore4 --help
  core4ctl help
  See also: aos-hub/core4/CHEATSHEET.md

Core:
  core4ctl menu
  core4ctl doctor
  core4ctl install-cli [TARGET]

Tracker:
  core4ctl status
  core4ctl sources
  core4ctl build
  core4ctl seed-week [args...]
  core4ctl export-daily [args...]
  core4ctl prune-events [args...]
  core4ctl finalize-month [args...]
  core4ctl finalize-week [args...]

Habits:
  core4ctl edit-habit [habit-name]   # Edit per-habit config

Taskwarrior:
  core4ctl list|today|week|done [task-args...]

Sync (timer-first):
  vaultctl core4 status
  vaultctl core4 init

Manual sync (emergency):
  core4ctl sync        # pull-core4 + vaultctl core4 push
  core4ctl pull-core4  # pull .core4/** from Drive + rebuild
  core4ctl push-core4  # push .core4/** to Drive
  core4ctl probe [all|today|week [YYYY-Www]]

Systemd:
  core4ctl install-timers

PWA ctx:
  core4ctl ctx [open|start|stop|restart|status|logs|menu]

Legacy (rarely needed):
  core4ctl mount-status|mount-enable|mount-disable|mount-restart|mount-logs
EOF
}

cmd_ctx() {
  local action="${1:-menu}"
  if command -v core4ctx >/dev/null 2>&1; then
    core4ctx "$action"
    return $?
  fi
  if command -v pwactx >/dev/null 2>&1; then
    pwactx core4 "$action"
    return $?
  fi
  echo "core4ctx/pwactx not found" >&2
  return 1
}

cmd="${1:-}"
if [[ -z "${cmd:-}" ]]; then
  if [[ -t 0 && -t 1 ]]; then
    cmd="menu"
  else
    cmd="help"
  fi
else
  shift || true
fi

case "$cmd" in
  -h|--help|help)
    shim_notice
    usage
    ;;
  ctx)
    cmd_ctx "${1:-}"
    ;;
  menu)
    case "${1:-}" in
      help|-h|--help)
        shim_notice
        usage
        ;;
      *)
        shim_notice
        exec_frontdoor core4 || menuctl menu
        ;;
    esac
    ;;
  dashboard|dash)
    case "${1:-}" in
      help|-h|--help)
        shim_notice
        usage
        ;;
      *)
        shim_notice
        exec_frontdoor core4 "$@" || menuctl menu
        ;;
    esac
    ;;
  # Explicit shim frontdoors
  fast)
    shim_notice
    exec_frontdoor c4 "$@" || trackctl status
    ;;
  score|score-day)
    shim_notice
    exec_frontdoor core4 -d "$@" || trackctl status
    ;;
  score-week)
    shim_notice
    exec_frontdoor core4 -w "$@" || trackctl status
    ;;
  weekview|week-score)
    shim_notice
    exec_frontdoor wcore4 "$@" || trackctl status
    ;;

  # Habit passthrough for users still typing core4ctl fitness, etc.
  fitness|fuel|meditation|memoirs|partner|posterity|discover|declare)
    shim_notice
    exec_frontdoor core4 "$cmd" "$@" || trackctl status
    ;;

  doctor) clinctl doctor ;;
  install-cli) clinctl install-cli "${1:-}" ;;

  status|sources|build|seed-week|export-daily|prune|prune-events|finalize-month|seal-month|month-close|finalize-week|seal-week|edit-habit|edit|list|ls|today|week|done|completed)
    trackctl "$cmd" "$@"
    ;;

  sync|sync-core4|push-core4|pull-core4)
    syncctl "$cmd" "$@"
    ;;

  probe)
    apictl "$@"
    ;;

  mount-status|mount-enable|mount-disable|mount-restart|mount-logs|install-timers)
    if [[ "$cmd" == mount-* ]]; then
      legacy_mount_notice
    fi
    servicectl "$cmd" "$@"
    ;;

  *)
    usage
    exit 1
    ;;
esac
