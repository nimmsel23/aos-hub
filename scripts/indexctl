#!/usr/bin/env bash
set -euo pipefail

# indexctl is intentionally user-service only (aos-index-dev.service).

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
if [[ "$ROOT_DIR" != "$HOME/aos-hub" && -d "$HOME/aos-hub/scripts" ]]; then
  ROOT_DIR="$HOME/aos-hub"
fi

# Shared ctl helpers (msg/warn/die/has_cmd/ui_*).
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/ctl-lib.sh"

# Codex session helper: indexctl codex [purpose...]
# shellcheck disable=SC1091

# Load global env (optional).
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/lib/aos-env.sh"
aos_env_load "" "$ROOT_DIR" || true

USER_SERVICE_NAME="${AOS_INDEX_USER_SERVICE:-aos-index-dev.service}"
HEALTH_URL="${AOS_INDEX_HEALTH_URL:-http://127.0.0.1:8799/health}"
HUB_DOCTOR="${AOS_HUB_DOCTOR:-$ROOT_DIR/scripts/aos-doctor}"

ensure_user_runtime_dir() {
  if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
    return 0
  fi
  local uid runtime_dir
  uid="$(id -u)"
  runtime_dir="/run/user/${uid}"
  if [[ -d "$runtime_dir" ]]; then
    export XDG_RUNTIME_DIR="$runtime_dir"
  fi
}
ensure_user_runtime_dir

user_bus_ok() {
  systemctl --user --version >/dev/null 2>&1 && systemctl --user is-active default.target >/dev/null 2>&1 || {
    systemctl --user list-unit-files >/dev/null 2>&1
  }
}

require_user_bus() {
  user_bus_ok || die "systemctl --user not available (no user bus). linger is required for persistent user service."
}

start_user_svc() { require_user_bus; systemctl --user start "$USER_SERVICE_NAME"; }
stop_user_svc() { require_user_bus; systemctl --user stop "$USER_SERVICE_NAME"; }
restart_user_svc() { require_user_bus; systemctl --user restart "$USER_SERVICE_NAME"; }
status_user_svc() { require_user_bus; systemctl --user status "$USER_SERVICE_NAME" --no-pager; }
enable_user_svc() { require_user_bus; systemctl --user enable "$USER_SERVICE_NAME"; }
disable_user_svc() { require_user_bus; systemctl --user disable "$USER_SERVICE_NAME"; }
logs_user_svc() { require_user_bus; journalctl --user -u "$USER_SERVICE_NAME" -f; }

user_state() {
  if ! user_bus_ok; then
    printf "unknown\n"
    return 0
  fi
  local state
  state="$(systemctl --user is-active "$USER_SERVICE_NAME" 2>/dev/null || true)"
  [[ -n "$state" ]] || state="unknown"
  printf "%s\n" "$state"
}

health_check() {
  if ! has_cmd curl; then
    warn "curl not found"
    return 0
  fi
  if curl -fsS "$HEALTH_URL" >/dev/null 2>&1; then
    msg "✅ health OK: $HEALTH_URL"
  else
    warn "health failed: $HEALTH_URL"
  fi
}

doctor() {
  msg "Indexctl doctor (user-service only)"
  msg "User service: $USER_SERVICE_NAME"
  msg "Health URL  : $HEALTH_URL"
  msg ""
  msg "User state  : $(user_state)"
  health_check
}

mode_status() {
  msg "Index mode status"
  msg "Service scope: user"
  msg "User service: $USER_SERVICE_NAME"
  local ustate
  ustate="$(user_state)"
  if [[ "$ustate" == "unknown" ]]; then
    msg "  active: unknown (no user bus)"
  else
    msg "  active: $ustate"
  fi
}

mode_dev() {
  msg "Switching to DEV mode (user service: $USER_SERVICE_NAME)"
  start_user_svc
  mode_status
}

legacy_system_cmd() {
  local cmd="$1"
  die "system-service path removed: '$cmd' is no longer supported in indexctl (user-service only: $USER_SERVICE_NAME)"
}

hub_doctor() {
  if [[ ! -e "$HUB_DOCTOR" ]]; then
    die "missing: $HUB_DOCTOR"
  fi
  if [[ -x "$HUB_DOCTOR" ]]; then
    "$HUB_DOCTOR"
    return 0
  fi
  if has_cmd bash; then
    bash "$HUB_DOCTOR"
    return 0
  fi
  die "not executable and bash not found: $HUB_DOCTOR"
}

usage() {
  cat <<EOF
indexctl - manage αOS index-node user service

Compatibility note:
  - indexctl is now user-service only (systemd --user).
  - System-service workflow was removed from this tool.

Usage:
  scripts/indexctl start|stop|restart|status|logs
  scripts/indexctl enable|disable
  scripts/indexctl user-start|user-stop|user-status
  scripts/indexctl mode-dev|mode-status
  scripts/indexctl doctor
  scripts/indexctl hub-doctor

Env:
  AOS_INDEX_HEALTH_URL=http://127.0.0.1:8799/health
  AOS_INDEX_USER_SERVICE=aos-index-dev.service
  AOS_HUB_DOCTOR=$ROOT_DIR/scripts/aos-doctor
EOF
}

cmd="${1:-}"
case "$cmd" in
  start) start_user_svc ;;
  stop) stop_user_svc ;;
  restart) restart_user_svc ;;
  status) status_user_svc ;;
  enable) enable_user_svc ;;
  disable) disable_user_svc ;;
  logs) logs_user_svc ;;
  user-start) start_user_svc ;;
  user-stop) stop_user_svc ;;
  user-status) status_user_svc ;;
  mode-dev|dev-mode|switch-dev) mode_dev ;;
  mode-status) mode_status ;;
  doctor) doctor ;;
  hub-doctor|aos-doctor) hub_doctor ;;
  install|env|env-show)
    legacy_system_cmd "$cmd"
    ;;
  -h|--help|help|"") usage ;;
  *) usage; exit 1 ;;
esac
