#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/ctl-lib.sh"
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/lib/aos-env.sh"
aos_env_load "" "$ROOT_DIR" || true

export CTL_APP_PREFIX="vaultctl"

SYSTEMD_USER_DIR="${AOS_SYSTEMD_USER_DIR:-$HOME/.config/systemd/user}"
STATE_DIR="${AOS_VAULTCTL_STATE_DIR:-$HOME/.local/state/vaultctl}"
ENV_FILE="$STATE_DIR/push.env"
LAST_SUCCESS_FILE="$STATE_DIR/last_success_epoch"
LAST_RESULT_FILE="$STATE_DIR/last_result"
LOG_FILE="$STATE_DIR/push.log"
LOCK_FILE="$STATE_DIR/push.lock"

PUSH_SERVICE="vaultctl-push.service"
PUSH_TIMER="vaultctl-push.timer"
MONITOR_SERVICE="vaultctl-push-monitor.service"
MONITOR_TIMER="vaultctl-push-monitor.timer"

VAULT_LOCAL_DEFAULT="${AOS_VAULT_ROOT:-${AOS_VAULT_DIR:-$HOME/vault}}"
VAULT_REMOTE_DEFAULT="${AOS_VAULT_PUSH_REMOTE:-eldanioo:alpha/vault}"
PUSH_CALENDAR_DEFAULT="${AOS_VAULT_PUSH_CALENDAR:-*:0/15}"
MONITOR_INTERVAL_DEFAULT="${AOS_VAULT_MONITOR_INTERVAL:-5m}"
STALE_AFTER_DEFAULT="${AOS_VAULT_STALE_AFTER_SECONDS:-1800}"
LOCK_WAIT_SECONDS_DEFAULT="${AOS_VAULT_LOCK_WAIT_SECONDS:-0}"
CHECK_SAMPLE_DEFAULT="${AOS_VAULT_CHECK_SAMPLE:-200}"
ALERT_ON_ERROR_DEFAULT="${AOS_VAULT_ALERT_ON_ERROR:-0}"

need_tooling() {
  need_cmd rclone "install rclone and configure remote first"
  need_cmd systemctl "systemd --user is required"
}

ensure_state_dir() {
  mkdir -p "$STATE_DIR"
}

ensure_systemd_dir() {
  mkdir -p "$SYSTEMD_USER_DIR"
}

realpath_safe() {
  local p="$1"
  if has_cmd realpath; then
    realpath -m -- "$p"
    return 0
  fi
  if has_cmd readlink; then
    readlink -f -- "$p" 2>/dev/null || printf "%s\n" "$p"
    return 0
  fi
  printf "%s\n" "$p"
}

write_env_file() {
  local local_dir="$1"
  local remote_dir="$2"
  local push_calendar="$3"
  local monitor_interval="$4"
  local stale_after="$5"
  local alert_on_error="$6"

  ensure_state_dir
  cat >"$ENV_FILE" <<EOT
VAULT_LOCAL='$local_dir'
VAULT_REMOTE='$remote_dir'
PUSH_ON_CALENDAR='$push_calendar'
MONITOR_ON_UNIT_ACTIVE_SEC='$monitor_interval'
STALE_AFTER_SECONDS='$stale_after'
AOS_VAULT_ALERT_ON_ERROR='$alert_on_error'
EOT
}

load_env_file() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
  fi
}

resolve_effective_local() {
  printf "%s\n" "$(realpath_safe "${VAULT_LOCAL:-$VAULT_LOCAL_DEFAULT}")"
}

resolve_effective_remote() {
  printf "%s\n" "${VAULT_REMOTE:-$VAULT_REMOTE_DEFAULT}"
}

resolve_effective_calendar() {
  printf "%s\n" "${PUSH_ON_CALENDAR:-$PUSH_CALENDAR_DEFAULT}"
}

resolve_effective_monitor_interval() {
  printf "%s\n" "${MONITOR_ON_UNIT_ACTIVE_SEC:-$MONITOR_INTERVAL_DEFAULT}"
}

resolve_effective_stale_after() {
  printf "%s\n" "${STALE_AFTER_SECONDS:-$STALE_AFTER_DEFAULT}"
}

resolve_effective_lock_wait() {
  printf "%s\n" "${AOS_VAULT_LOCK_WAIT_SECONDS:-$LOCK_WAIT_SECONDS_DEFAULT}"
}

resolve_effective_check_sample() {
  printf "%s\n" "${AOS_VAULT_CHECK_SAMPLE:-$CHECK_SAMPLE_DEFAULT}"
}

resolve_effective_alert_on_error() {
  printf "%s\n" "${AOS_VAULT_ALERT_ON_ERROR:-$ALERT_ON_ERROR_DEFAULT}"
}

send_error_alert() {
  local message="$1"
  local alert_on_error
  alert_on_error="$(resolve_effective_alert_on_error)"
  if [[ "$alert_on_error" != "1" ]]; then
    return 0
  fi

  if [[ -n "${AOS_VAULT_ALERT_CMD:-}" ]]; then
    ALERT_MESSAGE="$message" bash -lc "$AOS_VAULT_ALERT_CMD" >/dev/null 2>&1 || true
    return 0
  fi

  if has_cmd telectl; then
    telectl send "$message" >/dev/null 2>&1 || true
    return 0
  fi
  if has_cmd tele; then
    tele "$message" >/dev/null 2>&1 || true
    return 0
  fi
}

write_units() {
  local local_dir="$1"
  local remote_dir="$2"
  local push_calendar="$3"
  local monitor_interval="$4"
  local stale_after="$5"
  local alert_on_error="$6"

  ensure_systemd_dir
  write_env_file "$local_dir" "$remote_dir" "$push_calendar" "$monitor_interval" "$stale_after" "$alert_on_error"

  cat >"$SYSTEMD_USER_DIR/$PUSH_SERVICE" <<EOT
[Unit]
Description=Vault Push to GDrive (vaultctl)
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
EnvironmentFile=%h/.local/state/vaultctl/push.env
ExecStart=$SCRIPT_DIR/vaultctl _systemd-push
WorkingDirectory=%h
StandardOutput=journal
StandardError=journal
EOT

  cat >"$SYSTEMD_USER_DIR/$PUSH_TIMER" <<EOT
[Unit]
Description=Schedule vault push to GDrive (vaultctl)

[Timer]
OnCalendar=$push_calendar
Persistent=true
AccuracySec=1m
RandomizedDelaySec=1m
Unit=$PUSH_SERVICE

[Install]
WantedBy=timers.target
EOT

  cat >"$SYSTEMD_USER_DIR/$MONITOR_SERVICE" <<EOT
[Unit]
Description=Monitor vault push service health (vaultctl)

[Service]
Type=oneshot
EnvironmentFile=%h/.local/state/vaultctl/push.env
ExecStart=$SCRIPT_DIR/vaultctl _systemd-monitor
WorkingDirectory=%h
StandardOutput=journal
StandardError=journal
EOT

  cat >"$SYSTEMD_USER_DIR/$MONITOR_TIMER" <<EOT
[Unit]
Description=Monitor timer for vault push health (vaultctl)

[Timer]
OnBootSec=3m
OnUnitActiveSec=$monitor_interval
AccuracySec=30s
Unit=$MONITOR_SERVICE

[Install]
WantedBy=timers.target
EOT
}

record_result() {
  local status="$1"
  ensure_state_dir
  printf "%s\n" "$status" >"$LAST_RESULT_FILE"
}

record_success_now() {
  ensure_state_dir
  date +%s >"$LAST_SUCCESS_FILE"
  record_result "ok"
}

run_push() {
  local dry_run="${1:-0}"
  load_env_file
  need_tooling

  local local_dir remote_dir lock_wait lock_fd
  local_dir="$(resolve_effective_local)"
  remote_dir="$(resolve_effective_remote)"
  lock_wait="$(resolve_effective_lock_wait)"
  lock_fd=""

  [[ -d "$local_dir" ]] || die "Local vault folder not found: $local_dir"
  [[ "$remote_dir" == *:* ]] || die "Remote must match '<remote>:<path>' (got: $remote_dir)"

  ensure_state_dir

  if has_cmd flock; then
    exec {lock_fd}>"$LOCK_FILE"
    if [[ "$lock_wait" =~ ^[0-9]+$ ]] && (( lock_wait > 0 )); then
      if ! flock -w "$lock_wait" "$lock_fd"; then
        record_result "skipped_locked"
        ui_warn "Push already running (lock busy) -> skip"
        exec {lock_fd}>&-
        return 0
      fi
    else
      if ! flock -n "$lock_fd"; then
        record_result "skipped_locked"
        ui_warn "Push already running (lock busy) -> skip"
        exec {lock_fd}>&-
        return 0
      fi
    fi
  else
    ui_warn "flock not found; continuing without process lock"
  fi

  local -a cmd
  cmd=(
    rclone copy
    "$local_dir/"
    "$remote_dir/"
    --create-empty-src-dirs
    --fast-list
    --transfers "${AOS_VAULT_RCLONE_TRANSFERS:-4}"
    --checkers "${AOS_VAULT_RCLONE_CHECKERS:-8}"
    --stats 20s
    --stats-one-line
    --log-file "$LOG_FILE"
    --log-level INFO
  )

  if [[ "$dry_run" == "1" ]]; then
    cmd+=(--dry-run)
    ui_info "Dry-run push: $local_dir -> $remote_dir"
  else
    ui_info "Push: $local_dir -> $remote_dir"
  fi

  if "${cmd[@]}"; then
    if [[ "$dry_run" != "1" ]]; then
      record_success_now
    fi
    if [[ -n "$lock_fd" ]]; then
      exec {lock_fd}>&-
    fi
    ui_ok "Push completed"
    return 0
  fi

  record_result "failed"
  if [[ -n "$lock_fd" ]]; then
    exec {lock_fd}>&-
  fi
  send_error_alert "vaultctl push failed on $(hostname) at $(date '+%Y-%m-%d %H:%M:%S %Z')"
  ui_err "Push failed"
  return 1
}

run_check() {
  load_env_file
  need_tooling

  local full_mode="0"
  local sample_n
  sample_n="$(resolve_effective_check_sample)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --full)
        full_mode="1"
        shift
        ;;
      --sample)
        sample_n="${2:-}"
        shift 2
        ;;
      *)
        die "Unknown check option: $1"
        ;;
    esac
  done

  local local_dir remote_dir
  local_dir="$(resolve_effective_local)"
  remote_dir="$(resolve_effective_remote)"
  [[ -d "$local_dir" ]] || die "Local vault folder not found: $local_dir"
  [[ "$remote_dir" == *:* ]] || die "Remote must match '<remote>:<path>' (got: $remote_dir)"
  [[ "$sample_n" =~ ^[0-9]+$ ]] || die "--sample must be an integer"

  if systemctl --user is-active --quiet "$PUSH_SERVICE"; then
    record_result "skipped_check_push_active"
    ui_warn "Push service is active; check skipped to avoid false negatives"
    return 0
  fi

  local tmp_files tmp_all total pick
  tmp_files=""
  tmp_all=""
  total=0
  pick=0

  if [[ "$full_mode" != "1" ]]; then
    tmp_all="$(mktemp)"
    tmp_files="$(mktemp)"
    (
      cd "$local_dir"
      find . -type f -printf '%P\n'
    ) >"$tmp_all"
    total="$(wc -l <"$tmp_all" | tr -d ' ')"
    if [[ "$total" == "0" ]]; then
      rm -f "$tmp_all" "$tmp_files"
      ui_warn "No files found for check"
      return 0
    fi
    if (( sample_n <= 0 || sample_n >= total )); then
      pick="$total"
      cp "$tmp_all" "$tmp_files"
    else
      pick="$sample_n"
      if has_cmd shuf; then
        shuf -n "$pick" "$tmp_all" >"$tmp_files"
      else
        head -n "$pick" "$tmp_all" >"$tmp_files"
      fi
    fi
    ui_info "Check sample: ${pick}/${total} files"
  else
    ui_info "Check full dataset"
  fi

  local -a cmd
  cmd=(
    rclone check
    "$local_dir/"
    "$remote_dir/"
    --one-way
    --checkers "${AOS_VAULT_RCLONE_CHECKERS:-8}"
    --log-file "$LOG_FILE"
    --log-level INFO
  )
  if [[ "$full_mode" != "1" ]]; then
    cmd+=(--files-from "$tmp_files")
  fi

  if "${cmd[@]}"; then
    rm -f "${tmp_all:-}" "${tmp_files:-}"
    ui_ok "Check completed"
    return 0
  fi

  rm -f "${tmp_all:-}" "${tmp_files:-}"
  record_result "failed_check"
  send_error_alert "vaultctl check failed on $(hostname) at $(date '+%Y-%m-%d %H:%M:%S %Z')"
  ui_err "Check failed"
  return 1
}

systemd_reload_enable() {
  systemctl --user daemon-reload
  systemctl --user enable --now "$PUSH_TIMER" "$MONITOR_TIMER"
}

run_monitor() {
  load_env_file
  need_cmd systemctl "systemd --user is required"

  local stale_after now last age
  stale_after="$(resolve_effective_stale_after)"
  now="$(date +%s)"

  if systemctl --user is-failed --quiet "$PUSH_SERVICE"; then
    ui_warn "$PUSH_SERVICE is failed -> reset + retry"
    systemctl --user reset-failed "$PUSH_SERVICE" || true
    systemctl --user start --no-block "$PUSH_SERVICE"
    return 0
  fi

  if [[ ! -f "$LAST_SUCCESS_FILE" ]]; then
    ui_warn "No successful push recorded yet -> triggering push"
    systemctl --user start --no-block "$PUSH_SERVICE"
    return 0
  fi

  last="$(cat "$LAST_SUCCESS_FILE" 2>/dev/null || echo 0)"
  if ! [[ "$last" =~ ^[0-9]+$ ]]; then
    ui_warn "Invalid last_success value -> triggering push"
    systemctl --user start --no-block "$PUSH_SERVICE"
    return 0
  fi

  age=$((now - last))
  if (( age > stale_after )); then
    ui_warn "Last push is stale (${age}s > ${stale_after}s) -> triggering push"
    systemctl --user start --no-block "$PUSH_SERVICE"
    return 0
  fi

  ui_ok "Push health OK (last success ${age}s ago)"
}

render_status() {
  load_env_file
  local local_dir remote_dir calendar monitor_interval stale_after lock_wait check_sample alert_on_error
  local_dir="$(resolve_effective_local)"
  remote_dir="$(resolve_effective_remote)"
  calendar="$(resolve_effective_calendar)"
  monitor_interval="$(resolve_effective_monitor_interval)"
  stale_after="$(resolve_effective_stale_after)"
  lock_wait="$(resolve_effective_lock_wait)"
  check_sample="$(resolve_effective_check_sample)"
  alert_on_error="$(resolve_effective_alert_on_error)"

  printf "vaultctl push-only status\n"
  printf "local:   %s\n" "$local_dir"
  printf "remote:  %s\n" "$remote_dir"
  printf "push:    %s (%s / %s)\n" "$calendar" \
    "$(systemctl --user is-enabled "$PUSH_TIMER" 2>/dev/null || echo disabled)" \
    "$(systemctl --user is-active "$PUSH_TIMER" 2>/dev/null || echo inactive)"
  printf "monitor: %s (%s / %s)\n" "$monitor_interval" \
    "$(systemctl --user is-enabled "$MONITOR_TIMER" 2>/dev/null || echo disabled)" \
    "$(systemctl --user is-active "$MONITOR_TIMER" 2>/dev/null || echo inactive)"
  printf "stale-after-seconds: %s\n" "$stale_after"
  printf "lock-file: %s\n" "$LOCK_FILE"
  printf "lock-wait-seconds: %s\n" "$lock_wait"
  printf "check-sample-default: %s\n" "$check_sample"
  printf "alert-on-error: %s\n" "$alert_on_error"

  if [[ -f "$LAST_SUCCESS_FILE" ]]; then
    local ts
    ts="$(cat "$LAST_SUCCESS_FILE" 2>/dev/null || true)"
    if [[ "$ts" =~ ^[0-9]+$ ]]; then
      printf "last-success: %s (%s)\n" "$ts" "$(date -d "@$ts" '+%Y-%m-%d %H:%M:%S %Z' 2>/dev/null || echo n/a)"
    else
      printf "last-success: invalid (%s)\n" "$ts"
    fi
  else
    printf "last-success: never\n"
  fi

  if [[ -f "$LAST_RESULT_FILE" ]]; then
    printf "last-result: %s\n" "$(cat "$LAST_RESULT_FILE" 2>/dev/null || echo unknown)"
  fi

  if [[ -f "$LOG_FILE" ]]; then
    printf "log-file: %s\n" "$LOG_FILE"
  fi
}

show_logs() {
  local lines="${1:-80}"
  local follow="${2:-0}"
  need_cmd journalctl "journalctl is required"

  local -a cmd
  cmd=(journalctl --user -u "$PUSH_SERVICE" -u "$MONITOR_SERVICE" -n "$lines" --no-pager)
  if [[ "$follow" == "1" ]]; then
    cmd=(journalctl --user -u "$PUSH_SERVICE" -u "$MONITOR_SERVICE" -n "$lines" -f)
  fi
  "${cmd[@]}"
}

do_init() {
  local local_dir="${VAULT_LOCAL_DEFAULT}"
  local remote_dir="${VAULT_REMOTE_DEFAULT}"
  local push_calendar="${PUSH_CALENDAR_DEFAULT}"
  local monitor_interval="${MONITOR_INTERVAL_DEFAULT}"
  local stale_after="${STALE_AFTER_DEFAULT}"
  local alert_on_error="${ALERT_ON_ERROR_DEFAULT}"
  local run_now="0"
  local assume_yes="0"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --local)
        local_dir="${2:-}"
        shift 2
        ;;
      --remote)
        remote_dir="${2:-}"
        shift 2
        ;;
      --calendar)
        push_calendar="${2:-}"
        shift 2
        ;;
      --monitor-interval)
        monitor_interval="${2:-}"
        shift 2
        ;;
      --stale-after)
        stale_after="${2:-}"
        shift 2
        ;;
      --alert-on-error)
        alert_on_error="${2:-}"
        shift 2
        ;;
      --run-now)
        run_now="1"
        shift
        ;;
      --yes|-y)
        assume_yes="1"
        shift
        ;;
      *)
        die "Unknown init option: $1"
        ;;
    esac
  done

  local_dir="$(realpath_safe "$local_dir")"

  if [[ "$assume_yes" != "1" ]]; then
    ui_title "vaultctl init (push-only to gdrive)"
    local_dir="$(ui_input "Local vault path:" "$local_dir")"
    remote_dir="$(ui_input "Remote path (<remote>:<path>):" "$remote_dir")"
    push_calendar="$(ui_input "Push schedule (OnCalendar):" "$push_calendar")"
    monitor_interval="$(ui_input "Monitor interval (OnUnitActiveSec):" "$monitor_interval")"
    stale_after="$(ui_input "Stale threshold in seconds:" "$stale_after")"
    alert_on_error="$(ui_input "Alert on error (0/1):" "$alert_on_error")"
    if ui_confirm "Initial push direkt ausfuehren?"; then
      run_now="1"
    fi
  fi

  [[ -d "$local_dir" ]] || die "Local vault folder not found: $local_dir"
  [[ "$remote_dir" == *:* ]] || die "Remote must match '<remote>:<path>'"
  [[ "$stale_after" =~ ^[0-9]+$ ]] || die "--stale-after must be an integer"
  [[ "$alert_on_error" == "0" || "$alert_on_error" == "1" ]] || die "--alert-on-error must be 0 or 1"

  need_tooling
  write_units "$local_dir" "$remote_dir" "$push_calendar" "$monitor_interval" "$stale_after" "$alert_on_error"
  systemd_reload_enable
  ui_ok "Installed and enabled: $PUSH_TIMER + $MONITOR_TIMER"

  if [[ "$run_now" == "1" ]]; then
    ui_info "Starting initial push via systemd service"
    systemctl --user start "$PUSH_SERVICE"
    systemctl --user status "$PUSH_SERVICE" --no-pager || true
  fi
}

menu() {
  local choice=""
  while true; do
    choice="$(ctl_choose_one "vaultctl" \
      "Status" \
      "Init" \
      "Push now" \
      "Push dry-run" \
      "Check sample" \
      "Check full" \
      "Logs" \
      "Watch" \
      "Exit")" || return 0

    case "$choice" in
      "Status") render_status ;;
      "Init") do_init ;;
      "Push now") systemctl --user start "$PUSH_SERVICE" ;;
      "Push dry-run") run_push 1 ;;
      "Check sample") run_check ;;
      "Check full") run_check --full ;;
      "Logs") show_logs 120 0 ;;
      "Watch") watch_status ;;
      "Exit") return 0 ;;
    esac

    ui_pause
  done
}

watch_status() {
  local i=0
  while true; do
    clear || true
    render_status
    printf "\n(next refresh in 5s, Ctrl+C to stop)\n"
    sleep 5
    i=$((i + 1))
    if (( i % 6 == 0 )); then
      run_monitor || true
    fi
  done
}

usage() {
  cat <<'EOT'
vaultctl - push-only ~/vault -> gdrive (systemd + monitoring)

Usage:
  vaultctl                    # interactive menu
  vaultctl init [opts]        # install/update user units
  vaultctl push [--dry-run]   # run push immediately (direct, not systemd)
  vaultctl check [--full|--sample N]
  vaultctl status             # show push + monitor status
  vaultctl logs [n] [--follow]
  vaultctl watch
  vaultctl systemd-run        # start push via systemd service
  vaultctl systemd-restart    # restart timers

Init options:
  --local <path>
  --remote <remote:path>
  --calendar <OnCalendar>
  --monitor-interval <sec|min>
  --stale-after <seconds>
  --alert-on-error <0|1>
  --run-now
  --yes
EOT
}

main() {
  local cmd="${1:-menu}"
  shift || true

  case "$cmd" in
    menu) menu ;;
    init) do_init "$@" ;;
    push)
      if [[ "${1:-}" == "--dry-run" ]]; then
        run_push 1
      else
        run_push 0
      fi
      ;;
    check)
      run_check "$@"
      ;;
    status) render_status ;;
    logs)
      local n="80"
      local f="0"
      if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
        n="$1"
        shift
      fi
      if [[ "${1:-}" == "--follow" ]]; then
        f="1"
      fi
      show_logs "$n" "$f"
      ;;
    watch) watch_status ;;
    systemd-run)
      systemctl --user start "$PUSH_SERVICE"
      ;;
    systemd-restart)
      systemctl --user daemon-reload
      systemctl --user restart "$PUSH_TIMER" "$MONITOR_TIMER"
      ;;
    _systemd-push)
      run_push 0
      ;;
    _systemd-monitor)
      run_monitor
      ;;
    help|-h|--help) usage ;;
    *)
      die "Unknown command: $cmd"
      ;;
  esac
}

main "$@"
