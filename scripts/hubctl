#!/usr/bin/env bash
set -euo pipefail

# hubctl — unified CLI for aos-hub
# Simplified architecture: group commands, delegate everything, no nested prefixes

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Codex session helper
source "$ROOT_DIR/scripts/lib/codex-subcmd.sh" 2>/dev/null || true
codex_subcmd_maybe "main" "hubctl" "$@" && exit 0

# Load env
source "$ROOT_DIR/scripts/lib/aos-env.sh" 2>/dev/null || true
aos_env_load "" "$ROOT_DIR" 2>/dev/null || true

# Load UI lib
source "$SCRIPT_DIR/ctl-lib.sh" 2>/dev/null || true

# Helpers
hub_die() { ui_err "$*"; exit 1; }
exec_ctl() { local path="$ROOT_DIR/$1"; shift; [[ -x "$path" ]] || hub_die "not found: $path"; exec "$path" "$@"; }

# ============================================================================
# USAGE
# ============================================================================

usage() {
  cat <<'EOF'
hubctl — unified CLI for aos-hub

Usage:
  hubctl <command> [args...]

Service Commands:
  bridge <args>       Bridge control (bridgectl)
  router <args>       Router control (routerctl)
  index <args>        Index Node control (indexctl)
  node <args>         Alias for index

Dev Mode (user services):
  dev status          Show dev service status
  dev start [target]  Start dev services (index|router|bridge|all)
  dev stop [target]   Stop dev services
  dev restart [target] Restart dev services
  dev logs [target]   Follow dev logs

Tool Commands:
  core4 <args>        Core4 tracker (core4ctl)
  fire <args>         Fire Map commands
  sync <args>         Vault sync (syncctl)
  git <args>          Git operations (gitctl)
  backup <args>       Backup management (backupctl)
  mount <args>        Mount control (mountctl)
  hook <args>         Hook management (hookctl)
  tent <args>         Tent commands (tentctl)
  gas <args>          GAS operations (gasctl)
  door <args>         Door commands (doorctl)
  game <args>         Game commands (gamectl)
  voice <args>        Voice commands (voicectl)
  tele <args>         Telegram (telectl)
  mobileapp <args>    Mobile/PWA tooling (mobileappctl)

Utility:
  list                List all available commands
  status [opts]       Compact combined status (+ compressed logs)
  doctor              System health check
  help                Show this help

Examples:
  hubctl bridge health
  hubctl status
  hubctl status --watch 2 --logs 2
  hubctl dev restart bridge
  hubctl core4 sources
  hubctl fire status
  hubctl doctor

EOF
}

# ============================================================================
# COMMAND GROUPS
# ============================================================================

# Service delegation (direct exec)
delegate_service() {
  case "$1" in
    bridge) exec_ctl "bridge/bridgectl" "${@:2}" ;;
    router) exec_ctl "router/routerctl" "${@:2}" ;;
    index|node) exec_ctl "scripts/indexctl" "${@:2}" ;;
    *) return 1 ;;
  esac
}

# Tool delegation (direct exec)
delegate_tool() {
  case "$1" in
    core4) exec_ctl "core4/python-core4/core4ctl" "${@:2}" ;;
    sync) exec_ctl "scripts/syncctl" "${@:2}" ;;
    git) exec_ctl "scripts/gitctl" "${@:2}" ;;
    backup) exec_ctl "scripts/backupctl" "${@:2}" ;;
    mount) exec_ctl "scripts/mountctl" "${@:2}" ;;
    hook) exec_ctl "scripts/hookctl" "${@:2}" ;;
    tent) exec_ctl "game/python-tent-bot/tentctl" "${@:2}" ;;
    gas) exec_ctl "scripts/gasctl" "${@:2}" ;;
    firectl) exec_ctl "scripts/firectl" "${@:2}" ;;
    tele) exec_ctl "scripts/telectl" "${@:2}" ;;
    door) exec_ctl "door/cli/doorctl" "${@:2}" ;;
    game) exec_ctl "scripts/gamectl" "${@:2}" ;;
    voice) exec_ctl "scripts/voicectl" "${@:2}" ;;
    mobileapp|mobileappctl|pwa) exec_ctl "scripts/mobileappctl" "${@:2}" ;;
    *) return 1 ;;
  esac
}

# ============================================================================
# DEV MODE (user services)
# ============================================================================

DEV_INDEX_UNIT="${AOS_INDEX_DEV_UNIT:-aos-index-dev.service}"
DEV_ROUTER_UNIT="${AOS_ROUTER_DEV_UNIT:-aos-router-dev.service}"
DEV_BRIDGE_UNIT="${AOS_BRIDGE_DEV_UNIT:-aos-bridge-dev.service}"
PROD_INDEX_UNIT="${AOS_INDEX_SERVICE:-aos-index.service}"
PROD_ROUTER_UNIT="${AOS_ROUTER_SERVICE:-aos-router.service}"
PROD_BRIDGE_UNIT="${AOS_BRIDGE_SERVICE:-aos-bridge.service}"

have_cmd() { command -v "$1" >/dev/null 2>&1; }

svc_state() {
  local scope="$1" unit="$2"
  if [[ "$scope" == "user" ]]; then
    systemctl --user is-active "$unit" 2>/dev/null || echo "n/a"
  else
    systemctl is-active "$unit" 2>/dev/null || echo "n/a"
  fi
}

svc_enabled() {
  local scope="$1" unit="$2"
  if [[ "$scope" == "user" ]]; then
    systemctl --user is-enabled "$unit" 2>/dev/null || echo "n/a"
  else
    systemctl is-enabled "$unit" 2>/dev/null || echo "n/a"
  fi
}

http_probe_compact() {
  local url="$1"
  if ! have_cmd curl; then
    printf "curl?"
    return 0
  fi
  local code
  code="$(curl -sS -o /dev/null -m 1 -w "%{http_code}" "$url" 2>/dev/null || true)"
  if [[ -z "$code" || "$code" == "000" ]]; then
    printf "down"
  else
    printf "%s" "$code"
  fi
}

compact_journal_tail() {
  local scope="$1" unit="$2" lines="${3:-1}"
  have_cmd journalctl || { printf "-"; return 0; }

  local -a cmd=(journalctl --no-pager -n "$lines" -o short-iso)
  [[ "$scope" == "user" ]] && cmd+=(--user)
  cmd+=(-u "$unit")

  local out
  out="$("${cmd[@]}" 2>/dev/null | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//' || true)"
  [[ -n "$out" ]] || { printf "-"; return 0; }

  local joined
  joined="$(printf "%s\n" "$out" | awk 'NF{printf "%s%s", (n++?" || ":""), $0} END{if (n==0) printf "-"}')"
  if ((${#joined} > 140)); then
    joined="${joined:0:137}..."
  fi
  printf "%s" "$joined"
}

pick_log_scope_unit() {
  local prod_unit="$1" dev_unit="$2"
  local prod_state dev_state
  prod_state="$(svc_state system "$prod_unit")"
  dev_state="$(svc_state user "$dev_unit")"

  if [[ "$dev_state" == "active" ]]; then
    printf "user|%s" "$dev_unit"
  elif [[ "$prod_state" == "active" ]]; then
    printf "system|%s" "$prod_unit"
  elif [[ "$dev_state" != "n/a" ]]; then
    printf "user|%s" "$dev_unit"
  else
    printf "system|%s" "$prod_unit"
  fi
}

status_row() {
  local name="$1" prod_unit="$2" dev_unit="$3" health_url="${4:-}" log_lines="${5:-1}"
  local prod_state dev_state health="-"
  prod_state="$(svc_state system "$prod_unit")"
  dev_state="$(svc_state user "$dev_unit")"
  if [[ -n "$health_url" ]]; then
    health="$(http_probe_compact "$health_url")"
  fi

  local picked scope unit logline
  picked="$(pick_log_scope_unit "$prod_unit" "$dev_unit")"
  scope="${picked%%|*}"
  unit="${picked#*|}"
  logline="$(compact_journal_tail "$scope" "$unit" "$log_lines")"

  printf "%-7s  prod=%-9s dev=%-9s health=%-6s log[%s]=%s\n" \
    "$name" "$prod_state" "$dev_state" "$health" "$scope" "$logline"
}

render_compact_status() {
  local log_lines="${1:-1}"
  printf "hubctl status (compact)\n"
  printf "time: %s\n\n" "$(date '+%Y-%m-%d %H:%M:%S')"
  status_row "index"  "$PROD_INDEX_UNIT"  "$DEV_INDEX_UNIT"  "http://127.0.0.1:8799/health" "$log_lines"
  status_row "router" "$PROD_ROUTER_UNIT" "$DEV_ROUTER_UNIT" ""                               "$log_lines"
  status_row "bridge" "$PROD_BRIDGE_UNIT" "$DEV_BRIDGE_UNIT" "http://127.0.0.1:8080/health" "$log_lines"
}

status_action() {
  local watch=0
  local interval=2
  local log_lines=1

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -w|--watch)
        watch=1
        if [[ -n "${2:-}" && "${2:-}" =~ ^[0-9]+$ ]]; then
          interval="$2"
          shift
        fi
        ;;
      --watch=*)
        watch=1
        interval="${1#*=}"
        ;;
      --logs)
        log_lines="${2:-1}"
        shift
        ;;
      --logs=*)
        log_lines="${1#*=}"
        ;;
      --no-logs)
        log_lines=0
        ;;
      -h|--help|help)
        cat <<'EOF'
hubctl status — compact combined status

Usage:
  hubctl status [--watch [SEC]] [--logs N|--no-logs]

Examples:
  hubctl status
  hubctl status --logs 2
  hubctl status --watch 2 --logs 1
EOF
        return 0
        ;;
      *)
        hub_die "unknown status option: $1"
        ;;
    esac
    shift || true
  done

  [[ "$interval" =~ ^[0-9]+$ ]] || interval=2
  [[ "$log_lines" =~ ^[0-9]+$ ]] || log_lines=1

  if [[ "$watch" == "1" ]]; then
    while true; do
      printf '\033[2J\033[H'
      render_compact_status "$log_lines"
      printf "\nwatch: %ss  ctrl-c to exit\n" "$interval"
      sleep "$interval"
    done
  fi

  render_compact_status "$log_lines"
}

get_dev_units() {
  local target="${1:-all}"
  case "$target" in
    all|"") echo "$DEV_INDEX_UNIT $DEV_ROUTER_UNIT $DEV_BRIDGE_UNIT" ;;
    index) echo "$DEV_INDEX_UNIT" ;;
    router) echo "$DEV_ROUTER_UNIT" ;;
    bridge) echo "$DEV_BRIDGE_UNIT" ;;
    *) hub_die "unknown target: $target (use: index|router|bridge|all)" ;;
  esac
}

dev_status() {
  local target="${1:-all}"
  echo "Dev services (user scope):"
  for unit in $(get_dev_units "$target"); do
    local active enabled
    active=$(systemctl --user is-active "$unit" 2>/dev/null || echo "inactive")
    enabled=$(systemctl --user is-enabled "$unit" 2>/dev/null || echo "disabled")
    printf "  %-28s active=%-10s enabled=%s\n" "$unit" "$active" "$enabled"
  done
}

dev_action() {
  local action="$1"
  local target="${2:-all}"
  local units
  units=$(get_dev_units "$target")

  case "$action" in
    start|stop|restart)
      systemctl --user "$action" $units
      ;;
    logs)
      local args=()
      for unit in $units; do
        args+=("-u" "$unit")
      done
      journalctl --user "${args[@]}" -n 100 -f
      ;;
    *)
      hub_die "unknown dev action: $action"
      ;;
  esac
}

# ============================================================================
# FIRE COMMANDS
# ============================================================================

fire_action() {
  local cmd="${1:-}"
  shift || true

  local timer="${AOS_FIREMAP_TIMER_UNIT:-aos-firemap-weekly.timer}"
  local service="${timer%.timer}.service"

  case "$cmd" in
    setup) exec_ctl "scripts/setup-fire-map.sh" "$@" ;;
    run|sync) exec_ctl "firemap" sync "$@" ;;
    status) exec_ctl "firemap" status ;;
    list) exec_ctl "firemap" list ;;
    enable) systemctl --user enable --now "$timer" ;;
    disable) systemctl --user disable --now "$timer" ;;
    start) systemctl --user start "$timer" ;;
    stop) systemctl --user stop "$timer" ;;
    logs) journalctl --user -u "$service" -n 100 -f ;;
    ""|-h|--help|help)
      cat <<'EOF'
hubctl fire — Fire Map scheduling + sync

Commands:
  setup         Install Taskwarrior config + weekly timer
  enable        Enable + start weekly timer
  disable       Disable + stop weekly timer
  start|stop    Start/stop weekly timer
  status        Show Fire Map status (current week)
  list          List Fire Maps
  run|sync      Sync Fire Maps to Taskwarrior now
  logs          Follow weekly sync logs
EOF
      ;;
    *) hub_die "unknown fire command: $cmd" ;;
  esac
}

# ============================================================================
# DOCTOR (simplified)
# ============================================================================

doctor() {
  echo "=== aos-hub doctor ==="
  echo ""

  # Run full doctor if available
  if [[ -x "$ROOT_DIR/scripts/aos-doctor" ]]; then
    "$ROOT_DIR/scripts/aos-doctor"
  else
    echo "aos-doctor not found, showing basic status..."
    echo ""

    # Show production services
    echo "Production services (system):"
    for unit in aos-index.service aos-router.service aos-bridge.service; do
      local active enabled
      active=$(systemctl is-active "$unit" 2>/dev/null || echo "inactive")
      enabled=$(systemctl is-enabled "$unit" 2>/dev/null || echo "disabled")
      printf "  %-28s active=%-10s enabled=%s\n" "$unit" "$active" "$enabled"
    done
    echo ""

    # Show dev services
    dev_status all
    echo ""

    # Quick health checks
    echo "Health checks:"
    if curl -fsS http://127.0.0.1:8799/health >/dev/null 2>&1; then
      echo "  ✓ Index Node (8799)"
    else
      echo "  ✗ Index Node (8799) unreachable"
    fi

    if curl -fsS http://127.0.0.1:8080/health >/dev/null 2>&1; then
      echo "  ✓ Bridge (8080)"
    else
      echo "  ✗ Bridge (8080) unreachable"
    fi
  fi
}

# ============================================================================
# LIST
# ============================================================================

list_commands() {
  cat <<'EOF'
Available commands:

Services:
  bridge, router, index

Dev Mode:
  dev status|start|stop|restart|logs [target]

Tools:
  core4, fire, sync, git, backup, mount, hook
  tent, gas, door, game, voice, tele, firectl

Utility:
  list, status, doctor, help

For details: hubctl <command> --help
EOF
}

# ============================================================================
# MAIN DISPATCH
# ============================================================================

cmd="${1:-help}"
[[ "$cmd" != "help" ]] && shift || true

case "$cmd" in
  -h|--help|help) usage ;;
  list) list_commands ;;
  status) status_action "$@" ;;
  doctor) doctor ;;

  # Services (delegate)
  bridge|router|index|node)
    delegate_service "$cmd" "$@"
    ;;

  # Dev mode
  dev)
    sub="${1:-status}"
    shift || true
    case "$sub" in
      status) dev_status "$@" ;;
      start|stop|restart|logs) dev_action "$sub" "$@" ;;
      *) hub_die "unknown dev command: $sub (use: status|start|stop|restart|logs)" ;;
    esac
    ;;

  # Fire (special handling)
  fire)
    fire_action "$@"
    ;;

  # Tools (delegate)
  core4|sync|git|backup|mount|hook|tent|gas|firectl|tele|door|game|voice|mobileapp|mobileappctl|pwa)
    delegate_tool "$cmd" "$@"
    ;;

  *)
    echo "ERROR: unknown command: $cmd" >&2
    echo "" >&2
    usage >&2
    exit 1
    ;;
esac
