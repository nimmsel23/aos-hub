#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/ctl-lib.sh"
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/lib/aos-env.sh"
aos_env_load "" "$ROOT_DIR" 2>/dev/null || true

BASE_URL="${AOS_INDEX_HEALTH_URL:-http://127.0.0.1:8799}"
BASE_URL="${BASE_URL%/health}"
PWA_BASE_DIR="$ROOT_DIR/index-node/public/pwa"
PWA_NAMES=(core4 fire focus)
PWA_FILES=(index.html app.js style.css)
PWA_TAILNET_URL_OVERRIDE="${AOS_PWA_TAILNET_URL:-${MOBILEAPPCTL_TAILNET_URL:-}}"

usage() {
  cat <<EOF
Usage: mobileappctl <command> [args]
Commands:
  list           show registry table for available PWAs
  health [target] curl /pwa/<name>/ for each PWA and report HTTP status
                 target: local (default) | tailnet | all
  serve-status   show tailscale serve status + check PWA endpoints via tailnet URL
  open [name]    xdg-open the named PWA (all if omitted)
  check          verify index.html, app.js, style.css in each PWA
  changelog      show index-node/public/pwa/CHANGELOG.md
  routes         print canonical /pwa/<name>/ URLs
  new <name>     scaffold a new PWA stub (index/app/style)
  doctor         run check + health and summarize results
  help           show this message

Optional env:
  AOS_PWA_TAILNET_URL / MOBILEAPPCTL_TAILNET_URL
                 force a specific tailnet/funnel base URL (e.g. https://ideapad.tail... )
EOF
}

pwa_dir() {
  local name="${1?}"
  printf "%s/%s" "$PWA_BASE_DIR" "$name"
}

pwa_route() {
  local name="${1?}"
  printf "/pwa/%s/" "$name"
}

tailscale_serve_status_text() {
  has_cmd tailscale || return 1
  tailscale serve status 2>/dev/null
}

normalized_https_base_url() {
  local raw="${1:-}"
  raw="$(printf "%s" "$raw" | tr -d '\r' | xargs 2>/dev/null || true)"
  [[ -n "$raw" ]] || return 1
  case "$raw" in
    http://*|https://*) ;;
    *) raw="https://$raw" ;;
  esac
  printf "%s\n" "${raw%/}"
}

tailscale_self_dns_url() {
  has_cmd tailscale || return 1
  local dns=""

  if has_cmd jq; then
    dns="$(tailscale status --json 2>/dev/null | jq -r '.Self.DNSName // empty | sub("\\.$"; "")' 2>/dev/null | head -n 1)"
  else
    dns="$(tailscale status --json 2>/dev/null | sed -n 's/^[[:space:]]*"DNSName": "\([^"]*\)\\.",$/\1/p' | head -n 1)"
  fi

  [[ -n "$dns" ]] || return 1
  printf "https://%s\n" "$dns"
}

tailscale_serve_url_from_status() {
  local status_text="${1:-}"
  local preferred_url="${2:-}"
  local preferred_self_url="${3:-}"
  [[ -n "$status_text" ]] || return 1

  printf "%s\n" "$status_text" | awk -v preferred="$preferred_url" -v preferred_self="$preferred_self_url" '
    /^https:\/\// {
      current=$1
      if (first == "") first=$1
      if (current == preferred) preferred_seen=1
      if (current == preferred_self) preferred_self_seen=1
      next
    }
    /^\|--/ {
      if (current != "" && $0 ~ /\/pwa\/[[:space:]]+proxy[[:space:]]+http:\/\/127\.0\.0\.1:8799/) {
        print current
        found=1
        exit
      }
      if (current != "" && root_index == "" && $0 ~ /^\|--[[:space:]]+\/[[:space:]]+proxy[[:space:]]+http:\/\/127\.0\.0\.1:8799([[:space:]]|$)/) {
        root_index=current
      }
    }
    END {
      if (!found && preferred != "" && preferred_seen) {
        print preferred
        exit
      }
      if (!found && preferred_self != "" && preferred_self_seen) {
        print preferred_self
        exit
      }
      if (!found && root_index != "") {
        print root_index
        exit
      }
      if (!found && first != "") print first
    }
  '
}

tailscale_serve_url() {
  local status_text
  local preferred_url=""
  local preferred_self_url=""
  status_text="$(tailscale_serve_status_text || true)"
  preferred_url="$(normalized_https_base_url "$PWA_TAILNET_URL_OVERRIDE" || true)"
  preferred_self_url="$(tailscale_self_dns_url || true)"
  tailscale_serve_url_from_status "$status_text" "$preferred_url" "$preferred_self_url"
}

health_for_base() {
  local label="${1:-health}"
  local base="${2:-}"
  local failures=0
  local name route url status location

  [[ -n "$base" ]] || return 2
  base="${base%/}"

  for name in "${PWA_NAMES[@]}"; do
    route="$(pwa_route "$name")"
    url="$base$route"
    status="$(curl -s -o /dev/null -w "%{http_code}" "$url" || true)"
    if [[ "$status" =~ ^2[0-9][0-9]$ ]]; then
      msg "[$label] $name -> $status ($url)"
    elif [[ "$status" =~ ^3[0-9][0-9]$ ]]; then
      location="$(curl -sSI "$url" | awk 'BEGIN{IGNORECASE=1} /^location:/{sub(/\r$/,"",$2); print $2; exit}' || true)"
      warn "[$label] $name -> redirect ($status) ${location:-<no-location>} ($url)"
      failures=$((failures + 1))
    else
      warn "[$label] $name -> fail (${status:-?}) ($url)"
      failures=$((failures + 1))
    fi
  done
  return $failures
}

list_cmd() {
  printf "%-8s %-16s %-12s %-12s %-10s %-10s\n" "name" "route" "dir" "index.html" "app.js" "style.css"
  for name in "${PWA_NAMES[@]}"; do
    local dir
    dir="$(pwa_dir "$name")"
    local has_dir="no"
    [[ -d "$dir" ]] && has_dir="yes"
    local index_status="no"
    local app_status="no"
    local style_status="no"
    [[ -f "$dir/index.html" ]] && index_status="yes"
    [[ -f "$dir/app.js" ]] && app_status="yes"
    [[ -f "$dir/style.css" ]] && style_status="yes"
    printf "%-8s %-16s %-12s %-12s %-10s %-10s\n" \
      "$name" "$(pwa_route "$name")" "$has_dir" "$index_status" "$app_status" "$style_status"
  done
}

health_cmd() {
  local target="${1:-local}"
  local ts_url=""
  local rc=0

  case "$target" in
    ""|local)
      health_for_base "local" "$BASE_URL"
      return $?
      ;;
    tailnet|ts)
      ts_url="$(tailscale_serve_url || true)"
      [[ -n "$ts_url" ]] || { warn "tailscale serve URL not found (tailscale serve status)"; return 2; }
      health_for_base "tailnet" "$ts_url"
      return $?
      ;;
    all)
      set +e
      health_for_base "local" "$BASE_URL"; local_rc=$?
      ts_url="$(tailscale_serve_url || true)"
      if [[ -n "$ts_url" ]]; then
        health_for_base "tailnet" "$ts_url"; tailnet_rc=$?
      else
        warn "[tailnet] tailscale serve URL not found"
        tailnet_rc=2
      fi
      set -e
      (( local_rc == 0 && tailnet_rc == 0 )) || rc=1
      return "$rc"
      ;;
    *)
      die "Usage: mobileappctl health [local|tailnet|all]"
      ;;
  esac
}

serve_status_cmd() {
  local ts_url=""
  local status_text=""
  local has_pwa_proxy=0
  local sample_name=""
  local sample_route=""
  local sample_url=""
  local sample_status=""
  local sample_location=""

  if ! has_cmd tailscale; then
    die "tailscale not installed"
  fi

  msg "tailscale serve status:"
  status_text="$(tailscale_serve_status_text)" || return $?
  printf "%s\n" "$status_text"
  echo ""

  local preferred_url=""
  local preferred_self_url=""
  preferred_url="$(normalized_https_base_url "$PWA_TAILNET_URL_OVERRIDE" || true)"
  preferred_self_url="$(tailscale_self_dns_url || true)"
  ts_url="$(tailscale_serve_url_from_status "$status_text" "$preferred_url" "$preferred_self_url" || true)"
  if [[ -z "$ts_url" ]]; then
    warn "No tailscale serve HTTPS URL found."
    warn "PWAs under /pwa/* will not be reachable from tailnet until serve publishes the index-node route."
    warn "Hint: nodectl serve on  (or tailscale serve --bg 8799)"
    return 1
  fi

  if printf "%s\n" "$status_text" | rg -q '^\|--[[:space:]]+/pwa/[[:space:]]+proxy[[:space:]]+http://127\.0\.0\.1:8799'; then
    has_pwa_proxy=1
  fi

  if [[ -n "$preferred_url" && "$ts_url" == "$preferred_url" ]]; then
    msg "Detected tailnet URL (env override): $ts_url"
  elif [[ -n "$preferred_self_url" && "$ts_url" == "$preferred_self_url" ]]; then
    msg "Detected tailnet URL (Self.DNSName): $ts_url"
  else
    msg "Detected tailnet URL: $ts_url"
  fi
  echo ""
  health_for_base "tailnet" "$ts_url" || true

  sample_name="${PWA_NAMES[0]}"
  sample_route="$(pwa_route "$sample_name")"
  sample_url="${ts_url%/}${sample_route}"
  sample_status="$(curl -s -o /dev/null -w "%{http_code}" "$sample_url" || true)"
  sample_location="$(curl -sSI "$sample_url" | awk 'BEGIN{IGNORECASE=1} /^location:/{sub(/\r$/,"",$2); print $2; exit}' || true)"

  if [[ "$sample_status" =~ ^3[0-9][0-9]$ && "$sample_location" == "$sample_route" ]]; then
    echo ""
    warn "Detected redirect loop candidate on tailnet: $sample_route -> $sample_location (HTTP $sample_status)"
    if (( has_pwa_proxy )); then
      warn "Likely cause: tailscale serve '/pwa/' proxy strips the /pwa prefix before forwarding to index-node."
      warn "Recommended fix: remove '/pwa/' serve mapping and keep only '/' -> http://127.0.0.1:8799 (plus other API/bridge mappings as needed)."
    fi
    return 1
  fi
}

open_cmd() {
  local targets=()
  if (( $# == 0 )); then
    targets=("${PWA_NAMES[@]}")
  else
    targets=("$@")
  fi
  if ! has_cmd xdg-open; then
    warn "xdg-open not available; cannot open PWAs"
    return 1
  fi
  local failures=0
  for name in "${targets[@]}"; do
    local route url
    route="$(pwa_route "$name")"
    url="$BASE_URL$route"
    if ! xdg-open "$url" >/dev/null 2>&1; then
      warn "failed to xdg-open $url"
      failures=$((failures + 1))
    fi
  done
  return $failures
}

check_cmd() {
  local missing=0
  for name in "${PWA_NAMES[@]}"; do
    local dir file
    dir="$(pwa_dir "$name")"
    for file in "${PWA_FILES[@]}"; do
      if [[ ! -f "$dir/$file" ]]; then
        warn "missing $file for $name in $dir"
        missing=1
      fi
    done
  done
  return $missing
}

changelog_cmd() {
  local file="$PWA_BASE_DIR/CHANGELOG.md"
  [[ -f "$file" ]] || die "changelog not found at $file"
  if [[ -t 1 ]] && has_cmd less; then
    less "$file"
  else
    cat "$file"
  fi
}

routes_cmd() {
  for name in "${PWA_NAMES[@]}"; do
    printf "%s%s\n" "$BASE_URL" "$(pwa_route "$name")"
  done
}

new_cmd() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "Usage: mobileappctl new <name>"
  local dir
  dir="$(pwa_dir "$name")"
  if [[ -e "$dir" ]]; then
    die "$dir already exists"
  fi
  mkdir -p "$dir"
  local core_tab="tab"
  local fire_tab="tab"
  local focus_tab="tab"
  local hub_tab="tab"
  [[ "$name" == "core4" ]] && core_tab="tab active"
  [[ "$name" == "fire" ]] && fire_tab="tab active"
  [[ "$name" == "focus" ]] && focus_tab="tab active"
  cat <<EOF >"$dir/index.html"
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>αOS · ${name}</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <header class="topbar">
    <span class="brand">αOS</span>
    <nav class="tabs">
      <a class="$core_tab" href="/pwa/core4/">CORE</a>
      <a class="$fire_tab" href="/pwa/fire/">FIRE</a>
      <a class="$focus_tab" href="/pwa/focus/">FOCUS</a>
      <a class="$hub_tab" href="/">HUB</a>
    </nav>
  </header>
  <main class="wrap">
    <h1>αOS · ${name}</h1>
    <p class="intro">Placeholder for the ${name} progressive web app.</p>
  </main>
  <script src="app.js"></script>
</body>
</html>
EOF
  cat <<EOF >"$dir/app.js"
"use strict";

// TODO: wire ${name} runtime logic here.
EOF
  cat <<'EOF' >"$dir/style.css"
:root {
  --bg:       #0b0c0f;
  --surface:  #12141a;
  --text:     #e9edf2;
  --muted:    #8a94a0;
  --line:     #1d212b;
  --radius:   18px;
  --focus:    #6a9cf5;
  --focus-dim: rgba(106,156,245,.12);
  --focus-ring: rgba(106,156,245,.28);
  --ring-bg:  #1d222e;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100dvh;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px;
  background: var(--surface);
  border-bottom: 1px solid var(--line);
  position: sticky;
  top: 0;
  z-index: 10;
}

.brand {
  font-size: 12px;
  letter-spacing: 0.4em;
  color: var(--muted);
}

.tabs {
  display: flex;
  gap: 8px;
}

.tab {
  padding: 6px 12px;
  border-radius: 999px;
  border: 1px solid var(--line);
  text-decoration: none;
  font-size: 11px;
  letter-spacing: 0.12em;
  color: var(--muted);
  font-weight: 700;
}

.tab.active {
  border-color: var(--focus);
  color: var(--text);
  background: rgba(106,156,245,0.15);
}

.wrap {
  padding: 32px 20px;
}

.intro {
  margin-top: 12px;
  color: var(--muted);
}
EOF
}

doctor_cmd() {
  local check_status=0
  local local_health_status=0
  local tailnet_health_status=0
  set +e
  check_cmd
  check_status=$?
  health_cmd local
  local_health_status=$?
  health_cmd tailnet
  tailnet_health_status=$?
  set -e
  if [[ $check_status -eq 0 && $local_health_status -eq 0 && $tailnet_health_status -eq 0 ]]; then
    msg "doctor: all checks passed"
    return 0
  fi
  warn "doctor: check=$check_status local=$local_health_status tailnet=$tailnet_health_status"
  return 1
}

cmd="${1:-help}"
shift || true
case "$cmd" in
  list) list_cmd ;; 
  health) health_cmd "$@" ;; 
  serve-status|ts-status) serve_status_cmd ;;
  open) open_cmd "$@" ;; 
  check) check_cmd ;; 
  changelog) changelog_cmd ;; 
  routes) routes_cmd ;; 
  new) new_cmd "$@" ;; 
  doctor) doctor_cmd ;; 
  help|-h|--help) usage ;; 
  *)
    die "Unknown command: $cmd"
    ;;
esac
