#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd -P)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd -P)"
CANONICAL="$ROOT_DIR/game/fire/firectl"

usage() {
  cat <<EOF
firectl — compatibility wrapper

Canonical implementation:
  game/fire/firectl

Usage:
  scripts/firectl <args...>
EOF
}

case "${1:-}" in
  help|--help|-h|"")
    if [[ -x "$CANONICAL" ]]; then
      exec "$CANONICAL" help
    fi
    usage
    ;;
  *)
    if [[ -x "$CANONICAL" ]]; then
      exec "$CANONICAL" "$@"
    fi
    printf "ERR: missing canonical firectl: %s\n" "$CANONICAL" >&2
    exit 1
    ;;
esac
