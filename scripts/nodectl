#!/usr/bin/env bash
set -euo pipefail

# nodectl — index-node control (compatibility wrapper)
# Simplified: delegates most work to indexctl, hubctl, or direct npm commands

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Load libs
source "$ROOT_DIR/scripts/ctl-lib.sh" 2>/dev/null || true
source "$ROOT_DIR/scripts/lib/aos-env.sh" 2>/dev/null || true
aos_env_load "" "$ROOT_DIR" 2>/dev/null || true

# Config
INDEX_ROOT="${AOS_INDEX_ROOT:-$ROOT_DIR/index-node}"
NODE_HOST="${AOS_INDEX_HOST:-127.0.0.1}"
NODE_PORT="${AOS_INDEX_PORT:-8799}"
INDEXCTL_BIN="${INDEXCTL_BIN:-$ROOT_DIR/scripts/indexctl}"

[[ -d "$INDEX_ROOT" ]] || { echo "ERROR: index-node not found: $INDEX_ROOT" >&2; exit 1; }

# ============================================================================
# HELPERS
# ============================================================================

has_cmd() { command -v "$1" >/dev/null 2>&1; }

health_check() {
  if curl --max-time 2 -fsS "http://${NODE_HOST}:${NODE_PORT}/menu" >/dev/null 2>&1; then
    echo "✓ Index Node healthy (http://${NODE_HOST}:${NODE_PORT})"
  else
    echo "✗ Index Node unreachable (http://${NODE_HOST}:${NODE_PORT})"
  fi
}

ts_url() {
  has_cmd tailscale && tailscale serve status 2>/dev/null | awk '/^https:\/\//{print $1; exit}' || true
}

best_url() {
  local ts
  ts=$(ts_url)
  if [[ -n "$ts" ]]; then
    echo "$ts"
  else
    echo "http://${NODE_HOST}:${NODE_PORT}"
  fi
}

open_url() {
  local url="$1"
  if has_cmd xdg-open; then
    xdg-open "$url" >/dev/null 2>&1 &
  else
    echo "$url"
  fi
}

delegate_indexctl() {
  if [[ -x "$INDEXCTL_BIN" ]]; then
    exec "$INDEXCTL_BIN" "$@"
  else
    echo "ERROR: indexctl not found: $INDEXCTL_BIN" >&2
    exit 1
  fi
}

# ============================================================================
# USAGE
# ============================================================================

usage() {
  cat <<'EOF'
nodectl — index-node control (compatibility wrapper)

NOTE: For production use, prefer:
  - aosctl index ...    (system service)
  - hubctl index ...    (dev/user service)
  - nodectl is a compatibility toolbox with convenience commands

Quick Commands:
  status              Show service status + health check
  doctor              Full diagnostics (delegates to indexctl)
  start|stop|restart  Service control (delegates to indexctl)
  logs                Follow service logs (delegates to indexctl)

Development:
  dev                 Run npm dev server (auto-reload disabled)
  menu                Quick health check (curl /menu)
  warm                Warm up index by hitting / and /menu

URLs:
  open                Open best URL (tailscale if available)
  local               Open http://localhost:8799
  ts                  Open tailscale serve URL
  url                 Print best URL

Tailscale:
  serve on|off|status Manage tailscale serve

Service Mode:
  mode-dev            Switch to dev/user service
  mode-prod           Switch to system service
  mode-status         Show current mode

Delegation:
  indexctl <args>     Delegate to indexctl
  routerctl <args>    Delegate to routerctl
  bridgectl <args>    Delegate to bridgectl

Tooling:
  edit [file]         Edit file in index-node (default: server.js)
  help                Show this help

Examples:
  nodectl status
  nodectl dev
  nodectl open
  nodectl indexctl doctor
  nodectl edit server.js

EOF
}

# ============================================================================
# COMMANDS
# ============================================================================

cmd_status() {
  echo "=== Index Node Status ==="
  echo ""
  delegate_indexctl status
  echo ""
  health_check
  echo ""
  echo "URL: $(best_url)"
}

cmd_doctor() {
  delegate_indexctl doctor
}

cmd_menu() {
  if curl --max-time 2 -fsS "http://${NODE_HOST}:${NODE_PORT}/menu" 2>/dev/null | jq . 2>/dev/null; then
    echo ""
    echo "✓ /menu endpoint OK"
  else
    echo "✗ /menu endpoint failed"
    exit 1
  fi
}

cmd_warm() {
  echo "Warming up index-node..."
  curl -fsSL "http://${NODE_HOST}:${NODE_PORT}/" >/dev/null 2>&1 && echo "  ✓ /" || echo "  ✗ /"
  curl -fsSL "http://${NODE_HOST}:${NODE_PORT}/menu" >/dev/null 2>&1 && echo "  ✓ /menu" || echo "  ✗ /menu"
}

cmd_dev() {
  echo "Starting index-node in dev mode (npm run dev)..."
  cd "$INDEX_ROOT"
  exec npm run dev
}

cmd_url() {
  best_url
}

cmd_open() {
  local url
  url=$(best_url)
  echo "Opening: $url"
  open_url "$url"
}

cmd_local() {
  echo "Opening: http://localhost:${NODE_PORT}"
  open_url "http://localhost:${NODE_PORT}"
}

cmd_ts() {
  local url
  url=$(ts_url)
  if [[ -n "$url" ]]; then
    echo "Opening: $url"
    open_url "$url"
  else
    echo "ERROR: tailscale serve not active" >&2
    exit 1
  fi
}

cmd_serve() {
  local action="${1:-status}"
  case "$action" in
    on)
      if ! has_cmd tailscale; then
        echo "ERROR: tailscale not installed" >&2
        exit 1
      fi
      tailscale serve --bg "${NODE_PORT}"
      ;;
    off)
      if ! has_cmd tailscale; then
        echo "ERROR: tailscale not installed" >&2
        exit 1
      fi
      tailscale serve off
      ;;
    status)
      if has_cmd tailscale; then
        tailscale serve status
      else
        echo "tailscale: not installed"
      fi
      ;;
    *)
      echo "Usage: nodectl serve on|off|status" >&2
      exit 1
      ;;
  esac
}

cmd_edit() {
  local file="${1:-server.js}"
  local path="$INDEX_ROOT/$file"
  if [[ ! -f "$path" ]]; then
    echo "ERROR: file not found: $path" >&2
    exit 1
  fi
  "${EDITOR:-vim}" "$path"
}

# ============================================================================
# MAIN DISPATCH
# ============================================================================

cmd="${1:-status}"
[[ "$cmd" != "help" ]] && shift || true

case "$cmd" in
  -h|--help|help) usage ;;

  # Quick commands
  status) cmd_status ;;
  doctor) cmd_doctor ;;
  menu) cmd_menu ;;
  warm) cmd_warm ;;
  dev) cmd_dev ;;

  # URLs
  url) cmd_url ;;
  open) cmd_open ;;
  local) cmd_local ;;
  ts) cmd_ts ;;

  # Tailscale
  serve) cmd_serve "$@" ;;

  # Edit
  edit) cmd_edit "$@" ;;

  # Service control (delegate to indexctl)
  start|stop|restart|logs|fix)
    delegate_indexctl "$cmd" "$@"
    ;;

  # Mode switching (delegate to indexctl)
  mode-dev|mode-prod|mode-status)
    delegate_indexctl "$cmd" "$@"
    ;;

  # Pass-through delegation
  indexctl)
    delegate_indexctl "$@"
    ;;
  routerctl)
    exec "$ROOT_DIR/router/routerctl" "$@"
    ;;
  bridgectl)
    exec "$ROOT_DIR/bridge/bridgectl" "$@"
    ;;

  *)
    echo "ERROR: unknown command: $cmd" >&2
    echo "" >&2
    usage >&2
    exit 1
    ;;
esac
