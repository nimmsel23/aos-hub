#!/usr/bin/env bash
set -euo pipefail

# Compatibility wrapper: canonical nodectl now lives at index-node/nodectl.
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
TARGET="$ROOT_DIR/index-node/nodectl"

if [[ ! -e "$TARGET" ]]; then
  echo "ERROR: canonical nodectl not found: $TARGET" >&2
  exit 1
fi

exec "$TARGET" "$@"
