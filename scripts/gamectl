#!/usr/bin/env bash
set -euo pipefail

# gamectl (scripts/) is a thin UX/frontdoor wrapper.
# Canonical game domain logic lives in game/gamectl.
# codex-ashharbor: reduced duplicate implementation (service/system ops belong in hubctl).

GAMECTL_VERSION="2.0.0"

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PILLAR_GAMECTL="${GAME_PILLARCTL_BIN:-$ROOT_DIR/game/gamectl}"

# Codex session helper: gamectl codex [purpose...]
# shellcheck disable=SC1091

# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/aos-env.sh" 2>/dev/null || true
if declare -F aos_env_load >/dev/null 2>&1; then
  aos_env_load "" "$ROOT_DIR" 2>/dev/null || true
fi

# shellcheck disable=SC1091
source "$SCRIPT_DIR/ctl-lib.sh" 2>/dev/null || true

CURL_BIN="${CURL_BIN:-curl}"
INDEX_HEALTH_URL="${AOS_INDEX_HEALTH_URL:-http://127.0.0.1:8799/health}"
GAME_BASE_URL="${AOS_GAME_BASE_URL:-${AOS_INDEX_BASE_URL:-${INDEX_HEALTH_URL%/health}}}"
GAME_CENTRES=(frame freedom focus fire tent)

ui_die() {
  if declare -F ui_err >/dev/null 2>&1; then
    ui_err "$*"
  else
    printf 'ERROR: %s\n' "$*" >&2
  fi
  exit 1
}

ui_warnf() {
  if declare -F ui_warn >/dev/null 2>&1; then
    ui_warn "$*"
  else
    printf 'WARN: %s\n' "$*" >&2
  fi
}

ui_titlef() {
  if declare -F ui_title >/dev/null 2>&1; then
    ui_title "$*"
  else
    printf '%s\n' "$*"
  fi
}

have_cmd_local() { command -v "$1" >/dev/null 2>&1; }

pillar_gamectl_path() {
  if [[ -x "$PILLAR_GAMECTL" ]]; then
    printf '%s\n' "$PILLAR_GAMECTL"
    return 0
  fi
  if have_cmd_local gamectl && [[ "$(command -v gamectl)" != "$0" ]]; then
    command -v gamectl
    return 0
  fi
  return 1
}

delegate_pillar_exec() {
  local bin
  bin="$(pillar_gamectl_path)" || ui_die "canonical game/gamectl not found ($PILLAR_GAMECTL)"
  exec "$bin" "$@"
}

delegate_pillar_run() {
  local bin
  bin="$(pillar_gamectl_path)" || ui_die "canonical game/gamectl not found ($PILLAR_GAMECTL)"
  "$bin" "$@"
}

centre_url() {
  local name="${1:?}"
  printf "%s/game/%s" "${GAME_BASE_URL%/}" "$name"
}

http_code_ok() {
  local code="${1:-}"
  [[ "$code" =~ ^[0-9]{3}$ ]] || return 1
  ((10#$code >= 200 && 10#$code < 400))
}

centre_http_code() {
  local url="$1"
  if ! have_cmd_local "$CURL_BIN"; then
    printf 'curl?'
    return 0
  fi
  local code
  code="$("$CURL_BIN" -sS -o /dev/null -m 1 -w "%{http_code}" "$url" 2>/dev/null || true)"
  if [[ -z "$code" || "$code" == "000" ]]; then
    printf 'down'
  else
    printf '%s' "$code"
  fi
}

json_escape() {
  local s="${1-}"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

json_q() { printf '"%s"' "$(json_escape "${1-}")"; }

resolve_centres() {
  local requested=("$@")
  local req known name
  if ((${#requested[@]} == 0)); then
    printf '%s\n' "${GAME_CENTRES[@]}"
    return 0
  fi

  for req in "${requested[@]}"; do
    known=0
    for name in "${GAME_CENTRES[@]}"; do
      if [[ "$name" == "$req" ]]; then
        known=1
        break
      fi
    done
    if ((known == 0)); then
      ui_die "Unknown centre: $req (known: ${GAME_CENTRES[*]})"
    fi
    printf '%s\n' "$req"
  done
}

cmd_centres() {
  local brief=0 as_json=0
  local -a names=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --brief) brief=1 ;;
      --json) as_json=1 ;;
      -h|--help|help)
        cat <<'EOF_HELP'
gamectl centres — probe local /game/* centre routes

Usage:
  gamectl centres [--brief] [--json] [frame|freedom|focus|fire|tent ...]
EOF_HELP
        return 0
        ;;
      *) names+=("$1") ;;
    esac
    shift || true
  done

  mapfile -t names < <(resolve_centres "${names[@]}")

  local i=0 name url code mark
  if ((as_json == 1)); then
    printf '{"base_url":'; json_q "$GAME_BASE_URL"; printf ',"centres":['
    for name in "${names[@]}"; do
      url="$(centre_url "$name")"
      code="$(centre_http_code "$url")"
      (( i > 0 )) && printf ','
      printf '{"name":'; json_q "$name"; printf ',"url":'; json_q "$url"; printf ',"http":'; json_q "$code"; printf ',"ok":%s}' "$(http_code_ok "$code" && echo true || echo false)"
      i=$((i + 1))
    done
    printf ']}'
    printf '\n'
    return 0
  fi

  ((brief == 0)) && ui_titlef "gamectl centres"
  for name in "${names[@]}"; do
    url="$(centre_url "$name")"
    code="$(centre_http_code "$url")"
    mark="!!"
    http_code_ok "$code" && mark="OK"
    printf "  %-7s http=%-8s %s\n" "$name" "$code" "$url"
  done
}

pick_menu() {
  local prompt="$1"
  shift || true
  local -a opts=("$@")

  if declare -F ui_choose >/dev/null 2>&1; then
    ui_choose "$prompt" "${opts[@]}"
    return $?
  fi
  if declare -F ctl_choose_from_list >/dev/null 2>&1; then
    ctl_choose_from_list "$prompt" "${opts[@]}"
    return $?
  fi
  return 1
}

cmd_menu() {
  if ! declare -F ctl_can_prompt >/dev/null 2>&1 || ! ctl_can_prompt; then
    show_help
    return 0
  fi

  local action=""
  action="$(pick_menu "gamectl (user/centres)" \
    "dashboard" \
    "centres" \
    "doctor" \
    "paths" \
    "history" \
    "frame" \
    "freedom" \
    "focus" \
    "fire" \
    "tent" \
    "help" \
    "quit")" || return 0

  case "$action" in
    dashboard) delegate_pillar_exec dashboard ;;
    centres) cmd_centres --brief ;;
    doctor) delegate_pillar_exec doctor ;;
    paths) delegate_pillar_exec paths ;;
    history) delegate_pillar_exec history all ;;
    frame|freedom|focus|fire|tent) delegate_pillar_exec "$action" ;;
    help) show_help ;;
    quit) return 0 ;;
    *) return 0 ;;
  esac
}

legacy_system_ops_hint() {
  local cmd="${1:-}"
  ui_warnf "gamectl no longer owns system/service ops: '$cmd'"
  ui_warnf "Use: hubctl menu / hubctl status / hubctl doctor / hubctl dev ..."
}

show_help() {
  cat <<EOF_HELP
gamectl — Game user frontdoor (wrapper -> game/gamectl)

Usage:
  gamectl menu
  gamectl centres [--brief|--json] [names...]
  gamectl dashboard|status [YYYY-Www]
  gamectl doctor [YYYY-Www]
  gamectl paths [YYYY-Www]
  gamectl history [frame|freedom|focus|fire|core4score|tent|all]
  gamectl frame|freedom|focus|fire|tent [args...]
  gamectl version

Notes:
  - Canonical Game logic lives in: game/gamectl
  - scripts/gamectl is a UX/frontdoor wrapper for aos/aos-hub integration.
  - system/service operations belong in hubctl.
EOF_HELP
}

main() {
  local cmd="${1:-}"
  [[ -n "$cmd" ]] && shift || true

  case "$cmd" in
    "")
      if declare -F ctl_can_prompt >/dev/null 2>&1 && ctl_can_prompt; then
        cmd_menu
      else
        delegate_pillar_exec dashboard
      fi
      ;;
    menu)
      cmd_menu
      ;;
    centres)
      cmd_centres "$@"
      ;;
    dashboard|status|doctor|paths|history|version)
      delegate_pillar_exec "$cmd" "$@"
      ;;
    list)
      # Compatibility: older scripts/docs used `gamectl list` for overview.
      delegate_pillar_exec dashboard "$@"
      ;;
    frame|freedom|focus|fire|tent)
      delegate_pillar_exec "$cmd" "$@"
      ;;
    start|stop|restart|enable|disable|logs|config)
      legacy_system_ops_hint "$cmd"
      return 2
      ;;
    help|-h|--help)
      show_help
      ;;
    *)
      ui_warnf "Unknown gamectl command: $cmd"
      show_help
      return 2
      ;;
  esac
}

main "$@"
