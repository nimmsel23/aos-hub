#!/usr/bin/env bash
set -euo pipefail

GAMECTL_VERSION="1.1.0"

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Codex session helper: gamectl codex [purpose...]
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/lib/codex-subcmd.sh"
codex_subcmd_maybe "game" "gamectl" "$@" && exit 0

# Load global env (optional).
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/aos-env.sh"
aos_env_load "" "$ROOT_DIR" || true

# Shared UI helpers.
# shellcheck disable=SC1091
source "$SCRIPT_DIR/ctl-lib.sh"

SYSTEMCTL_BIN="${SYSTEMCTL_BIN:-systemctl}"
JOURNALCTL_BIN="${JOURNALCTL_BIN:-journalctl}"
SYSTEMCTL_USER=("$SYSTEMCTL_BIN" --user)
JOURNALCTL_USER=("$JOURNALCTL_BIN" --user)

SERVICE_GAME="${AOS_GAME_MOUNT_SERVICE:-rclone-alpha-game.service}"
INDEX_HEALTH_URL="${AOS_INDEX_HEALTH_URL:-http://127.0.0.1:8799/health}"
GAME_BASE_URL="${AOS_GAME_BASE_URL:-${AOS_INDEX_BASE_URL:-${INDEX_HEALTH_URL%/health}}}"
CURL_BIN="${CURL_BIN:-curl}"
GAME_CENTRES=(frame freedom focus fire tent)

UNITS=(
  "$SERVICE_GAME"
)

get_units() {
  local out=()
  local unit
  for unit in "${UNITS[@]}"; do
    [[ -n "$unit" ]] && out+=("$unit")
  done
  printf '%s\n' "${out[@]}"
}

show_help() {
  cat <<'EOF_HELP'
gamectl - Game service manager

Usage:
  gamectl <command> [args...]

Commands:
  list                       List managed units
  status [--full]            Compact status (+ centres) / verbose systemctl status
  centres [--brief]          List/check frame freedom focus fire tent routes
  frame|freedom|focus|fire|tent [status|url|open]
  start                      Start all units
  stop                       Stop all units
  restart                    Restart all units
  enable                     Enable all units
  disable                    Disable all units
  logs [--follow|-f] [unit]  Show logs for a unit (defaults to all units)
  doctor                     Health check (units + systemd)
  menu                       Interactive menu
  version                    Show version
  help                        Show this help

Notes:
  - Uses systemd user units (systemctl --user).
  - Override unit via AOS_GAME_MOUNT_SERVICE.
EOF_HELP
}

cmd_list() {
  get_units
}

centre_url() {
  local name="${1:?}"
  printf "%s/game/%s" "${GAME_BASE_URL%/}" "$name"
}

centre_http_code() {
  local url="$1"
  if ! has_cmd "$CURL_BIN"; then
    printf "curl?"
    return 0
  fi
  local code
  code="$("$CURL_BIN" -sS -o /dev/null -m 1 -w "%{http_code}" "$url" 2>/dev/null || true)"
  if [[ -z "$code" || "$code" == "000" ]]; then
    printf "down"
  else
    printf "%s" "$code"
  fi
}

cmd_centres() {
  local brief=0
  if [[ "${1:-}" == "--brief" ]]; then
    brief=1
  fi

  (( brief == 1 )) || ui_title "gamectl centres"
  local name url code
  for name in "${GAME_CENTRES[@]}"; do
    url="$(centre_url "$name")"
    code="$(centre_http_code "$url")"
    if (( brief == 1 )); then
      printf "  %-8s http=%-5s %s\n" "$name" "$code" "$url"
    else
      printf "%-8s  http=%-5s  %s\n" "$name" "$code" "$url"
    fi
  done
}

cmd_centre() {
  local name="${1:?}"
  shift || true
  local sub="${1:-status}"
  shift || true
  local url
  url="$(centre_url "$name")"

  case "$sub" in
    status|check)
      printf "%s  http=%s\n" "$url" "$(centre_http_code "$url")"
      ;;
    url)
      printf "%s\n" "$url"
      ;;
    open)
      if has_cmd xdg-open; then
        xdg-open "$url" >/dev/null 2>&1 || ui_err "Failed to open $url"
      else
        ui_err "xdg-open not found"
        return 1
      fi
      ;;
    *)
      ui_err "Unknown centre action: $sub (use: status|url|open)"
      return 2
      ;;
  esac
}

cmd_status_full() {
  need_cmd "$SYSTEMCTL_BIN"
  mapfile -t units < <(get_units)
  if ((${#units[@]} == 0)); then
    ui_warn "No units configured"
    return 0
  fi
  "${SYSTEMCTL_USER[@]}" status "${units[@]}"
}

cmd_status() {
  local mode="compact"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --full) mode="full" ;;
      --compact) mode="compact" ;;
      *)
        ui_err "Unknown status option: $1"
        return 2
        ;;
    esac
    shift || true
  done

  if [[ "$mode" == "full" ]]; then
    cmd_status_full
    return
  fi

  ui_title "gamectl status"
  need_cmd "$SYSTEMCTL_BIN"
  mapfile -t units < <(get_units)
  if ((${#units[@]} == 0)); then
    ui_warn "No units configured"
  else
    local unit active enabled
    for unit in "${units[@]}"; do
      active="$("${SYSTEMCTL_USER[@]}" is-active "$unit" 2>/dev/null || echo "inactive")"
      enabled="$("${SYSTEMCTL_USER[@]}" is-enabled "$unit" 2>/dev/null || echo "disabled")"
      printf "unit   %-28s active=%-9s enabled=%s\n" "$unit" "$active" "$enabled"
    done
  fi
  echo
  cmd_centres --brief
}

cmd_start() {
  need_cmd "$SYSTEMCTL_BIN"
  mapfile -t units < <(get_units)
  ((${#units[@]} > 0)) || { ui_warn "No units configured"; return 0; }
  "${SYSTEMCTL_USER[@]}" start "${units[@]}"
}

cmd_stop() {
  need_cmd "$SYSTEMCTL_BIN"
  mapfile -t units < <(get_units)
  ((${#units[@]} > 0)) || { ui_warn "No units configured"; return 0; }
  "${SYSTEMCTL_USER[@]}" stop "${units[@]}"
}

cmd_restart() {
  need_cmd "$SYSTEMCTL_BIN"
  mapfile -t units < <(get_units)
  ((${#units[@]} > 0)) || { ui_warn "No units configured"; return 0; }
  "${SYSTEMCTL_USER[@]}" restart "${units[@]}"
}

cmd_enable() {
  need_cmd "$SYSTEMCTL_BIN"
  mapfile -t units < <(get_units)
  ((${#units[@]} > 0)) || { ui_warn "No units configured"; return 0; }
  "${SYSTEMCTL_USER[@]}" enable "${units[@]}"
}

cmd_disable() {
  need_cmd "$SYSTEMCTL_BIN"
  mapfile -t units < <(get_units)
  ((${#units[@]} > 0)) || { ui_warn "No units configured"; return 0; }
  "${SYSTEMCTL_USER[@]}" disable "${units[@]}"
}

cmd_logs() {
  need_cmd "$JOURNALCTL_BIN"
  local follow=""
  local unit=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--follow) follow="--follow" ;;
      *) unit="$1" ;;
    esac
    shift
  done

  if [[ -n "$unit" ]]; then
    "${JOURNALCTL_USER[@]}" $follow -u "$unit"
    return
  fi

  mapfile -t units < <(get_units)
  if ((${#units[@]} == 0)); then
    ui_warn "No units configured"
    return 0
  fi

  "${JOURNALCTL_USER[@]}" $follow "${units[@]/#/-u }"
}

cmd_doctor() {
  ui_title "gamectl doctor"
  if ! has_cmd "$SYSTEMCTL_BIN"; then
    ui_err "systemctl not found"
    return 1
  fi

  mapfile -t units < <(get_units)
  if ((${#units[@]} == 0)); then
    ui_warn "No units configured"
    return 0
  fi

  for unit in "${units[@]}"; do
    if "${SYSTEMCTL_USER[@]}" is-active --quiet "$unit"; then
      ui_ok "$unit active"
    else
      ui_warn "$unit inactive"
    fi
  done
}

cmd_menu() {
  ui_title "gamectl"
  local action
  action=$(ui_choose "Select" \
    "status" \
    "start" \
    "stop" \
    "restart" \
    "enable" \
    "disable" \
    "logs" \
    "centres" \
    "doctor" \
    "list" \
    "quit")

  case "$action" in
    status) cmd_status ;;
    start) cmd_start ;;
    stop) cmd_stop ;;
    restart) cmd_restart ;;
    enable) cmd_enable ;;
    disable) cmd_disable ;;
    logs) cmd_logs ;;
    centres) cmd_centres ;;
    doctor) cmd_doctor ;;
    list) cmd_list ;;
    quit) exit 0 ;;
    *) exit 0 ;;
  esac
}

cmd_version() {
  echo "gamectl version $GAMECTL_VERSION"
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    list) cmd_list ;;
    status) cmd_status "$@" ;;
    centres) cmd_centres "$@" ;;
    frame|freedom|focus|fire|tent) cmd_centre "$cmd" "$@" ;;
    start) cmd_start ;;
    stop) cmd_stop ;;
    restart) cmd_restart ;;
    enable) cmd_enable ;;
    disable) cmd_disable ;;
    logs) cmd_logs "$@" ;;
    doctor) cmd_doctor ;;
    menu) cmd_menu ;;
    version) cmd_version ;;
    help|-h|--help) show_help ;;
    *)
      ui_err "Unknown command: $cmd"
      show_help
      exit 2
      ;;
  esac
}

main "$@"
