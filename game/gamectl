#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd -P)"

source "$ROOT_DIR/scripts/ctl-lib.sh"       2>/dev/null || true
source "$ROOT_DIR/scripts/lib/aos-env.sh"   2>/dev/null && aos_env_load "" "$ROOT_DIR" 2>/dev/null || true

usage() {
  cat <<EOF
gamectl — Game Pillar CLI  (Frame → Freedom → Focus → Fire)

Usage:
  gamectl <map> <cmd> [DOMAIN] [options]

Maps & Commands:
  gamectl frame   new|show|list|edit  [DOMAIN]
  gamectl freedom new|show|list|edit  [DOMAIN]
  gamectl focus   new|show|list|edit  [DOMAIN]
  gamectl fire    new|show|list|edit  [DOMAIN]

Delegates to:
  frame/framectl  |  freedom/freedomctl  |  focus/focusctl  |  fire/firectl
EOF
}

MAP="$SCRIPT_DIR/${1:-}"

case "${1:-}" in
  frame)    shift; exec "$SCRIPT_DIR/frame/framectl"     "$@" ;;
  freedom)  shift; exec "$SCRIPT_DIR/freedom/freedomctl" "$@" ;;
  focus)    shift; exec "$SCRIPT_DIR/focus/focusctl"     "$@" ;;
  fire)     shift; exec "$SCRIPT_DIR/fire/firectl"       "$@" ;;
  help|--help|-h) usage ;;
  *) usage ;;
esac
