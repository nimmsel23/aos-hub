#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd -P)"
FOCUS_PY="$SCRIPT_DIR/focus.py"

source "$ROOT_DIR/scripts/ctl-lib.sh"       2>/dev/null || true
source "$ROOT_DIR/scripts/lib/aos-env.sh"   2>/dev/null && aos_env_load "" "$ROOT_DIR" 2>/dev/null || true

py() { python3 "$FOCUS_PY" "$@"; }

usage() {
  cat <<EOF
focusctl — Focus Map CLI  (Monthly Mission)

Usage:
  focusctl new  [DOMAIN] [YYYY-MM] [--mode domain-first|question-first]   Neue Focus Map (default: alle Domains, question-first)
  focusctl show [DOMAIN]             Focus Map anzeigen
  focusctl list                      Alle Focus Maps auflisten
  focusctl edit [DOMAIN]             Im Editor öffnen
  focusctl ctx  [open|start|stop|restart|status|logs|menu]  Focus PWA ctx (via focusctx)

Domain: BODY | BEING | BALANCE | BUSINESS  (optional — alle wenn weggelassen)
EOF
}

cmd_new()  {
  local domain="${1:-}"
  shift || true
  py new ${domain:+--domain "$domain"} "$@"
}
cmd_show() { py show ${1:+--domain "$1"}; }
cmd_list() { py list; }
cmd_edit() { py edit ${1:+--domain "$1"}; }
cmd_ctx() {
  local action="${1:-menu}"
  if command -v focusctx >/dev/null 2>&1; then
    focusctx "$action"
    return $?
  fi
  if command -v pwactx >/dev/null 2>&1; then
    pwactx focus "$action"
    return $?
  fi
  echo "focusctx not found (install /home/alpha/.dotfiles/bin/focusctx or pwactx)" >&2
  return 1
}
case "${1:-}" in
  new)   shift; cmd_new  "$@" ;;
  show)  shift; cmd_show "${1:-}" ;;
  list)  cmd_list ;;
  edit)  shift; cmd_edit "${1:-}" ;;
  ctx)   shift; cmd_ctx  "${1:-}" ;;
  help|--help|-h) usage ;;
  *) usage ;;
esac
