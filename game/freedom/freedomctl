#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd -P)"
FREEDOM_PY="$SCRIPT_DIR/freedom.py"

source "$ROOT_DIR/scripts/ctl-lib.sh"       2>/dev/null || true
source "$ROOT_DIR/scripts/lib/aos-env.sh"   2>/dev/null && aos_env_load "" "$ROOT_DIR" 2>/dev/null || true

py() { python3 "$FREEDOM_PY" "$@"; }

usage() {
  cat <<EOF
freedomctl — Freedom Map CLI  (Annual Vision / IPW)

Usage:
  freedomctl new  [DOMAIN] [--year YYYY] [--mode domain-first|question-first]   Neue Freedom Map (default: alle Domains, question-first)
  freedomctl show [DOMAIN]                 Freedom Map anzeigen
  freedomctl list                          Alle Freedom Maps auflisten
  freedomctl edit [DOMAIN]                 Im Editor öffnen
  freedomctl ctx  [open|start|stop|restart|status|logs|menu]  Freedom PWA ctx (via freedomctx)

Domain: BODY | BEING | BALANCE | BUSINESS  (optional — alle wenn weggelassen)
EOF
}

cmd_new()  {
  local domain="${1:-}"
  shift || true
  py new ${domain:+--domain "$domain"} "$@"
}
cmd_show() { py show ${1:+--domain "$1"}; }
cmd_list() { py list; }
cmd_edit() { py edit ${1:+--domain "$1"}; }
cmd_ctx() {
  local action="${1:-menu}"
  if command -v freedomctx >/dev/null 2>&1; then
    freedomctx "$action"
    return $?
  fi
  if command -v pwactx >/dev/null 2>&1; then
    pwactx freedom "$action"
    return $?
  fi
  echo "freedomctx/pwactx not found" >&2
  return 1
}
case "${1:-}" in
  new)   shift; cmd_new  "$@" ;;
  show)  shift; cmd_show "${1:-}" ;;
  list)  cmd_list ;;
  edit)  shift; cmd_edit "${1:-}" ;;
  ctx)   shift; cmd_ctx  "${1:-}" ;;
  help|--help|-h) usage ;;
  *) usage ;;
esac
