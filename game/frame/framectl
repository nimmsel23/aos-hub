#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd -P)"
FRAME_PY="$SCRIPT_DIR/frame.py"

# Shared helpers
source "$ROOT_DIR/scripts/ctl-lib.sh" 2>/dev/null || true
source "$ROOT_DIR/scripts/lib/aos-env.sh" 2>/dev/null && aos_env_load "" "$ROOT_DIR" 2>/dev/null || true

py() { python3 "$FRAME_PY" "$@"; }

usage() {
  cat <<EOF
framectl — Frame Map CLI

Usage:
  framectl new [DOMAIN] [--mode domain-first|question-first]  Neuen Frame anlegen (default: alle Domains, question-first)
  framectl show [BODY|BEING|BALANCE|BUSINESS]  Frame anzeigen
  framectl list                                Alle Frames auflisten
  framectl edit [DOMAIN]                       Frame im Editor öffnen

EOF
}

cmd_new()  {
  local domain="${1:-}"
  shift || true
  py new ${domain:+--domain "$domain"} "$@"
}
cmd_show() { py show ${1:+--domain "$1"}; }
cmd_list() { py list; }
cmd_edit() {
  local domain="${1:-}"
  local state_dir="$HOME/.aos/frame"
  if [[ -n "$domain" ]]; then
    local file="$state_dir/${domain,,}.yaml"
    [[ -f "$file" ]] || { echo "Kein Frame für $domain. Erst: framectl new $domain"; exit 1; }
    "${EDITOR:-nano}" "$file"
  else
    "${EDITOR:-nano}" "$state_dir/"
  fi
}

case "${1:-}" in
  new)   shift; cmd_new  "$@" ;;
  show)  shift; cmd_show "${1:-}" ;;
  list)  cmd_list ;;
  edit)  shift; cmd_edit "${1:-}" ;;
  help|--help|-h) usage ;;
  *) usage ;;
esac
