#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd -P)"

game_proto_domains=(BODY BEING BALANCE BUSINESS)

proto_today() { date +%F; }
proto_now_utc() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }
proto_current_year() { date +%Y; }
proto_current_month() { date +%Y-%m; }
proto_current_week() { date +%G-W%V; }

proto_require_domain() {
  local d="${1^^}"
  case "$d" in
    BODY|BEING|BALANCE|BUSINESS|ALL) printf '%s\n' "$d" ;;
    *) echo "invalid domain: $1 (expected BODY|BEING|BALANCE|BUSINESS|all)" >&2; return 1 ;;
  esac
}

proto_quarter_from_month() {
  local month="${1:-$(proto_current_month)}"
  local year="${month%%-*}"
  local mm="${month#*-}"
  mm=$((10#$mm))
  local q=$(( (mm - 1) / 3 + 1 ))
  printf '%s-Q%s\n' "$year" "$q"
}

proto_year_from_quarter() {
  printf '%s\n' "${1%%-Q*}"
}

proto_next_day() {
  local d="$1"
  date -d "$d +1 day" +%F
}

proto_week_from_date() {
  local d="$1"
  date -d "$d" +%G-W%V
}

proto_expand_domains() {
  local domain="${1:-ALL}"
  if [[ "${domain^^}" == "ALL" ]]; then
    printf '%s\n' "${game_proto_domains[@]}"
    return 0
  fi
  proto_require_domain "$domain" >/dev/null
  printf '%s\n' "${domain^^}"
}

proto_repo_ref() {
  local p="$1"
  # Keep repo-relative refs stable for future Node/GAS adapters.
  printf 'game/%s\n' "${p#"$ROOT_DIR/game/"}"
}

proto_write() {
  local path="$1"
  local force="${2:-0}"
  mkdir -p "$(dirname "$path")"
  if [[ -f "$path" && "$force" != "1" ]]; then
    cat >/dev/null
    printf '  = %s (exists)\n' "${path#$ROOT_DIR/}"
    return 0
  fi
  cat >"$path"
  printf '  + %s\n' "${path#$ROOT_DIR/}"
}

proto_ics_daily() {
  local file="$1"
  local day="$2"
  local force="${3:-0}"
  local next
  next="$(proto_next_day "$day")"
  local dtstart="${day//-/}"
  local dtend="${next//-/}"
  local dtstamp
  dtstamp="$(date -u +"%Y%m%dT%H%M%SZ")"
  local uid="${dtstart}-aos-fire@alphaos.local"

  proto_write "$file" "$force" <<EOF
BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//AlphaOS//Fire Daily Prototype//EN
CALSCALE:GREGORIAN
BEGIN:VEVENT
UID:${uid}
DTSTAMP:${dtstamp}
DTSTART;VALUE=DATE:${dtstart}
DTEND;VALUE=DATE:${dtend}
SUMMARY:AlphaOS Fire Daily ${day}
DESCRIPTION:Prototype Fire Daily generated by game/fire/firectl
END:VEVENT
END:VCALENDAR
EOF
}

proto_frame_generate() {
  local domain="$1"
  local year="$2"
  local force="${3:-0}"
  local out="$ROOT_DIR/game/frame/prototypes/${domain}/${year}/annual.yaml"

  proto_write "$out" "$force" <<EOF
version: 1
type: frame-map
domain: ${domain}
period:
  cadence: annual
  year: ${year}
updated: $(proto_today)
created: $(proto_now_utc)
status: draft
source_refs: {}
current_reality:
  where_now: "TODO"
  constraints: []
  assets: []
notes: ""
EOF
}

proto_freedom_generate() {
  local domain="$1"
  local quarter="$2"
  local force="${3:-0}"
  local year
  year="$(proto_year_from_quarter "$quarter")"
  local frame_ref="$ROOT_DIR/game/frame/prototypes/${domain}/${year}/annual.yaml"
  local out="$ROOT_DIR/game/freedom/prototypes/${domain}/${quarter}/quarterly.yaml"

  proto_write "$out" "$force" <<EOF
version: 1
type: freedom-map
domain: ${domain}
period:
  cadence: quarterly
  quarter: ${quarter}
  year: ${year}
updated: $(proto_today)
created: $(proto_now_utc)
status: draft
source_refs:
  frame: $(proto_repo_ref "$frame_ref")
horizon: "10-year"
vision: "TODO"
pillars:
  identity: []
  systems: []
  outcomes: []
EOF
}

proto_focus_generate() {
  local domain="$1"
  local month="$2"
  local force="${3:-0}"
  local quarter
  quarter="$(proto_quarter_from_month "$month")"
  local year="${month%%-*}"
  local frame_ref="$ROOT_DIR/game/frame/prototypes/${domain}/${year}/annual.yaml"
  local freedom_ref="$ROOT_DIR/game/freedom/prototypes/${domain}/${quarter}/quarterly.yaml"
  local out="$ROOT_DIR/game/focus/prototypes/${domain}/${month}/monthly.md"

  proto_write "$out" "$force" <<EOF
---
type: focus-map
domain: ${domain}
month: ${month}
updated: $(proto_today)
created: $(proto_now_utc)
status: draft
source_refs:
  frame: $(proto_repo_ref "$frame_ref")
  freedom: $(proto_repo_ref "$freedom_ref")
---

# ${domain} Focus ${month}

## Mission

- TODO

## Outcomes

- TODO

## Constraints

- TODO

## Weekly Strikes (seed)

- TODO
EOF
}

proto_fire_generate() {
  local week="$1"
  local day="$2"
  local month="$3"
  local force="${4:-0}"
  local dir="$ROOT_DIR/game/fire/prototypes/${week}"
  local week_md="$dir/weekly.md"
  local day_json="$dir/daily.json"
  local day_ics="$dir/daily.ics"

  proto_write "$week_md" "$force" <<EOF
---
type: fire-map
week: ${week}
updated: $(proto_today)
created: $(proto_now_utc)
status: draft
focus_maps:
  body: game/focus/prototypes/BODY/${month}/monthly.md
  being: game/focus/prototypes/BEING/${month}/monthly.md
  balance: game/focus/prototypes/BALANCE/${month}/monthly.md
  business: game/focus/prototypes/BUSINESS/${month}/monthly.md
source_refs:
  focus_month: ${month}
---

# FIRE MAP ${week}

## BODY
- TODO

## BEING
- TODO

## BALANCE
- TODO

## BUSINESS
- TODO
EOF

  proto_write "$day_json" "$force" <<EOF
{
  "version": 1,
  "type": "fire-daily",
  "date": "${day}",
  "week": "${week}",
  "status": "draft",
  "source_refs": {
    "fire_weekly": "game/fire/prototypes/${week}/weekly.md"
  },
  "strikes": {
    "BODY": [],
    "BEING": [],
    "BALANCE": [],
    "BUSINESS": []
  }
}
EOF

  proto_ics_daily "$day_ics" "$day" "$force"
}

proto_tent_generate() {
  local week="$1"
  local force="${2:-0}"
  local out="$ROOT_DIR/game/tent/prototypes/${week}/weekly.md"

  proto_write "$out" "$force" <<EOF
---
type: tent-report
week: ${week}
updated: $(proto_today)
created: $(proto_now_utc)
status: draft
source_refs:
  fire: game/fire/prototypes/${week}/weekly.md
---

# General's Tent ${week}

## Fire Review

- Review: game/fire/prototypes/${week}/weekly.md

## Patterns

- TODO

## Corrections

- TODO

## Next Week Intent

- TODO
EOF
}

cmd_frame() {
  local domain="ALL"
  local year="$(proto_current_year)"
  local force=0

  if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then domain="$1"; shift; fi
  if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then year="$1"; shift; fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --domain) domain="${2:-}"; shift 2 ;;
      --year) year="${2:-}"; shift 2 ;;
      --force) force=1; shift ;;
      *) echo "Unknown frame arg: $1" >&2; return 1 ;;
    esac
  done

  printf 'Frame prototypes (%s, %s)\n' "$domain" "$year"
  while IFS= read -r d; do
    proto_frame_generate "$d" "$year" "$force"
  done < <(proto_expand_domains "$domain")
}

cmd_freedom() {
  local domain="ALL"
  local quarter
  quarter="$(proto_quarter_from_month)"
  local force=0

  if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then domain="$1"; shift; fi
  if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then quarter="$1"; shift; fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --domain) domain="${2:-}"; shift 2 ;;
      --quarter) quarter="${2:-}"; shift 2 ;;
      --force) force=1; shift ;;
      *) echo "Unknown freedom arg: $1" >&2; return 1 ;;
    esac
  done

  printf 'Freedom prototypes (%s, %s)\n' "$domain" "$quarter"
  while IFS= read -r d; do
    proto_freedom_generate "$d" "$quarter" "$force"
  done < <(proto_expand_domains "$domain")
}

cmd_focus() {
  local domain="ALL"
  local month="$(proto_current_month)"
  local force=0

  if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then domain="$1"; shift; fi
  if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then month="$1"; shift; fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --domain) domain="${2:-}"; shift 2 ;;
      --month) month="${2:-}"; shift 2 ;;
      --force) force=1; shift ;;
      *) echo "Unknown focus arg: $1" >&2; return 1 ;;
    esac
  done

  printf 'Focus prototypes (%s, %s)\n' "$domain" "$month"
  while IFS= read -r d; do
    proto_focus_generate "$d" "$month" "$force"
  done < <(proto_expand_domains "$domain")
}

cmd_fire() {
  local day="$(proto_today)"
  local week
  week="$(proto_week_from_date "$day")"
  local month="$(proto_current_month)"
  local force=0

  if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then week="$1"; shift; fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --week) week="${2:-}"; shift 2 ;;
      --date) day="${2:-}"; shift 2 ;;
      --month) month="${2:-}"; shift 2 ;;
      --force) force=1; shift ;;
      *) echo "Unknown fire arg: $1" >&2; return 1 ;;
    esac
  done
  # Recompute week from explicit day if caller did not pass --week.
  if [[ -n "$day" && "$week" == "$(proto_week_from_date "$(proto_today)")" ]]; then
    week="$(proto_week_from_date "$day")"
  fi

  printf 'Fire prototypes (week=%s, day=%s, month=%s)\n' "$week" "$day" "$month"
  proto_fire_generate "$week" "$day" "$month" "$force"
}

cmd_tent() {
  local week="$(proto_current_week)"
  local force=0

  if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then week="$1"; shift; fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --week) week="${2:-}"; shift 2 ;;
      --force) force=1; shift ;;
      *) echo "Unknown tent arg: $1" >&2; return 1 ;;
    esac
  done

  printf 'Tent prototypes (week=%s)\n' "$week"
  proto_tent_generate "$week" "$force"
}

cmd_flow() {
  local month="$(proto_current_month)"
  local day="$(proto_today)"
  local week
  week="$(proto_week_from_date "$day")"
  local force=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --month) month="${2:-}"; shift 2 ;;
      --date) day="${2:-}"; shift 2 ;;
      --week) week="${2:-}"; shift 2 ;;
      --force) force=1; shift ;;
      *) echo "Unknown flow arg: $1" >&2; return 1 ;;
    esac
  done

  if [[ "$week" == "$(proto_week_from_date "$(proto_today)")" && "$day" != "$(proto_today)" ]]; then
    week="$(proto_week_from_date "$day")"
  fi

  echo "Game prototype flow"
  local year="${month%%-*}"
  local quarter
  quarter="$(proto_quarter_from_month "$month")"
  local force_args=()
  if [[ "$force" -eq 1 ]]; then
    force_args=(--force)
  fi
  cmd_frame ALL "$year" "${force_args[@]}"
  cmd_freedom ALL "$quarter" "${force_args[@]}"
  cmd_focus ALL "$month" "${force_args[@]}"
  cmd_fire "$week" --date "$day" --month "$month" "${force_args[@]}"
  cmd_tent "$week" "${force_args[@]}"
}

usage() {
  cat <<EOF
game_proto.sh — prototype scaffold generator for Game cascade

Usage:
  game/lib/game_proto.sh frame   [DOMAIN|all] [YEAR] [--force]
  game/lib/game_proto.sh freedom [DOMAIN|all] [YYYY-QN] [--force]
  game/lib/game_proto.sh focus   [DOMAIN|all] [YYYY-MM] [--force]
  game/lib/game_proto.sh fire    [YYYY-Www] [--date YYYY-MM-DD] [--month YYYY-MM] [--force]
  game/lib/game_proto.sh tent    [YYYY-Www] [--force]
  game/lib/game_proto.sh flow    [--month YYYY-MM] [--date YYYY-MM-DD] [--week YYYY-Www] [--force]

Outputs are written to:
  game/{frame,freedom,focus,fire,tent}/prototypes/
EOF
}

main() {
  local cmd="${1:-}"
  shift || true
  case "$cmd" in
    frame) cmd_frame "$@" ;;
    freedom) cmd_freedom "$@" ;;
    focus) cmd_focus "$@" ;;
    fire) cmd_fire "$@" ;;
    tent) cmd_tent "$@" ;;
    flow) cmd_flow "$@" ;;
    help|--help|-h|"") usage ;;
    *) echo "Unknown command: $cmd" >&2; usage; return 1 ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
