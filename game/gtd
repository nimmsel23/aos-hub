#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
WORK_DIR="$ROOT_DIR/work"
mkdir -p "$WORK_DIR"

today() { date +%F; }
now_utc() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }
year_now() { date +%Y; }
month_now() { date +%Y-%m; }
week_now() { date +%G-W%V; }
week_from_date() { date -d "$1" +%G-W%V; }
next_day() { date -d "$1 +1 day" +%F; }

quarter_from_month() {
  local month="${1:-$(month_now)}"
  local y="${month%%-*}"
  local m="${month#*-}"
  m=$((10#$m))
  printf '%s-Q%d\n' "$y" $(((m - 1) / 3 + 1))
}

valid_domain() {
  case "${1^^}" in BODY|BEING|BALANCE|BUSINESS|ALL) return 0 ;; *) return 1 ;; esac
}

domains() {
  if [[ "${1^^}" == "ALL" ]]; then
    printf '%s\n' BODY BEING BALANCE BUSINESS
  else
    printf '%s\n' "${1^^}"
  fi
}

write_if_missing() {
  local file="$1"
  mkdir -p "$(dirname "$file")"
  if [[ -f "$file" ]]; then
    printf '= %s\n' "${file#$ROOT_DIR/}"
    cat >/dev/null
    return 0
  fi
  # Scaffold once and preserve later edits on rerun.
  cat >"$file"
  printf '+ %s\n' "${file#$ROOT_DIR/}"
}

write_force() {
  local file="$1"
  mkdir -p "$(dirname "$file")"
  cat >"$file"
  printf '+ %s\n' "${file#$ROOT_DIR/}"
}

usage() {
  cat <<'EOF'
game/gtd - terminal GAME script (Frame / Freedom / Focus / Fire / Daily / Tent)

Usage:
  game/gtd frame [DOMAIN|all] [YEAR]
  game/gtd freedom [DOMAIN|all] [YYYY-QN]
  game/gtd focus [DOMAIN|all] [YYYY-MM]
  game/gtd fire-week [YYYY-Www] [YYYY-MM]
  game/gtd fire-day [YYYY-MM-DD] [YYYY-MM]
  game/gtd daily [YYYY-MM-DD]
  game/gtd tent [YYYY-Www]
  game/gtd today
  game/gtd status
EOF
}

cmd_frame() {
  local domain="${1:-ALL}"
  local year="${2:-$(year_now)}"
  valid_domain "$domain" || { echo "invalid domain" >&2; exit 1; }
  while IFS= read -r d; do
    local file="$WORK_DIR/frame/$d/$year/annual.yaml"
    write_if_missing "$file" <<EOF
version: 1
type: frame-map
domain: $d
period:
  cadence: annual
  year: $year
created: $(now_utc)
updated: $(today)
status: draft
current_reality:
  where_am_i_now: ""
  how_did_i_get_here: ""
  how_do_i_feel_about_where_i_am: ""
  what_is_working: []
  what_is_not_working: []
EOF
  done < <(domains "$domain")
}

cmd_freedom() {
  local domain="${1:-ALL}"
  local quarter="${2:-$(quarter_from_month)}"
  valid_domain "$domain" || { echo "invalid domain" >&2; exit 1; }
  local year="${quarter%%-Q*}"
  while IFS= read -r d; do
    local file="$WORK_DIR/freedom/$d/$quarter/quarterly.yaml"
    write_if_missing "$file" <<EOF
version: 1
type: freedom-map
domain: $d
period:
  cadence: quarterly
  quarter: $quarter
  year: $year
created: $(now_utc)
updated: $(today)
status: draft
source_refs:
  frame: game/work/frame/$d/$year/annual.yaml
horizon: 10-year
ipw_vision: ""
identity_shift: ""
EOF
  done < <(domains "$domain")
}

cmd_focus() {
  local domain="${1:-ALL}"
  local month="${2:-$(month_now)}"
  valid_domain "$domain" || { echo "invalid domain" >&2; exit 1; }
  local quarter
  quarter="$(quarter_from_month "$month")"
  local year="${month%%-*}"
  while IFS= read -r d; do
    local file="$WORK_DIR/focus/$d/$month/monthly.md"
    write_if_missing "$file" <<EOF
---
type: focus-map
domain: $d
month: $month
created: $(now_utc)
updated: $(today)
status: draft
source_refs:
  frame: game/work/frame/$d/$year/annual.yaml
  freedom: game/work/freedom/$d/$quarter/quarterly.yaml
---

# $d Focus $month

## Habits
- 

## Routines
- 

## Additions
- 

## Eliminations
- 

## Monthly Mission
- 
EOF
  done < <(domains "$domain")
}

cmd_fire_week() {
  local wk="${1:-$(week_now)}"
  local month="${2:-$(month_now)}"
  local file="$WORK_DIR/fire/$wk/weekly.md"
  write_if_missing "$file" <<EOF
---
type: fire-map
week: $wk
month: $month
created: $(now_utc)
updated: $(today)
status: draft
focus_maps:
  body: game/work/focus/BODY/$month/monthly.md
  being: game/work/focus/BEING/$month/monthly.md
  balance: game/work/focus/BALANCE/$month/monthly.md
  business: game/work/focus/BUSINESS/$month/monthly.md
---

# FIRE $wk

## BODY
- [ ] Strike 1
- [ ] Strike 2
- [ ] Strike 3
- [ ] Strike 4

## BEING
- [ ] Strike 1
- [ ] Strike 2
- [ ] Strike 3
- [ ] Strike 4

## BALANCE
- [ ] Strike 1
- [ ] Strike 2
- [ ] Strike 3
- [ ] Strike 4

## BUSINESS
- [ ] Strike 1
- [ ] Strike 2
- [ ] Strike 3
- [ ] Strike 4
EOF
}

cmd_fire_day() {
  local d="${1:-$(today)}"
  local month="${2:-${d:0:7}}"
  local wk
  wk="$(week_from_date "$d")"
  cmd_fire_week "$wk" "$month" >/dev/null
  local json="$WORK_DIR/fire/$wk/daily.json"
  local ics="$WORK_DIR/fire/$wk/daily.ics"
  write_force "$json" <<EOF
{
  "version": 1,
  "type": "fire-daily",
  "date": "$d",
  "week": "$wk",
  "status": "draft",
  "source_refs": {
    "fire_weekly": "game/work/fire/$wk/weekly.md"
  },
  "strikes": {
    "BODY": [],
    "BEING": [],
    "BALANCE": [],
    "BUSINESS": []
  }
}
EOF

  local next dtstart dtend dtstamp uid
  next="$(next_day "$d")"
  dtstart="${d//-/}"
  dtend="${next//-/}"
  dtstamp="$(date -u +"%Y%m%dT%H%M%SZ")"
  uid="${dtstart}-aos-game@local"
  # Fire daily ICS lets the same daily intent be mirrored into a calendar.
  write_force "$ics" <<EOF
BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//AlphaOS//Game Daily//EN
CALSCALE:GREGORIAN
BEGIN:VEVENT
UID:$uid
DTSTAMP:$dtstamp
DTSTART;VALUE=DATE:$dtstart
DTEND;VALUE=DATE:$dtend
SUMMARY:Fire Daily $d
DESCRIPTION:game/work/fire/$wk/daily.json
END:VEVENT
END:VCALENDAR
EOF
}

cmd_tent() {
  local wk="${1:-$(week_now)}"
  local file="$WORK_DIR/tent/$wk/weekly.md"
  write_if_missing "$file" <<EOF
---
type: tent-report
week: $wk
created: $(now_utc)
updated: $(today)
status: draft
source_refs:
  fire: game/work/fire/$wk/weekly.md
---

# General's Tent $wk

## Component 1: Return and Report
- Freedom Maps: On Track / Off Track
- Focus Maps: Momentum / Losing Steam
- Fire Maps: Weekly War Win / Loss
- Alpha Score:
  - ___ / 28 Core
  - ___ / 7 Stack
  - ___ / 21 Door

## Component 2: Lessons Learned
- What worked?
- What did not?
- Cross-domain lesson?

## Component 3: Course Correction
- What to realign now?
- What to stop?
- What to reinforce?

## Component 4: New Targets
- Body:
- Being:
- Balance:
- Business:
EOF
}

cmd_daily() {
  local d="${1:-$(today)}"
  local m="${d:0:7}"
  local wk
  wk="$(week_from_date "$d")"
  # Daily Game references Fire artifacts, so build them first.
  cmd_fire_day "$d" "$m" >/dev/null
  local file="$WORK_DIR/daily/$d.md"
  write_force "$file" <<EOF
---
type: daily-game
date: $d
week: $wk
month: $m
created: $(now_utc)
updated: $(today)
source_refs:
  fire_daily_json: game/work/fire/$wk/daily.json
  fire_daily_ics: game/work/fire/$wk/daily.ics
  fire_weekly: game/work/fire/$wk/weekly.md
---

# Daily Game $d

## Power (Core)
- BODY
- BEING
- BALANCE
- BUSINESS

## Perspective (Voice)
- STOP
- SUBMIT
- STRUGGLE
- STRIKE

## Production (Door)
- Door:
- Hits today:
- Done list:
EOF
}

cmd_today() {
  local d m wk q y
  d="$(today)"
  m="$(month_now)"
  wk="$(week_now)"
  q="$(quarter_from_month "$m")"
  y="${m%%-*}"
  cmd_frame ALL "$y"
  cmd_freedom ALL "$q"
  cmd_focus ALL "$m"
  cmd_daily "$d" >/dev/null
  cmd_tent "$wk"
}

cmd_status() {
  local d m wk q y
  d="$(today)"
  m="$(month_now)"
  wk="$(week_now)"
  q="$(quarter_from_month "$m")"
  y="${m%%-*}"
  echo "date=$d month=$m quarter=$q week=$wk"
  while IFS= read -r dom; do
    printf '%s frame=%s freedom=%s focus=%s\n' \
      "$dom" \
      "$( [[ -f "$WORK_DIR/frame/$dom/$y/annual.yaml" ]] && echo yes || echo no )" \
      "$( [[ -f "$WORK_DIR/freedom/$dom/$q/quarterly.yaml" ]] && echo yes || echo no )" \
      "$( [[ -f "$WORK_DIR/focus/$dom/$m/monthly.md" ]] && echo yes || echo no )"
  done < <(domains ALL)
  printf 'fire_week=%s fire_day_json=%s fire_day_ics=%s tent=%s daily=%s\n' \
    "$( [[ -f "$WORK_DIR/fire/$wk/weekly.md" ]] && echo yes || echo no )" \
    "$( [[ -f "$WORK_DIR/fire/$wk/daily.json" ]] && echo yes || echo no )" \
    "$( [[ -f "$WORK_DIR/fire/$wk/daily.ics" ]] && echo yes || echo no )" \
    "$( [[ -f "$WORK_DIR/tent/$wk/weekly.md" ]] && echo yes || echo no )" \
    "$( [[ -f "$WORK_DIR/daily/$d.md" ]] && echo yes || echo no )"
}

case "${1:-}" in
  frame) shift; cmd_frame "${1:-ALL}" "${2:-$(year_now)}" ;;
  freedom) shift; cmd_freedom "${1:-ALL}" "${2:-$(quarter_from_month)}" ;;
  focus) shift; cmd_focus "${1:-ALL}" "${2:-$(month_now)}" ;;
  fire-week) shift; cmd_fire_week "${1:-$(week_now)}" "${2:-$(month_now)}" ;;
  fire-day) shift; cmd_fire_day "${1:-$(today)}" "${2:-$(month_now)}" ;;
  daily) shift; cmd_daily "${1:-$(today)}" ;;
  tent) shift; cmd_tent "${1:-$(week_now)}" ;;
  today) shift; cmd_today ;;
  status) shift; cmd_status ;;
  help|--help|-h|"") usage ;;
  *) usage; exit 1 ;;
esac
