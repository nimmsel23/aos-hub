# Fire local env (untracked/local values recommended)
#
# This file is sourced by:
# - game/fire/gcal-push-due.sh
# You can also reuse it for other Fire scripts if needed.

# ----- Taskwarrior / Firemap basics (optional overrides) -----
AOS_TASK_BIN=task
AOS_TZ=Europe/Vienna

# Existing Firemap/Telegram settings (optional here; fill only if you use them)
# AOS_FIREMAP_BOT_TOKEN=
# AOS_FIREMAP_CHAT_ID=
# AOS_FIREMAP_SENDER=api
# AOS_FIREMAP_TASK_EXPORT_PATH=$HOME/.local/share/alphaos/task_export.json

# ----- Google Calendar sync for due:today + overdue -----
# Backend: gcalcli | ics | print
AOS_FIRE_GCAL_BACKEND="gcalcli"

# Preferred write target for gcalcli (name or ID; name is easiest)
# Use ONE of these (name recommended first):
AOS_FIRE_GCAL_CALENDAR="Fire Map"
# AOS_FIRE_GCAL_CALENDAR_ID=
# Optional explicit path to Google OAuth Desktop client JSON for gcalcli init helper.
# If empty, Fire scripts auto-detect `game/fire/client_secret*.json`.
# AOS_FIRE_GCAL_CLIENT_SECRET_JSON=/home/alpha/aos-hub/game/fire/client_secret_....json
# If you already have GAS Fire env values, the sync script also falls back to:
# FIRE_GCAL_CALENDAR_NAME / FIRE_GCAL_CALENDAR_ID

# Event title prefixes (helps separate today vs overdue)
AOS_FIRE_GCAL_PREFIX_TODAY="[TW today]"
AOS_FIRE_GCAL_PREFIX_OVERDUE="[TW overdue]"

# Marker used for idempotent re-sync delete/add cycle
AOS_FIRE_GCAL_MARKER_PREFIX=AOS_TW_GCAL_SYNC
# Default daily time for `firectl gcal auto enable` (HH:MM local time)
AOS_FIRE_GCAL_DAILY_TIME=07:00
# If a task has `scheduled`, push as timed event on TODAY using scheduled HH:MM.
AOS_FIRE_GCAL_SCHEDULED_AS_TIMED=1
# Duration (minutes) for scheduled timed events.
AOS_FIRE_GCAL_SCHEDULED_DURATION_MIN=60

# ----- Taskwarrior selection for Fire due-sync -----
# Mode:
# - filters: use two explicit task filters (default)
# - report:  use one task report/query and split into today/overdue inside the script
AOS_FIRE_GCAL_TW_SOURCE=report

# Default filter mode (current behavior)
AOS_FIRE_GCAL_TW_FILTER_TODAY="status:pending due:today"
AOS_FIRE_GCAL_TW_FILTER_OVERDUE="status:pending due.before:today"

# Optional report mode (example: your custom report `fired`)
# When enabled, the script runs `task $AOS_FIRE_GCAL_TW_REPORT export`
# and classifies entries by due date (today vs overdue).
AOS_FIRE_GCAL_TW_REPORT=fired

# Optional fallback output path when using --backend ics
# AOS_FIRE_GCAL_ICS_OUT=$HOME/vault/Game/Fire/gcal-due/tasks.ics

# ----- Existing GAS Fire Centre values (read/display) -----
# These are usually read-only/display/feed values, not direct write auth.
# FIRE_GCAL_EMBED_URL=
# FIRE_GCAL_CALENDAR_NAME=
# FIRE_GCAL_CALENDAR_ID=
# FIRE_GCAL_ICS_URL=

AOS_FIREMAP_CHAT_IDS=8442781308

AOS_FIREMAP_ALLOW_TELE_FALLBACK=0
