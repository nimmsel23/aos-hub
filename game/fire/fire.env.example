# Fire env (template)
#
# Copy to: ~/.env/fire.env
# Or point scripts to a custom location:
#   export AOS_FIRE_ENV_FILE=/path/to/fire.env
#
# NOTE: This file is committed. Do not put secrets here.

# Binaries
AOS_TASK_BIN=task
AOS_TELE_BIN=tele
AOS_PYTHON_BIN=python

# Firemap Telegram sender (fill in your local ~/.env/fire.env)
AOS_FIREMAP_BOT_TOKEN=
AOS_FIREMAP_CHAT_ID=
AOS_FIREMAP_CHAT_IDS=   # optional fanout: comma-separated, e.g. 123,456
AOS_FIREMAP_SENDER=api

# Firemap selection
# - Dated tasks (due/scheduled/wait + overdue) are included regardless of tags.
# - Undated tasks are included by tags (execution backlog).
AOS_FIREMAP_TAGS=production,hit,fire
AOS_FIREMAP_TAGS_MODE=any   # any|all
AOS_FIREMAP_INCLUDE_UNDATED_DAILY=1
AOS_FIREMAP_INCLUDE_UNDATED_WEEKLY=1
AOS_FIREMAP_MAX_UNDATED=10
AOS_FIREMAP_TASK_EXPORT_PATH=$HOME/.local/share/alphaos/task_export.json
AOS_FIREMAP_TASK_EXPORT_MAX_AGE_SEC=600
AOS_TZ=Europe/Vienna

# firectl paths (optional overrides)
# AOS_VAULT_DIR=$HOME/vault
# AOS_FIRE_DIR=$HOME/vault/Game/Fire

# Index Node Fire Taskwarrior fallback (optional)
FIRE_TASK_DATE_FIELDS=scheduled,due,wait
FIRE_INCLUDE_UNDATED=1
FIRE_TASK_TAGS=production,hit,fire
FIRE_TASK_TAGS_MODE=any
FIRE_TASK_EXCLUDE_TAGS=door,mission

# Fire -> Google Calendar daily due sync
# Backend: gcalcli | ics | print
AOS_FIRE_GCAL_BACKEND=gcalcli
# Calendar name or ID (name recommended)
AOS_FIRE_GCAL_CALENDAR=
# AOS_FIRE_GCAL_CALENDAR_ID=
# Optional explicit OAuth JSON path; otherwise auto-detect `game/fire/client_secret*.json`
# AOS_FIRE_GCAL_CLIENT_SECRET_JSON=

# Event formatting
AOS_FIRE_GCAL_PREFIX_TODAY="[TW today]"
AOS_FIRE_GCAL_PREFIX_OVERDUE="[TW overdue]"
AOS_FIRE_GCAL_MARKER_PREFIX=AOS_TW_GCAL_SYNC

# Daily auto timer default time (used by `firectl gcal auto enable`)
AOS_FIRE_GCAL_DAILY_TIME=07:00

# Taskwarrior selection for due-sync:
# - filters: explicit today/overdue filters
# - report: use one report/query and split in script
AOS_FIRE_GCAL_TW_SOURCE=report
AOS_FIRE_GCAL_TW_REPORT=fired
# Filter fallback (when source=filters)
AOS_FIRE_GCAL_TW_FILTER_TODAY="status:pending due:today"
AOS_FIRE_GCAL_TW_FILTER_OVERDUE="status:pending due.before:today"

# Scheduled behavior:
# If task has `scheduled`, create timed event at scheduled HH:MM (local time),
# otherwise all-day event.
AOS_FIRE_GCAL_SCHEDULED_AS_TIMED=1
AOS_FIRE_GCAL_SCHEDULED_DURATION_MIN=60
