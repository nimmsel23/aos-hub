#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$APP_DIR/.." && pwd)"

# shellcheck disable=SC1090
source "$APP_DIR/bridge-lib.sh"

SERVICE_NAME="aos-bridge.service"
SERVICE_PATH_SYS="$ROOT_DIR/systemd/system/$SERVICE_NAME"

BRIDGE_ENV_FILE="${BRIDGE_ENV_FILE:-$HOME/.env/bridge.env}"
AOS_ENV_FILE="${AOS_ENV_FILE:-$BRIDGE_ENV_FILE}"

SERVICE_MODE="$(bridge_detect_mode)"

systemctl_sys() { sudo systemctl "$@"; }


unit_dst_path() {
  echo "$USER_SERVICE_DIR/$SERVICE_NAME"
}

show_installed_unit_ref() {
  local dst
  dst="$(unit_dst_path)"
  if [[ -L "$dst" ]]; then
    local target=""
    target="$(readlink -f -- "$dst" 2>/dev/null || readlink -- "$dst" 2>/dev/null || true)"
    ui_info "Installed unit: $dst -> ${target:-<unknown>}"
    return 0
  fi
  if [[ -e "$dst" ]]; then
    ui_info "Installed unit: $dst (not a symlink)"
    return 0
  fi
  ui_info "Installed unit: (not linked)"
}

diagnose_systemd() {
  ui_title "bridgectl systemd diagnose"

  ui_info "Repo unit: $SERVICE_PATH_SYS"

  load_env_file_if_present "$AOS_ENV_FILE" || true

  if [[ -n "${AOS_HUB_DIR:-}" ]]; then
    ui_info "AOS_HUB_DIR: $AOS_HUB_DIR"
  else
    ui_info "AOS_HUB_DIR: (unset)"
  fi
  if [[ "${AOS_HUB_DIR:-}" == "/" ]]; then
    ui_warn "AOS_HUB_DIR is '/', ExecStart will try: cd /bridge"
  fi

  msg ""
  msg "-- systemctl cat ${SERVICE_NAME} --"
  systemctl_sys cat "$SERVICE_NAME" --no-pager 2>/dev/null || true

  msg ""
  msg "-- systemctl show (selected) --"
  systemctl_sys show "$SERVICE_NAME" -p FragmentPath -p DropInPaths -p ExecStart -p EnvironmentFiles 2>/dev/null || true

  msg ""
  msg "-- systemctl status --"
  systemctl_sys status "$SERVICE_NAME" --no-pager 2>/dev/null || true
}

fix_systemd() {
  ui_title "bridgectl systemd fix"

  local assume_yes=0
  if [[ "${1:-}" == "--yes" || "${1:-}" == "-y" ]]; then
    assume_yes=1
  fi

  msg ""

  if ((assume_yes)); then
    ui_info "Applying: daemon-reload + restart"
  else
    ui_info "This will daemon-reload and restart the service."
    ui_confirm "Proceed?" || return 0
  fi

  systemctl_sys daemon-reload
  systemctl_sys restart "$SERVICE_NAME" || true

  msg ""
  systemctl_sys status "$SERVICE_NAME" --no-pager || true

  if has_cmd journalctl; then
    msg ""
    msg "-- recent logs --"
    journalctl -u "$SERVICE_NAME" -n 60 --no-pager || true
  fi

  status
}

install_deps() {
  if ! has_cmd pacman; then
    die "pacman not found. Install python-aiohttp manually."
  fi
  msg "Installing python-aiohttp (Arch)..."
  sudo pacman -S python-aiohttp
}

link_service() {
  local force=0
  if [[ "${1:-}" == "--force" || "${1:-}" == "-f" ]]; then
    force=1
  fi

  local dst="/etc/systemd/system/$SERVICE_NAME"
  if [[ -e "$dst" ]]; then
    if ((force)); then
      local ts="$(date +%s)"
      if [[ -L "$dst" ]]; then
        sudo rm -f "$dst"
      else
        sudo mv "$dst" "$dst.bak.$ts"
      fi
    else
      msg "Service already linked: $dst"
      msg "Tip: bridge-servicectl link-service --force"
      return 0
    fi
  fi

  sudo ln -s "$SERVICE_PATH_SYS" "$dst"
  msg "Linked service: $dst"
}

status() {
  msg "Bridge status:"

  if has_cmd python; then
    python - <<'PY' || true
import importlib.util
print("python:", "ok")
spec = importlib.util.find_spec("aiohttp")
print("aiohttp:", "ok" if spec else "missing")
PY
  else
    ui_warn "python not found"
  fi

  msg ""
  msg "Env:"
  if [[ -f "$AOS_ENV_FILE" ]]; then
    ui_ok "AOS env present: $AOS_ENV_FILE"
  else
    ui_warn "AOS env missing: $AOS_ENV_FILE"
  fi

  load_env_file_if_present "$AOS_ENV_FILE" || true

  if [[ -n "${AOS_HUB_DIR:-}" ]]; then
    ui_ok "AOS_HUB_DIR: $AOS_HUB_DIR"
  else
    ui_info "AOS_HUB_DIR not set (default: $HOME/aos-hub)"
  fi

  local rc=0
  msg ""

  # System scope
  if has_cmd systemctl; then
    local sys_active sys_enabled
    sys_active="$(systemctl is-active "aos-bridge.service" 2>/dev/null || true)"
    sys_enabled="$(systemctl is-enabled "aos-bridge.service" 2>/dev/null || true)"
    [[ -z "$sys_active" ]]  && sys_active="-"
    [[ -z "$sys_enabled" ]] && sys_enabled="-"
    msg "Systemd (system): active=$sys_active enabled=$sys_enabled"
  fi

  # Service active check
  local sys_a
  sys_a="$(systemctl is-active "aos-bridge.service" 2>/dev/null || true)"

  if [[ "$sys_a" == "active" ]]; then
    ui_ok "Active mode: system ($SERVICE_NAME)"
  else
    ui_warn "System bridge is inactive."
    rc=1
  fi

  return "$rc"
}

system_active_state() {
  if ! has_cmd systemctl; then
    echo "unknown"
    return 0
  fi
  local state
  state="$(systemctl is-active "aos-bridge.service" 2>/dev/null || true)"
  [[ -n "$state" ]] || state="inactive"
  echo "$state"
}

warn_if_system_active() {
  # No longer needed - system service is canonical mode
  return 0
}

svc_restart() {
  local active_check
  active_check="$(systemctl is-active "$SERVICE_NAME" 2>/dev/null || true)"
  if [[ "$active_check" == "active" ]]; then
    msg "Restarting system service: $SERVICE_NAME"
    systemctl_sys restart "$SERVICE_NAME"
  else
    ui_warn "System service inactive. Starting: $SERVICE_NAME"
    systemctl_sys start "$SERVICE_NAME"
  fi
}

svc_start() {
  if [[ "$(systemctl is-active "$SERVICE_NAME" 2>/dev/null || true)" == "active" ]]; then
    msg "System service already active: $SERVICE_NAME"
  else
    msg "Starting system service: $SERVICE_NAME"
    systemctl_sys start "$SERVICE_NAME"
  fi
}

svc_stop() {
  if [[ "$(systemctl is-active "$SERVICE_NAME" 2>/dev/null || true)" == "active" ]]; then
    msg "Stopping system service: $SERVICE_NAME"
    systemctl_sys stop "$SERVICE_NAME"
  else
    msg "System service not running: $SERVICE_NAME"
  fi
}

logs() {
  sudo journalctl -u "$SERVICE_NAME" -n 200 -f
}

env_edit() { "${EDITOR:-nano}" "$AOS_ENV_FILE"; }

usage() {
  cat <<'__HELP__'
bridge-servicectl — Manage AOS Bridge systemd service

Canonical mode is systemd system service. Use with: sudo bridgectl ...

Usage: bridge-servicectl <command>

Commands:
  status              Show bridge status
  start               Start system bridge service
  stop                Stop system bridge service
  restart             Restart system bridge service (or start if inactive)
  logs                Follow system bridge journal logs
  enable              Link + enable + start system service
  env                 Edit ~/.env/bridge.env
  install-deps        Install python-aiohttp (Arch)
  link-service [-f]   Symlink unit file to /etc/systemd/system/
  diagnose            Systemd unit diagnosis
  fix [--yes]         Fix unit symlink + restart

Env:
  BRIDGE_ENV_FILE (default: ~/.env/bridge.env)
__HELP__
}

cmd="${1:-status}"
shift || true

case "$cmd" in
  -h|--help|help) usage ;;
  status) status ;;
  install-deps) install_deps ;;
  link-service) link_service "${1:-}" ;;
  diagnose) diagnose_systemd ;;
  fix) fix_systemd "${1:-}" ;;
  enable)
    if [[ "$SERVICE_MODE" == "system" ]]; then
      msg "System service mode detected. To enable system bridge:"
      msg "  sudo ln -sf $SERVICE_PATH_SYS /etc/systemd/system/"
      msg "  sudo systemctl daemon-reload"
      msg "  sudo systemctl enable --now aos-bridge.service"
    else
      link_service --force
      systemctl_user daemon-reload
      systemctl_user enable --now "$SERVICE_NAME"
    fi
    ;;
  start) svc_start ;;
  stop) svc_stop ;;
  restart) svc_restart ;;
  logs) logs ;;
  env) env_edit ;;
  *) usage; exit 1 ;;
esac
