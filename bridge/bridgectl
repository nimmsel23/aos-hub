#!/usr/bin/env bash
set -euo pipefail

# bridgectl — thin dispatcher
# Keep this file small; real logic lives in:
#   - bridge-servicectl (systemd/env)
#   - bridge-apictl     (HTTP endpoints)
#   - bridge-tsctl      (tailscale serve/funnel/status)

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$APP_DIR"

# If called via non-repo path/symlink, prefer the canonical repo checkout.
if [[ "$ROOT_DIR" != "$HOME/aos-hub" && -d "$HOME/aos-hub/scripts" ]]; then
  ROOT_DIR="$HOME/aos-hub"
  APP_DIR="$ROOT_DIR"
fi
BRIDGE_DIR="$ROOT_DIR/bridge"

# shellcheck disable=SC1090
source "$BRIDGE_DIR/bridge-lib.sh"

SYNCCTL_BIN="${SYNCCTL_BIN:-$ROOT_DIR/scripts/syncctl}"
HEARTBEAT_BIN="${HEARTBEAT_BIN:-$ROOT_DIR/scripts/heartbeat}"
ROUTERCTL_BIN="${ROUTERCTL_BIN:-$ROOT_DIR/router/routerctl}"
SYSTEMSTATUSCTL_BIN="${SYSTEMSTATUSCTL_BIN:-$ROOT_DIR/scripts/systemstatusctl}"
ENV_FILE="${AOS_ENV_FILE:-$HOME/.env/aos.env}"

servicectl() { exec "$BRIDGE_DIR/bridge-servicectl" "$@"; }
apictl() { exec "$BRIDGE_DIR/bridge-apictl" "$@"; }
tsctl() { exec "$BRIDGE_DIR/bridge-tsctl" "$@"; }

syncctl_cmd() {
  if [[ -x "$SYNCCTL_BIN" ]]; then
    echo "$SYNCCTL_BIN"
    return 0
  fi
  if has_cmd syncctl; then
    echo "syncctl"
    return 0
  fi
  return 1
}

run_syncctl() {
  local cmd
  cmd="$(syncctl_cmd)" || die "syncctl not found"
  exec "$cmd" "$@"
}

routerctl_cmd() {
  if [[ -x "$ROUTERCTL_BIN" ]]; then
    echo "$ROUTERCTL_BIN"
    return 0
  fi
  if has_cmd routerctl; then
    command -v routerctl
    return 0
  fi
  return 1
}

heartbeat_cmd() {
  if [[ -x "$HEARTBEAT_BIN" ]]; then
    echo "$HEARTBEAT_BIN"
    return 0
  fi
  if has_cmd heartbeat; then
    command -v heartbeat
    return 0
  fi
  local bin
  bin="$(routerctl_cmd)" || return 1
  echo "$bin"
  return 0
}

run_heartbeat() {
  local sub="${1:-status}"; shift || true
  local bin
  bin="$(heartbeat_cmd)" || die "heartbeat not available"
  if [[ "$bin" == *routerctl ]]; then
    exec "$bin" heartbeat "$sub" "$@"
  fi
  exec "$bin" "$sub" "$@"
}

systemstatusctl_cmd() {
  if [[ -x "$SYSTEMSTATUSCTL_BIN" ]]; then
    echo "$SYSTEMSTATUSCTL_BIN"
    return 0
  fi
  if has_cmd systemstatusctl; then
    command -v systemstatusctl
    return 0
  fi
  return 1
}

run_systemstatus() {
  local bin
  bin="$(systemstatusctl_cmd)" || die "systemstatusctl not found"
  exec "$bin" trigger "$@"
}

doctor() {
  ui_title "bridgectl doctor"

  local rc=0
  if ! "$BRIDGE_DIR/bridge-servicectl" status; then
    rc=1
  fi
  msg ""

  local dev_unit="${AOS_BRIDGE_USER_SERVICE:-aos-bridge-dev.service}"
  local user_active="unknown"
  local legacy_user_active="unknown"
  local sys_active="unknown"
  if has_cmd systemctl; then
    sys_active="$(systemctl is-active "aos-bridge.service" 2>/dev/null || true)"
    [[ -n "$sys_active" ]] || sys_active="inactive"
  fi
  if systemctl --user show-environment >/dev/null 2>&1; then
    user_active="$(systemctl --user is-active "$dev_unit" 2>/dev/null || true)"
    legacy_user_active="$(systemctl --user is-active "aos-bridge.service" 2>/dev/null || true)"
  fi

  msg "Systemd checks:"
  if [[ "$sys_active" == "active" ]]; then
    ui_warn "system service active (unmanaged): aos-bridge.service"
  elif [[ "$sys_active" == "inactive" ]]; then
    ui_info "system service inactive"
  else
    ui_warn "system service status unknown"
  fi

  if [[ "$user_active" == "active" ]]; then
    ui_ok "user service active: $dev_unit"
  elif [[ "$user_active" == "inactive" || "$user_active" == "failed" ]]; then
    ui_info "user service inactive"
  else
    ui_warn "user service status unknown (no user bus)"
  fi

  if [[ "$legacy_user_active" == "active" && "$dev_unit" != "aos-bridge.service" ]]; then
    ui_warn "legacy user service active: aos-bridge.service (migrate to $dev_unit)"
  fi

  if [[ "$sys_active" == "active" && "$user_active" == "active" ]]; then
    ui_warn "double-run risk: both system and user services are active"
  fi
  if [[ "$user_active" == "active" ]]; then
    ui_ok "mode: user (canonical)"
  elif [[ "$sys_active" == "active" ]]; then
    ui_warn "unsupported mode: system-only active"
    rc=1
  else
    ui_warn "mode: none (bridge not active)"
    rc=1
  fi
  msg ""

  "$BRIDGE_DIR/bridge-tsctl" status || true
  msg ""

  "$BRIDGE_DIR/bridge-apictl" health || true
  msg ""

  "$BRIDGE_DIR/bridge-apictl" debug || true

  return "$rc"
}

menu() {
  ui_title "bridgectl"
  local action
  action="$(choose \
    "service status" "service logs" "service restart" "service enable" "service env" \
    "systemd diagnose" "systemd fix" \
    "api health" "api debug" "api version" "api doctor" "api test-rpc" "api flush" \
    "core4 today" "core4 week" "core4 pull" \
    "tent fetch" "tent sync" \
    "fire daily" "fire review" "fire trigger" \
    "rpc health" \
    "tele send" \
    "api sync-status" "api sync-pull" "api sync-push" "api sync-pull (dry-run)" "api sync-push (dry-run)" "api sync-abort" \
    "syncctl menu" "syncctl status" "syncctl sync" "syncctl pull" \
    "gas systemstatus" \
    "heartbeat status" "heartbeat ping" "heartbeat logs" \
    "tailscale status" "tailscale serve" "tailscale funnel" \
    "doctor" "quit")"

  case "$action" in
    "service status") servicectl status ;;
    "service logs") servicectl logs ;;
    "service restart") servicectl restart ;;
    "service enable") servicectl enable ;;
    "service env") servicectl env ;;

    "systemd diagnose") servicectl diagnose ;;
    "systemd fix") servicectl fix ;;

    "api health") apictl health ;;
    "api debug") apictl debug ;;
    "api version") apictl version ;;
    "api doctor") apictl doctor ;;
    "api test-rpc") apictl test-rpc ;;
    "api flush") apictl flush ;;

    "core4 today") apictl core4-today ;;
    "core4 week") apictl core4-week ;;
    "core4 pull") apictl core4-pull ;;

    "tent fetch") apictl tent-fetch ;;
    "tent sync") apictl tent-sync ;;

    "fire daily") apictl fire-daily ;;
    "fire review") apictl fire-review ;;
    "fire trigger") apictl fire-trigger ;;

    "rpc health") apictl rpc health ;;

    "tele send") apictl tele-send "bridgectl menu test" ;;

    "api sync-status") apictl sync-status ;;
    "api sync-pull") apictl sync-pull ;;
    "api sync-push") apictl sync-push ;;
    "api sync-pull (dry-run)") apictl sync-pull --dry-run ;;
    "api sync-push (dry-run)") apictl sync-push --dry-run ;;
    "api sync-abort") apictl sync-abort ;;

    "syncctl menu") run_syncctl menu ;;
    "syncctl status") run_syncctl status ;;
    "syncctl sync") run_syncctl sync ;;
    "syncctl pull") run_syncctl pull ;;

    "gas systemstatus") run_systemstatus ;;

    "heartbeat status") run_heartbeat status ;;
    "heartbeat ping") run_heartbeat ping ;;
    "heartbeat logs") run_heartbeat logs ;;

    "tailscale status") tsctl status ;;
    "tailscale serve") tsctl serve ;;
    "tailscale funnel") tsctl funnel ;;

    doctor) doctor ;;
    quit) exit 0 ;;
  esac
}

usage() {
  cat <<'EOF'
bridgectl — CLI for AOS Bridge (aiohttp on :8080)

The Bridge is the bidirectional HTTP layer between Gas HQ (cloud) and local
services. Reachable via Tailscale at ideapad.tail7a15d6.ts.net/bridge.

USAGE
  bridgectl <command> [args...]
  bridgectl                       (opens interactive menu)

QUICK START
  bridgectl health                Check if bridge is online
  bridgectl status                Show user service state (canonical mode)
  bridgectl doctor                Full system diagnosis
  bridgectl core4-today           Today's Core4 habits + total

SERVICE MANAGEMENT
  status                          Service state (user scope; system shown as warning)
  start|stop|restart              Control user bridge service
  enable                          Link + enable + start user service
  logs                            Follow user journal logs
  env                             Edit ~/.env/aos.env
  diagnose                        Systemd unit file diagnosis
  fix [--yes]                     Fix unit symlink + restart

HEALTH & DEBUG
  health                          Bridge /health endpoint
  debug                           /debug endpoint + RPC test
  doctor                          Full diagnosis (service + tailscale + API)
  version                         Bridge version + git rev

CORE4 (Habit Tracking)
  core4-today                     Today's totals + habits
  core4-week [YYYY-Wxx]           Weekly aggregate (default: current week)
  core4-log <domain> <task>       Log habit completion
  core4-log <domain> <task> --undo   Undo habit completion
  core4-pull                      Pull Core4 from Google Drive

TENT (Weekly Review)
  tent-fetch [YYYY-Wxx]           Fetch Tent report
  tent-sync [YYYY-Wxx]            Sync Tent to GAS
  tent-summary <md> [YYYY-Wxx]    Save weekly summary markdown

FIRE (Execution Tracking)
  fire-daily [--send] [--scope daily|weekly] [--days N]
  fire-review                     Daily review data (tasks + sessions)
  fire-trigger                    Trigger weekly Fire Map generation

TASKS (Taskwarrior ↔ GAS)
  task-add <desc> [--tag T] [--project P] [--due D] [--priority H|M|L]
  task-modify <uuid> [--tag-add T] [--tag-rm T] [--project P] [--due D]
  task-op <JSON>                  Forward raw operation to GAS

WARSTACK
  warstack-draft <JSON>           Save/clear War Stack draft for /resume

TELEGRAM
  tele-send <text> [--chat-id ID] Send message via GAS webhook

RPC (Gas HQ Remote Procedure Call)
  test-rpc                        Test RPC with health action
  rpc <action> [JSON-args]        Send arbitrary RPC to GAS Tent

SYNC (rclone via Bridge)
  sync-push [--dry-run]           Push vault to Google Drive
  sync-pull [--dry-run]           Pull vault from Google Drive
  sync-status                     Current sync operation status
  sync-abort                      Abort running sync

TAILSCALE
  tailscale                       Show Tailscale serve status
  serve                           Configure tailscale serve
  funnel                          Configure tailscale funnel

OTHER
  syncctl <args...>               Delegate to syncctl
  heartbeat <cmd>                 Router heartbeat management
  systemstatus                    Trigger GAS system status update

SECURITY
  Bridge requires X-Bridge-Token header when AOS_BRIDGE_TOKEN is set.
  NEVER use 'tailscale funnel' — exposes bridge to public internet.
  Use 'tailscale serve' only (tailnet-only access).

ENV
  AOS_ENV_FILE          ~/.env/aos.env (bridge + all services)
  AOS_BRIDGE_TOKEN      Auth token (required for production)
  AOS_BRIDGE_URL        Override bridge URL (default: http://127.0.0.1:8080)

SEE ALSO
  bridge/ARCHITECTURE.md    Full architecture documentation
  bridge/README.md          Endpoint reference + config
  bridge/AGENTS.md          Developer guidelines
EOF
}

cmd="${1:-menu}"
shift || true

case "$cmd" in
  -h|--help|help) usage ;;
  menu) menu ;;
  doctor) doctor ;;

  status|enable|start|stop|restart|logs|env|install-deps|link-service|diagnose|fix)
    servicectl "$cmd" "$@"
    ;;

  health|debug|version|test-rpc|flush|rpc|\
  core4-today|core4-week|core4-log|core4-pull|\
  tent-fetch|tent-sync|tent-summary|\
  fire-daily|fire-review|fire-trigger|\
  task-add|task-modify|task-op|\
  warstack-draft|tele-send|\
  sync-status|sync-pull|sync-push|sync-abort)
    apictl "$cmd" "$@"
    ;;
  doctor-api|api-doctor) apictl doctor ;;

  tailscale) tsctl status ;;
  serve) tsctl serve ;;
  funnel) tsctl funnel ;;

  syncctl) run_syncctl "$@" ;;
  heartbeat) run_heartbeat "${1:-status}" "${@:2}" ;;
  systemstatus) run_systemstatus "$@" ;;

  *)
    usage
    exit 1
    ;;
esac
