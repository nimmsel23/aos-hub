#!/usr/bin/env bash
# voicectl - THE VOICE Management (Mental Mastery)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$SCRIPT_DIR/../lib"

# Source libraries
source "$LIB_DIR/voice_data.sh"
source "$LIB_DIR/voice_session.sh"
source "$LIB_DIR/voice_format.sh"
source "$SCRIPT_DIR/../../scripts/ctl-lib.sh"

# Environment
EDITOR="${EDITOR:-nano}"
if command -v micro >/dev/null 2>&1; then
  EDITOR=micro
fi

#─────────────────────────────────────────────────────────────────────────
# Commands
#─────────────────────────────────────────────────────────────────────────

cmd_list() {
  local limit="${1:-50}"
  local sessions
  sessions=$(list_sessions "$limit")
  draw_sessions_table "$sessions"
}

cmd_start() {
  local domain=""

  # Check if domain specified
  if [[ -n "${1:-}" ]]; then
    case "$1" in
      body|being|balance|business)
        domain="$1"
        ;;
      *)
        ui_err "Invalid domain: $1"
        ui_info "Valid domains: body, being, balance, business"
        return 1
        ;;
    esac
  fi

  ui_title "VOICE Session - 4 Steps to Mental Mastery"
  if [[ -n "$domain" ]]; then
    ui_info "Domain: ${domain^^}"
  fi
  echo ""
  ui_info "This will guide you through:"
  ui_info "  🛑 STOP - Pattern interrupt"
  ui_info "  📝 SUBMIT - Face truth (4F: Facts/Feelings/Focus/Fruit)"
  ui_info "  ⚔️  STRUGGLE - Rewrite story"
  ui_info "  ⚡ STRIKE - Decisive action"
  echo ""

  # Source enhanced session if available
  if [[ -f "$LIB_DIR/voice_session_v2.sh" ]]; then
    source "$LIB_DIR/voice_session_v2.sh"
    local file
    file=$(interactive_session_v2 "$domain")
    echo ""
    ui_ok "Session complete!"

    if ui_confirm "Open in editor?"; then
      "$EDITOR" "$file"
    fi

    if ui_confirm "View with glow?"; then
      format_session "$file"
    fi
  else
    # Fallback to original
    if ui_confirm "Start interactive session?"; then
      local file
      file=$(interactive_session)
      echo ""
      ui_ok "Session complete!"

      if ui_confirm "Open in editor?"; then
        "$EDITOR" "$file"
      fi

      if ui_confirm "View with glow?"; then
        format_session "$file"
      fi
    else
      ui_info "Creating template only..."
      local file
      file=$(quick_session)
      ui_ok "Template created: $file"
      "$EDITOR" "$file"
    fi
  fi
}

cmd_show() {
  local id="$1"

  if ! session_exists "$id"; then
    ui_err "Session not found: $id"
    return 1
  fi

  local file
  file=$(get_session_file "$id")

  ui_title "VOICE Session: $(basename "$file")"
  echo ""
  format_session "$file"
}

cmd_edit() {
  local id="$1"

  if ! session_exists "$id"; then
    ui_err "Session not found: $id"
    return 1
  fi

  local file
  file=$(get_session_file "$id")
  "$EDITOR" "$file"
  ui_ok "Session edited: $(basename "$file")"
}

cmd_search() {
  local query="$1"
  local results
  results=$(search_sessions "$query")
  draw_search_results "$results" "$query"
}

cmd_recent() {
  local count="${1:-10}"
  cmd_list "$count"
}

cmd_stats() {
  local stats
  stats=$(get_stats)
  draw_stats "$stats"
}

cmd_strike() {
  local id="$1"

  if ! session_exists "$id"; then
    ui_err "Session not found: $id"
    return 1
  fi

  local file
  file=$(get_session_file "$id")

  ui_title "STRIKE from Session"
  echo ""
  extract_strike "$file"
  echo ""
}

cmd_dir() {
  local vdir
  vdir=$(get_voice_dir)
  echo "$vdir"
}

cmd_status() {
  local vdir
  vdir=$(get_voice_dir)

  ui_title "VOICE Status"
  echo ""

  # Vault directory
  if [[ -d "$vdir" ]]; then
    ui_ok "Vault:  $vdir"
  else
    ui_err "Vault:  $vdir (NOT FOUND)"
  fi

  # Session count
  local total=0
  if [[ -d "$vdir" ]]; then
    total=$(find "$vdir" -maxdepth 1 -type f -name "*.md" 2>/dev/null | wc -l)
  fi
  ui_info "Total sessions: $total"

  # This week / month
  local this_week=0 this_month=0
  if [[ -d "$vdir" ]]; then
    this_week=$(find "$vdir" -maxdepth 1 -type f -name "*.md" -newermt "monday" 2>/dev/null | wc -l)
    this_month=$(find "$vdir" -maxdepth 1 -type f -name "*.md" -newermt "$(date '+%Y-%m-01')" 2>/dev/null | wc -l)
  fi
  ui_info "This week:  $this_week"
  ui_info "This month: $this_month"

  # Today's session check
  local today_file="$vdir/VOICE-$(date '+%Y-%m-%d')*.md"
  local today_count
  today_count=$(find "$vdir" -maxdepth 1 -type f -name "VOICE-$(date '+%Y-%m-%d')*.md" 2>/dev/null | wc -l)
  local autosave_count
  autosave_count=$(find "$vdir" -maxdepth 1 -type f -name "Voice_*_$(date '+%Y-%m-%d').md" 2>/dev/null | wc -l)
  if (( today_count > 0 || autosave_count > 0 )); then
    ui_ok "Today:  $((today_count + autosave_count)) file(s)"
  else
    ui_info "Today:  no session yet"
  fi

  # Index Node API check
  echo ""
  local api_url="${AOS_INDEX_URL:-http://127.0.0.1:8799}"
  local health
  health=$(curl -sf "$api_url/health" 2>/dev/null || echo "")
  if [[ -n "$health" ]]; then
    ui_ok "Index Node: $api_url (online)"
    # Check memoirs PWA
    local pwa_status
    pwa_status=$(curl -sfI "$api_url/pwa/memoirs/" 2>/dev/null | head -1 || echo "")
    if [[ "$pwa_status" == *"200"* ]]; then
      ui_ok "Memoirs PWA: /pwa/memoirs/ (ok)"
    else
      ui_err "Memoirs PWA: /pwa/memoirs/ (not reachable)"
    fi
    # Check voice desktop
    local voice_status
    voice_status=$(curl -sfI "$api_url/voice/" 2>/dev/null | head -1 || echo "")
    if [[ "$voice_status" == *"200"* ]]; then
      ui_ok "Voice Desktop: /voice/ (ok)"
    else
      ui_err "Voice Desktop: /voice/ (not reachable)"
    fi
  else
    ui_err "Index Node: $api_url (offline)"
  fi

  echo ""
}

voice_menu_pick() {
  local prompt="$1"
  shift || true
  local -a options=("$@")
  local backend="${VOICECTL_MENU_BACKEND:-gum}"

  if [[ "$backend" == "fzf" ]]; then
    ui_menu_fzf "$prompt" "${options[@]}" && return 0
    ui_menu_gum "$prompt" "${options[@]}" && return 0
  else
    ui_menu_gum "$prompt" "${options[@]}" && return 0
    ui_menu_fzf "$prompt" "${options[@]}" && return 0
  fi

  ctl_choose_from_list "$prompt" "${options[@]}"
}

cmd_menu() {
  if ! ctl_can_prompt; then
    cmd_help
    return 0
  fi

  while true; do
    ui_title "voicectl"
    local action
    action="$(voice_menu_pick "VOICE" \
      "start session" \
      "recent (10)" \
      "list (20)" \
      "stats" \
      "status" \
      "search..." \
      "show..." \
      "edit..." \
      "strike..." \
      "dir" \
      "help" \
      "quit")" || return 0

    case "$action" in
      "start session") cmd_start ;;
      "recent (10)") cmd_recent 10 ;;
      "list (20)") cmd_list 20 ;;
      "stats") cmd_stats ;;
      "status") cmd_status ;;
      "search...")
        local q
        q="$(ui_input "Search query" "")" || true
        [[ -n "${q:-}" ]] && cmd_search "$q"
        ;;
      "show...")
        local id
        id="$(ui_input "Session ID" "")" || true
        [[ -n "${id:-}" ]] && cmd_show "$id"
        ;;
      "edit...")
        local id
        id="$(ui_input "Session ID" "")" || true
        [[ -n "${id:-}" ]] && cmd_edit "$id"
        ;;
      "strike...")
        local id
        id="$(ui_input "Session ID" "")" || true
        [[ -n "${id:-}" ]] && cmd_strike "$id"
        ;;
      "dir") cmd_dir ;;
      "help") cmd_help ;;
      "quit") return 0 ;;
      *) return 0 ;;
    esac

    ui_pause
  done
}

#─────────────────────────────────────────────────────────────────────────
# Help
#─────────────────────────────────────────────────────────────────────────

cmd_help() {
  cat <<EOF
voicectl - THE VOICE Management (Mental Mastery)

USAGE:
  voicectl <command> [options]

COMMANDS:
  menu                        Interactive terminal menu
  start                       Start new VOICE session (interactive 4-step)
  list [limit]                List recent sessions (default: 50)
  recent [count]              Show recent sessions (default: 10)
  show <id>                   View session with glow
  edit <id>                   Edit session in editor
  search <query>              Search sessions by content
  stats                       Session statistics
  strike <id>                 Extract STRIKE from session
  status                      Health check (vault, PWA, API)
  dir                         Show VOICE directory path

EXAMPLES:
  voicectl start              # Interactive 4-step session
  voicectl menu               # Interactive VOICE menu
  voicectl list               # Show all sessions
  voicectl recent 5           # Last 5 sessions
  voicectl show 2026-02-09    # View specific session
  voicectl search "pattern"   # Search for keyword
  voicectl stats              # Statistics

THE VOICE - 4 Steps:
  🛑 STOP    - Interrupt destructive pattern
  🙏 SUBMIT  - Face truth, surrender
  ⚔️  STRUGGLE - Rewrite narrative
  ⚡ STRIKE  - Decisive action

Integration:
  - VOICE → DOOR: Strike becomes War Stack
  - VOICE → GAME: Insights update Frame Map
  - 61 sessions Q3/Q4 = deep material for Maps

VOICE Directory: $(get_voice_dir)
EOF
}

#─────────────────────────────────────────────────────────────────────────
# Main
#─────────────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    start)
      cmd_start "$@"
      ;;
    menu)
      cmd_menu "$@"
      ;;
    list|ls)
      cmd_list "$@"
      ;;
    show|view)
      if [[ $# -eq 0 ]]; then
        ui_err "Usage: voicectl show <session-id>"
        exit 1
      fi
      cmd_show "$@"
      ;;
    edit)
      if [[ $# -eq 0 ]]; then
        ui_err "Usage: voicectl edit <session-id>"
        exit 1
      fi
      cmd_edit "$@"
      ;;
    search)
      if [[ $# -eq 0 ]]; then
        ui_err "Usage: voicectl search <query>"
        exit 1
      fi
      cmd_search "$@"
      ;;
    recent)
      cmd_recent "$@"
      ;;
    stats)
      cmd_stats "$@"
      ;;
    strike)
      if [[ $# -eq 0 ]]; then
        ui_err "Usage: voicectl strike <session-id>"
        exit 1
      fi
      cmd_strike "$@"
      ;;
    status)
      cmd_status "$@"
      ;;
    dir)
      cmd_dir "$@"
      ;;
    help|--help|-h)
      cmd_help
      ;;
    *)
      ui_err "Unknown command: $cmd"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
