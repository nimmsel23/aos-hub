#!/usr/bin/env bash
set -euo pipefail

APP="aos"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# Normalize to repo checkout if available
if [[ "$SCRIPT_DIR" != "$HOME/aos-hub" && -d "$HOME/aos-hub/scripts" ]]; then
  SCRIPT_DIR="$HOME/aos-hub"
fi

have() { command -v "$1" >/dev/null 2>&1; }
die() { echo "[$APP] $*" >&2; exit 1; }
can_prompt() {
  [[ -t 0 && -t 1 ]]
}

resolve_bin() {
  local primary="$1"; shift
  if [[ -n "$primary" && -x "$primary" ]]; then
    echo "$primary"; return 0
  fi
  for cand in "$@"; do
    if [[ -n "$cand" && -x "$cand" ]]; then
      echo "$cand"; return 0
    fi
  done
  if have "$primary"; then
    command -v "$primary"; return 0
  fi
  return 1
}

AOSCTL="$(resolve_bin "$SCRIPT_DIR/aosctl" || true)"
HUBCTL="$(resolve_bin "$SCRIPT_DIR/scripts/hubctl" || true)"
CORE4CTL="$(resolve_bin "$SCRIPT_DIR/core4/python-core4/core4ctl" "$SCRIPT_DIR/scripts/core4ctl" || true)"
C4D_BIN="$(resolve_bin "c4d" "$HOME/bin/c4d" || true)"
SYNCCTL="$(resolve_bin "$SCRIPT_DIR/scripts/syncctl" || true)"
GITCTL="$(resolve_bin "$SCRIPT_DIR/scripts/gitctl" || true)"
INDEXCTL="$(resolve_bin "$SCRIPT_DIR/scripts/indexctl" || true)"
NODECTL="$(resolve_bin "$SCRIPT_DIR/scripts/nodectl" || true)"
GAMECTL="$(resolve_bin "$SCRIPT_DIR/scripts/gamectl" || true)"
DOORCTL="$(resolve_bin "$SCRIPT_DIR/door/cli/doorctl" "$SCRIPT_DIR/scripts/doorctl" || true)"
BACKUPCTL="$(resolve_bin "$SCRIPT_DIR/scripts/backupctl" || true)"
MOUNTCTL="$(resolve_bin "$SCRIPT_DIR/scripts/mountctl" || true)"
HOOKCTL="$(resolve_bin "$SCRIPT_DIR/scripts/hookctl" || true)"
VOICECTL="$(resolve_bin "$SCRIPT_DIR/scripts/voicectl" || true)"
MOBILEAPPCTL="$(resolve_bin "$SCRIPT_DIR/scripts/mobileappctl" || true)"
GASCTL="$(resolve_bin "$SCRIPT_DIR/scripts/gasctl" || true)"
TELECTL="$(resolve_bin "$SCRIPT_DIR/scripts/telectl" || true)"
FIRECTL="$(resolve_bin "$SCRIPT_DIR/scripts/firectl" || true)"
ROUTERCTL="$(resolve_bin "$SCRIPT_DIR/routerctl" "$SCRIPT_DIR/router/routerctl" || true)"
BRIDGECTL="$(resolve_bin "$SCRIPT_DIR/bridgectl" "$SCRIPT_DIR/bridge/bridgectl" || true)"
NODE_RESTART="$SCRIPT_DIR/scripts/ctl/node-restart.sh"
AOS_DASHBOARD_EXT="${AOS_DASHBOARD_EXT:-$HOME/.config/aos/dashboard.sh}"

pick_exec_token() {
  local resolved="$1"
  local fallback="$2"
  if [[ -n "$resolved" ]]; then
    printf "%s\n" "$resolved"
  else
    printf "%s\n" "$fallback"
  fi
}

exec_or_path() {
  local resolved="$1"
  local fallback="$2"
  shift 2
  if [[ -n "$resolved" ]]; then
    exec "$resolved" "$@"
  fi
  have "$fallback" || die "$fallback not found in PATH"
  exec "$fallback" "$@"
}

usage() {
  cat <<EOF
$APP — αOS main terminal frontdoor (user workflows + wrappers)

Usage:
  $APP dashboard                    # hotkey terminal dashboard (default in TTY)
  $APP menu                         # gum menu (legacy/simple launcher)
  $APP restart [all|index|router|bridge]
  $APP sync|vault|git ...           # syncctl/gitctl wrappers
  $APP hub|index|bridge|router ...  # aos-hub system/ops wrappers
  $APP node|nodectl ...             # nodectl compatibility toolbox
  $APP core4|game|door|fire|tele ...  # user/centre wrappers
  $APP potential|plan|production|profit ...  # Door 4P phase frontdoors
  $APP backup|mount|hook|gas|voice|mobileapp ...
  $APP aosctl ...                   # direct aosctl passthrough
  $APP mobileappctl|pwa ...         # mobileapp aliases (compat)
  $APP alias <subcommand> [...]     # multi-shell alias manager (aos-alias)

Dashboard:
  - Hotkeys launch common status/doctor/menu flows (gamectl, doorctl, hubctl, ...)
  - Extend/override keys via: ${AOS_DASHBOARD_EXT}
    API in extension file: aos_dashboard_register <key> <group> <label> <desc> <cmd> [args...]

Examples:
  $APP
  $APP dashboard
  $APP game centres
  $APP door health
  $APP potential
  $APP plan activate 1
  $APP production focus
  $APP profit review
  $APP hub doctor
  $APP menu
  $APP sync summary
  $APP vault status
  $APP aosctl status
EOF
}

cmd="${1:-}"
shift || true

# ---- launcher menu (gum/fzf/select) ----
aos_menu_pick_select() {
  local prompt="$1"
  shift || true
  local -a options=("$@")
  [[ ${#options[@]} -gt 0 ]] || return 1
  can_prompt || return 1

  printf '%s\n' "$prompt"
  local opt=""
  select opt in "${options[@]}"; do
    [[ -n "$opt" ]] || continue
    printf '%s\n' "$opt"
    return 0
  done
  return 1
}

aos_menu_pick() {
  local prompt="$1"
  shift || true
  local -a options=("$@")
  local backend="${AOS_MENU_BACKEND:-gum}"
  [[ ${#options[@]} -gt 0 ]] || return 1

  if [[ "$backend" == "fzf" ]]; then
    if have fzf && can_prompt; then
      printf '%s\n' "${options[@]}" | fzf --prompt="${prompt} > " --height=~60% --border
      return 0
    fi
    if have gum && can_prompt; then
      gum choose --header "$prompt" "${options[@]}"
      return 0
    fi
  else
    if have gum && can_prompt; then
      gum choose --header "$prompt" "${options[@]}"
      return 0
    fi
    if have fzf && can_prompt; then
      printf '%s\n' "${options[@]}" | fzf --prompt="${prompt} > " --height=~60% --border
      return 0
    fi
  fi

  aos_menu_pick_select "$prompt" "${options[@]}"
}

menu() {
  if ! can_prompt; then
    usage
    return 0
  fi
  if ! have gum && ! have fzf; then
    if [[ -n "$AOSCTL" ]]; then
      exec "$AOSCTL" menu
    elif [[ -n "$HUBCTL" ]]; then
      exec "$HUBCTL" menu
    fi
    die "no gum/fzf found and no aosctl/hubctl menu fallback available"
  fi

  local choice
  local -a menu_options=(
    "Dashboard: hotkey terminal dashboard"
    "Sync: menu (syncctl)"
    "Sync: list targets"
    "Git: status"
    "Vault: status"
    "Core4: dashboard (c4d)"
    "Game: dashboard (gamectl)"
    "Door: dashboard (doorctl)"
    "Hub: menu (hubctl)"
    "Router: control bot (routerctl)"
    "Aliases: manage (aos-alias)"
    "Help"
    "Quit"
  )
  choice="$(aos_menu_pick "αOS — aos" "${menu_options[@]}")"

  case "$choice" in
    "Dashboard: hotkey terminal dashboard")
      dashboard
      ;;
    "Sync: menu (syncctl)")
      if [[ -n "$SYNCCTL" ]]; then
        exec "$SYNCCTL" menu
      fi
      exec syncctl menu
      ;;
    "Sync: list targets")
      if [[ -n "$SYNCCTL" ]]; then
        exec "$SYNCCTL" list
      fi
      exec syncctl list
      ;;
    "Git: status")
      if [[ -n "$GITCTL" ]]; then
        exec "$GITCTL" status
      fi
      exec gitctl status
      ;;
    "Vault: status")
      if [[ -n "$SYNCCTL" ]]; then
        exec "$SYNCCTL" vault status
      fi
      exec syncctl vault status
      ;;
    "Core4: dashboard (c4d)")
      if [[ -n "$C4D_BIN" ]]; then
        exec "$C4D_BIN"
      fi
      core4_cmd menu
      ;;
    "Game: dashboard (gamectl)")
      game_cmd dashboard
      ;;
    "Door: dashboard (doorctl)")
      door_cmd dashboard
      ;;
    "Hub: menu (hubctl)")
      hub_cmd menu
      ;;
    "Router: control bot (routerctl)")
      exec_or_path "$ROUTERCTL" routerctl
      ;;
    "Aliases: manage (aos-alias)")
      exec aos-alias ui
      ;;
    "Help") usage ;;
    "Quit") exit 0 ;;
    *) exit 0 ;;
  esac
}

# ---- dashboard registry ----
declare -a AOS_DASH_KEYS=()
declare -A AOS_DASH_GROUP=()
declare -A AOS_DASH_LABEL=()
declare -A AOS_DASH_DESC=()
declare -A AOS_DASH_CMD=()
AOS_DASH_SEP=$'\037'
AOS_DASH_READY=0
AOS_DASH_MESSAGE=""
AOS_DASH_MESSAGE_LEVEL="info"
AOS_DASH_SCREEN_ACTIVE=0

aos_dashboard_register() {
  local key="${1:-}"
  local group="${2:-General}"
  local label="${3:-}"
  local desc="${4:-}"
  shift 4 || true

  [[ -n "$key" ]] || die "dashboard register: missing key"
  [[ ${#key} -eq 1 ]] || die "dashboard register: key must be 1 char ($key)"
  [[ -n "$label" ]] || die "dashboard register: missing label for key $key"
  [[ $# -ge 1 ]] || die "dashboard register: missing command for key $key"

  local packed="$1"
  shift || true
  local arg
  for arg in "$@"; do
    packed+="${AOS_DASH_SEP}${arg}"
  done

  if [[ -z "${AOS_DASH_LABEL[$key]+x}" ]]; then
    AOS_DASH_KEYS+=("$key")
  fi
  AOS_DASH_GROUP[$key]="$group"
  AOS_DASH_LABEL[$key]="$label"
  AOS_DASH_DESC[$key]="$desc"
  AOS_DASH_CMD[$key]="$packed"
}

dashboard_unpack_cmd() {
  local key="$1"
  local packed="${AOS_DASH_CMD[$key]:-}"
  AOS_DASH_CMDV=()
  [[ -n "$packed" ]] || return 1
  IFS="$AOS_DASH_SEP" read -r -a AOS_DASH_CMDV <<<"$packed"
  [[ ${#AOS_DASH_CMDV[@]} -gt 0 ]]
}

dashboard_command_exists() {
  local key="$1"
  dashboard_unpack_cmd "$key" || return 1
  local bin="${AOS_DASH_CMDV[0]}"
  if [[ "$bin" == */* ]]; then
    [[ -x "$bin" ]]
  else
    have "$bin"
  fi
}

dashboard_set_message() {
  AOS_DASH_MESSAGE_LEVEL="${1:-info}"
  AOS_DASH_MESSAGE="${2:-}"
}

dashboard_screen_enter() {
  [[ "$AOS_DASH_SCREEN_ACTIVE" == "1" ]] && return 0
  [[ -t 1 ]] || return 0
  [[ "${TERM:-dumb}" != "dumb" ]] || return 0
  printf '\033[?1049h\033[2J\033[H\033[?25l'
  AOS_DASH_SCREEN_ACTIVE=1
}

dashboard_screen_leave() {
  [[ "$AOS_DASH_SCREEN_ACTIVE" == "1" ]] || return 0
  printf '\033[?25h\033[?1049l'
  AOS_DASH_SCREEN_ACTIVE=0
}

dashboard_screen_show_cursor() {
  [[ "$AOS_DASH_SCREEN_ACTIVE" == "1" ]] || return 0
  printf '\033[?25h'
}

dashboard_screen_hide_cursor() {
  [[ "$AOS_DASH_SCREEN_ACTIVE" == "1" ]] || return 0
  printf '\033[?25l'
}

dashboard_http_code() {
  local url="$1"
  if ! have curl; then
    printf "curl?"
    return 0
  fi
  local code
  code="$(curl -sS -o /dev/null -m 0.4 -w "%{http_code}" "$url" 2>/dev/null || true)"
  if [[ -z "$code" || "$code" == "000" ]]; then
    printf "down"
  else
    printf "%s" "$code"
  fi
}

dashboard_svc_state() {
  local scope="$1" unit="$2"
  if ! have systemctl; then
    printf "no-systemctl"
    return 0
  fi
  local out=""
  if [[ "$scope" == "user" ]]; then
    out="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
  else
    out="$(systemctl is-active "$unit" 2>/dev/null || true)"
  fi
  if [[ -n "$out" ]]; then
    printf "%s" "$out"
  else
    printf "unavail"
  fi
}

dashboard_mark() {
  local key="$1"
  if dashboard_command_exists "$key"; then
    printf "ok"
  else
    printf "!!"
  fi
}

dashboard_term_size() {
  AOS_DASH_ROWS=24
  AOS_DASH_COLS=80

  local sz=""
  if [[ -t 0 ]]; then
    sz="$(stty size 2>/dev/null || true)"
  elif [[ -r /dev/tty && -w /dev/tty ]]; then
    sz="$(stty size </dev/tty 2>/dev/tty || true)"
  fi

  if [[ "$sz" =~ ^([0-9]+)[[:space:]]+([0-9]+)$ ]]; then
    AOS_DASH_ROWS="${BASH_REMATCH[1]}"
    AOS_DASH_COLS="${BASH_REMATCH[2]}"
    return 0
  fi

  if have tput; then
    local lines cols
    lines="$(tput lines 2>/dev/null || true)"
    cols="$(tput cols 2>/dev/null || true)"
    [[ "$lines" =~ ^[0-9]+$ ]] && AOS_DASH_ROWS="$lines"
    [[ "$cols" =~ ^[0-9]+$ ]] && AOS_DASH_COLS="$cols"
  fi
}

dashboard_move_to() {
  local row="$1" col="${2:-1}"
  printf '\033[%d;%dH' "$row" "$col"
}

dashboard_print_line_fit() {
  local line="${1:-}"
  local width="${AOS_DASH_COLS:-80}"
  (( width < 8 )) && width=8
  if ((${#line} > width)); then
    if (( width > 3 )); then
      line="${line:0:width-3}..."
    else
      line="${line:0:width}"
    fi
  fi
  printf '\033[2K%s\n' "$line"
}

dashboard_render_body_content() {
  local now
  now="$(date '+%Y-%m-%d %H:%M:%S')"
  printf 'aos  |  terminal frontdoor  |  %s\n' "$now"
  printf '\n'
  printf '[Portals]\n'
  printf '  [c] Core4   (%s) -> c4d (fallback: core4ctl menu)\n' "$(dashboard_mark c)"
  printf '  [g] Game    (%s) -> gamectl dashboard\n' "$(dashboard_mark g)"
  printf '  [d] Door    (%s) -> doorctl dashboard\n' "$(dashboard_mark d)"
  printf '  [v] Voice   (%s) -> voicectl menu\n' "$(dashboard_mark v)"
  printf '\n'
  printf '[Layers]\n'
  printf '  [h] hubctl    (%s) -> system/service layer (router/bridge/node/sync/...)\n' "$(dashboard_mark h)"
  printf '  [a] aosctl    (%s) -> /opt/aos system service layer\n' "$(dashboard_mark a)"
  printf '  [m] aos menu  (local launcher / command palette)\n'
  printf '\n'
  printf '[Principle]\n'
  printf '  aos = frontdoor / portals. Component actions live in the wrapped *ctl CLIs.\n'
  printf '\n'
  printf 'Press ? for advanced keymap. Extension file: %s\n' "$AOS_DASHBOARD_EXT"
}

dashboard_help_keymap() {
  local key group prev_group="" state_mark
  printf '\nKeymap (all registered actions)\n'
  printf '%s\n' '------------------------------'
  for key in "${AOS_DASH_KEYS[@]}"; do
    group="${AOS_DASH_GROUP[$key]}"
    if [[ "$group" != "$prev_group" ]]; then
      [[ -n "$prev_group" ]] && printf '\n'
      printf '[%s]\n' "$group"
      prev_group="$group"
    fi
    if dashboard_command_exists "$key"; then
      state_mark="ok"
    else
      state_mark="!!"
    fi
    printf '  [%s] %-18s  (%s) %s\n' \
      "$key" "${AOS_DASH_LABEL[$key]}" "$state_mark" "${AOS_DASH_DESC[$key]}"
  done
}

