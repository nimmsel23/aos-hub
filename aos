dashboard_load_extensions() {
  if [[ -r "$AOS_DASHBOARD_EXT" ]]; then
    # shellcheck disable=SC1090
    source "$AOS_DASHBOARD_EXT"
    dashboard_set_message info "Loaded dashboard extensions: $AOS_DASHBOARD_EXT"
  fi
}

dashboard_init() {
  [[ "$AOS_DASH_READY" == "1" ]] && return 0
  dashboard_register_defaults
  dashboard_load_extensions
  AOS_DASH_READY=1
}

dashboard_render() {
  dashboard_term_size
  printf '\033[2J\033[H'

  local footer_lines=3
  local body_max=$((AOS_DASH_ROWS - footer_lines))
  (( body_max < 3 )) && body_max=3

  local -a body_lines=()
  mapfile -t body_lines < <(dashboard_render_body_content)

  local i
  for ((i = 0; i < body_max && i < ${#body_lines[@]}; i++)); do
    dashboard_print_line_fit "${body_lines[$i]}"
  done

  for ((; i < body_max; i++)); do
    printf '\033[2K\n'
  done

  dashboard_move_to $((AOS_DASH_ROWS - footer_lines + 1)) 1
  printf '\033[2K'
  printf '%*s\n' "${AOS_DASH_COLS}" '' | tr ' ' '-'
  dashboard_print_line_fit 'Hotkeys: [c g d v] portals  [h] hubctl  [a] aosctl  [m] menu  [?] advanced  [q] quit'
  if [[ -n "$AOS_DASH_MESSAGE" ]]; then
    dashboard_print_line_fit "[$AOS_DASH_MESSAGE_LEVEL] $AOS_DASH_MESSAGE"
  else
    dashboard_print_line_fit "Ready."
  fi
}

dashboard_help_overlay() {
  printf '\033[2J\033[H'
  cat <<EOF
aos dashboard help

Built-ins:
  q         Quit dashboard
  ENTER     Refresh dashboard
  ?         This help

Extension API:
  Add file: ${AOS_DASHBOARD_EXT}
  Function: aos_dashboard_register <key> <group> <label> <desc> <cmd> [args...]

Example:
  aos_dashboard_register "w" "Custom" "watchdog" "Trigger local systemstatus" watchdog

Notes:
  - Reuse an existing key to override an entry.
  - New keys append to the end of their group order (in registration order).
  - Commands run in the current terminal and return to the dashboard when they exit.
EOF
  dashboard_help_keymap
  printf '\nPress ENTER to return... '
  dashboard_screen_show_cursor
  IFS= read -r _
  dashboard_screen_hide_cursor
}

dashboard_run_key() {
  local key="$1"
  if ! dashboard_unpack_cmd "$key"; then
    dashboard_set_message err "No command registered for key '$key'"
    return 1
  fi

  local cmdline=""
  local token
  for token in "${AOS_DASH_CMDV[@]}"; do
    printf -v token '%q' "$token"
    cmdline+="${cmdline:+ }${token}"
  done

  printf '\033[2J\033[H'
  printf 'aos dashboard -> [%s] %s\n' "$key" "${AOS_DASH_LABEL[$key]}"
  printf '%s\n' "${AOS_DASH_DESC[$key]}"
  printf '\n$ %s\n\n' "$cmdline"

  dashboard_screen_show_cursor
  set +e
  "${AOS_DASH_CMDV[@]}"
  local rc=$?
  set -e
  dashboard_screen_hide_cursor

  dashboard_set_message info "Key '$key' finished with exit code $rc"
  printf '\n[exit=%d] Press ENTER to return... ' "$rc"
  dashboard_screen_show_cursor
  IFS= read -r _
  dashboard_screen_hide_cursor
  return 0
}

dashboard() {
  if ! can_prompt; then
    usage
    return 0
  fi

  dashboard_init
  dashboard_screen_enter
  trap 'dashboard_screen_leave' EXIT INT TERM

  while true; do
    dashboard_render
    IFS= read -rsn1 key || break
    case "${key:-}" in
      q) break ;;
      "") dashboard_set_message info "Refreshed dashboard" ;;
      "?") dashboard_help_overlay ;;
      $'\e')
        IFS= read -rsn2 -t 0.02 _ || true
        dashboard_set_message info "Use dashboard hotkeys (single key) or ? for help"
        ;;
      *)
        dashboard_run_key "$key" || true
        ;;
    esac
  done

  dashboard_screen_leave
  trap - EXIT INT TERM
}

# ---- wrappers ----
sync_cmd() {
  local sub="${1:-menu}"; shift || true
  exec_or_path "$SYNCCTL" syncctl "$sub" "$@"
}

git_cmd() {
  local sub="${1:-status}"; shift || true
  exec_or_path "$GITCTL" gitctl "$sub" "$@"
}

vault_cmd() {
  local sub="${1:-status}"; shift || true
  exec_or_path "$SYNCCTL" syncctl vault "$sub" "$@"
}

router_cmd() {
  local sub="${1:-status}"; shift || true
  exec_or_path "$ROUTERCTL" routerctl "$sub" "$@"
}

bridge_cmd() {
  local sub="${1:-health}"; shift || true
  exec_or_path "$BRIDGECTL" bridgectl "$sub" "$@"
}

index_cmd() {
  local sub="${1:-status}"; shift || true
  exec_or_path "$INDEXCTL" indexctl "$sub" "$@"
}

node_cmd() {
  local sub="${1:-status}"; shift || true
  exec_or_path "$NODECTL" nodectl "$sub" "$@"
}

hub_cmd() {
  local sub="${1:-menu}"; shift || true
  exec_or_path "$HUBCTL" hubctl "$sub" "$@"
}

aosctl_cmd() {
  local sub="${1:-dashboard}"; shift || true
  exec_or_path "$AOSCTL" aosctl "$sub" "$@"
}

core4_cmd() {
  local sub="${1:-menu}"; shift || true
  exec_or_path "$CORE4CTL" core4ctl "$sub" "$@"
}

game_cmd() {
  local sub="${1:-dashboard}"; shift || true
  exec_or_path "$GAMECTL" gamectl "$sub" "$@"
}

door_cmd() {
  local sub="${1:-dashboard}"; shift || true
  exec_or_path "$DOORCTL" doorctl "$sub" "$@"
}

fire_cmd() {
  local sub="${1:-status}"; shift || true
  exec_or_path "$FIRECTL" firectl "$sub" "$@"
}

door_phase_cmd() {
  local phase="${1:?}"
  shift || true
  door_cmd "$phase" "$@"
}

tele_cmd() {
  local sub="${1:-help}"; shift || true
  exec_or_path "$TELECTL" telectl "$sub" "$@"
}

backup_cmd() {
  local sub="${1:-status}"; shift || true
  exec_or_path "$BACKUPCTL" backupctl "$sub" "$@"
}

mount_cmd() {
  local sub="${1:-status}"; shift || true
  exec_or_path "$MOUNTCTL" mountctl "$sub" "$@"
}

hook_cmd() {
  local sub="${1:-status}"; shift || true
  exec_or_path "$HOOKCTL" hookctl "$sub" "$@"
}

gas_cmd() {
  local sub="${1:-help}"; shift || true
  exec_or_path "$GASCTL" gasctl "$sub" "$@"
}

voice_cmd() {
  local sub="${1:-menu}"; shift || true
  exec_or_path "$VOICECTL" voicectl "$sub" "$@"
}

mobileapp_cmd() {
  local sub="${1:-help}"; shift || true
  exec_or_path "$MOBILEAPPCTL" mobileappctl "$sub" "$@"
}

alias_cmd() {
  have aos-alias || die "aos-alias not found in PATH"
  exec aos-alias "${@:-ui}"
}

restart_cmd() {
  local target="${1:-all}"
  [[ -x "$NODE_RESTART" ]] || die "node-restart not found: $NODE_RESTART"
  # Source so we stay in the same process (no exec — we want to return)
  # shellcheck source=scripts/ctl/node-restart.sh
  source "$NODE_RESTART"
  node_restart_main "$target"
}

case "$cmd" in
  dashboard|dash|ui) dashboard ;;
  menu) menu ;;
  restart) restart_cmd "$@" ;;
  sync) sync_cmd "$@" ;;
  git) git_cmd "$@" ;;
  vault) vault_cmd "$@" ;;
  hub) hub_cmd "$@" ;;
  aosctl) aosctl_cmd "$@" ;;
  core4) core4_cmd "$@" ;;
  index) index_cmd "$@" ;;
  node|nodectl) node_cmd "$@" ;;
  bridge) bridge_cmd "$@" ;;
  router) router_cmd "$@" ;;
  game) game_cmd "$@" ;;
  door) door_cmd "$@" ;;
  potential|plan|production|profit) door_phase_cmd "$cmd" "$@" ;;
  fire) fire_cmd "$@" ;;
  tele) tele_cmd "$@" ;;
  backup) backup_cmd "$@" ;;
  mount) mount_cmd "$@" ;;
  hook) hook_cmd "$@" ;;
  gas) gas_cmd "$@" ;;
  voice) voice_cmd "$@" ;;
  mobileapp|mobileappctl|pwa) mobileapp_cmd "$@" ;;
  alias) alias_cmd "$@" ;;
  help|-h|--help) usage ;;
  "")
    if can_prompt; then
      dashboard
    else
      usage
    fi
    ;;
  *)
    echo "[$APP] Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
