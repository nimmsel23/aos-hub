    "$(pick_exec_token "$HUBCTL" "hubctl")" menu
  aos_dashboard_register "m" "Core" "aos menu" "Launcher menu (gum/fzf/select)" \
    "$(pick_exec_token "$SCRIPT_DIR/aos" "aos")" menu
