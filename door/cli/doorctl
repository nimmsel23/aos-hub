cmd_commands() {
  if json_mode; then
    require_jq || return 1
    print_command_catalog \
      | jq -R 'select(length > 0) | split("\t") | {name: .[0], usage: .[1], summary: .[2]}' \
      | jq -s '.'
    return 0
  fi

  ui_title "doorctl Commands"
  print_command_catalog | while IFS=$'\t' read -r name usage summary; do
    printf "  %-10s %-30s %s\n" "$name" "$usage" "$summary"
  done
}

cmd_current() {
  local arg="${1:-}"
  if [[ -z "$arg" ]]; then
    local cur
    cur="$(door_current_get || true)"
    if json_mode; then
      require_jq || return 1
      jq -n --arg door "$cur" '{door:$door}'
    elif [[ -n "$cur" ]]; then
      echo "$cur"
    fi
    return 0
  fi

  if [[ "$arg" == "clear" || "$arg" == "reset" ]]; then
    door_current_clear
    if json_mode; then
      require_jq || return 1
      jq -n '{cleared:true}'
    fi
    return 0
  fi

  local door_name="$*"
  door_current_set "$door_name"
  local stack_file=""
  stack_file="$(door_stack_file_for "$door_name" || true)"
  if [[ -z "$stack_file" ]]; then
    ui_warn "No War Stack found in $DOOR_PRODUCTION_DIR for: $door_name"
  fi
  if json_mode; then
    require_jq || return 1
    jq -n --arg door "$door_name" --arg stack "$stack_file" '{door:$door, set:true, warstack:$stack}'
  else
    echo "$door_name"
  fi
}

cmd_ctx() {
  local action="${1:-menu}"
  if command -v doorctx >/dev/null 2>&1; then
    doorctx "$action"
    return $?
  fi
  if command -v pwactx >/dev/null 2>&1; then
    pwactx door "$action"
    return $?
  fi
  echo "doorctx/pwactx not found" >&2
  return 1
}

build_health_json() {
  require_jq || return 1

  local doors_json="${1:-[]}"
  local items=()
  local healthy_count=0
  local attention_count=0
  local stalled_count=0

  while IFS= read -r door; do
    [[ -z "$door" ]] && continue
    local name modified activity health_status
    name="$(printf "%s" "$door" | jq -r '.name')"
    modified="$(printf "%s" "$door" | jq -r '.modified // ""')"
    activity="$(time_ago "$modified")"
    health_status="$(get_health_status "$modified")"

    case "$health_status" in
      healthy) healthy_count=$((healthy_count + 1)) ;;
      attention) attention_count=$((attention_count + 1)) ;;
      stalled) stalled_count=$((stalled_count + 1)) ;;
    esac

    items+=("$(printf "%s" "$door" | jq -c --arg activity "$activity" --arg health_status "$health_status" \
      '. + {activity: $activity, health_status: $health_status}')")
  done < <(printf "%s" "$doors_json" | jq -c '.[]?')

  if ((${#items[@]} == 0)); then
    jq -n \
      --argjson healthy "$healthy_count" \
      --argjson attention "$attention_count" \
      --argjson stalled "$stalled_count" \
      '{summary:{healthy:$healthy, attention:$attention, stalled:$stalled, total:0}, doors:[]}'
    return 0
  fi

  printf "%s\n" "${items[@]}" | jq -s \
    --argjson healthy "$healthy_count" \
    --argjson attention "$attention_count" \
    --argjson stalled "$stalled_count" \
    '{summary:{healthy:$healthy, attention:$attention, stalled:$stalled, total:length}, doors:.}'
}

cmd_phase_report() {
  local phase="${1:?}"
  local status_filter="${2:-pending}"
  local -a query=()

  require_task || return 1

  case "$phase" in
    potential)
      query+=("(project:HotList or project:HOTLIST)")
      ;;
    plan)
      query+=("(project:HotList or project:HOTLIST)")
      query+=("(priority:H or priority:M or priority:L)")
      ;;
    production)
      query+=("(door_name.not: or +door or +hit or +strike)")
      ;;
    profit)
      query+=("(door_name.not: or +door or +hit or +strike)")
      ;;
    *)
      query+=("+$phase")
      ;;
  esac

  if [[ "$status_filter" != "all" ]]; then
    query+=("status:$status_filter")
  fi

  if json_mode; then
    require_jq || return 1
    "$TASK_BIN" "${query[@]}" export 2>/dev/null
    return 0
  fi

  ui_title "Door Phase: ${phase^}"
  "$TASK_BIN" "${query[@]}"
}

cmd_potential() {
  local sub="${1:-list}"
  shift || true

  case "$sub" in
    list|show|"")
      cmd_hotlist list "$@"
      ;;
    json)
      cmd_hotlist json "${1:-active}"
      ;;
    add)
      cmd_hotlist add "$@"
      ;;
    open)
      cmd_hotlist open "$@"
      ;;
    import|capture)
      [[ $# -ge 2 ]] || { ui_err "Usage: doorctl potential import <task-uuid> <description...>"; return 1; }
      require_exec_script "$HOT_TO_MD_SH" "hot_to_md.sh" || return 1
      "$HOT_TO_MD_SH" "$@"
      ;;
    report)
      cmd_phase_report potential "${1:-pending}"
      ;;
    pending|completed|deleted|waiting|all)
      # Backward compatibility: `doorctl potential pending`
      cmd_phase_report potential "$sub"
      ;;
    help|-h|--help)
      cat <<'EOF'
doorctl potential

Potential = Hot List / Possibilities (Chapter 26)

Usage:
  doorctl potential [list]
  doorctl potential json [active|all|promoted]
  doorctl potential add <idea...>
  doorctl potential open <task-number>
  doorctl potential import <task-uuid> <description...>
  doorctl potential report [status]
EOF
      ;;
    *)
      ui_err "Unknown potential command: $sub"
      return 2
      ;;
  esac
}

cmd_plan() {
  local sub="${1:-list}"
  shift || true

  case "$sub" in
    list|show|status|"")
      cmd_phase_report plan pending
      ;;
    activate|promote)
      cmd_doorwar_activate "$@"
      ;;
    war|warstack)
      # Compatibility alias: War Stack belongs to Production.
      cmd_production warstack "$@"
      ;;
    automate)
      # Compatibility alias: canonical entrypoint is `doorctl production automate`.
      cmd_production automate "$@"
      ;;
    transition)
      [[ $# -ge 2 ]] || { ui_err "Usage: doorctl plan transition <task_id> <title...>"; return 1; }
      require_exec_script "$DOOR_LIFECYCLE_SH" "door_lifecycle.sh" || return 1
      local task_id="$1"; shift
      "$DOOR_LIFECYCLE_SH" "potential" "plan" "$task_id" "$*"
      ;;
    report)
      cmd_phase_report plan "${1:-pending}"
      ;;
    pending|completed|deleted|waiting|all)
      cmd_phase_report plan "$sub"
      ;;
    help|-h|--help)
      cat <<'EOF'
doorctl plan

Plan = Door War (Chapter 27)

Usage:
  doorctl plan [list]
  doorctl plan activate <hot-selector> [door-name] [--force]
  doorctl plan report [status]

Compatibility aliases:
  doorctl plan war <door> [show|edit]
  doorctl plan automate <war-stack-file.md>
EOF
      ;;
    *)
      ui_err "Unknown plan command: $sub"
      return 2
      ;;
  esac
}

