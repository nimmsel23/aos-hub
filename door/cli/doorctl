cmd_health() {
  require_task || return 1
  require_jq || return 1

  local doors
  doors="$(get_doors 2>/dev/null || echo '[]')"

  if json_mode; then
    build_health_json "$doors"
    return 0
  fi

  ui_title "Door Health Check"

  if [[ "$doors" == "[]" || -z "$doors" ]]; then
    ui_info "No doors to check."
    return 0
  fi

  echo "$doors" | jq -r '.[] | @json' | while IFS= read -r door; do
    local name
    name=$(echo "$door" | jq -r '.name')
    local modified
    modified=$(echo "$door" | jq -r '.modified')
    local activity
    activity=$(time_ago "$modified")

    local health_status
    health_status=$(get_health_status "$modified")
    local emoji
    emoji=$(get_health_emoji "$health_status")

    case "$health_status" in
      stalled) ui_err "$emoji $name: STALLED ($activity)" ;;
      attention) ui_warn "$emoji $name: Needs attention ($activity)" ;;
      healthy) ui_ok "$emoji $name: Healthy ($activity)" ;;
    esac
  done

  echo
  ui_info "Stalled = no activity in $STALLED_DAYS+ days"
  ui_info "Needs attention = no activity in 3+ days"
}

cmd_stalled() {
  require_task || return 1
  require_jq || return 1

  local doors
  doors="$(get_doors 2>/dev/null || echo '[]')"

  if json_mode; then
    local items=()
    while IFS= read -r door; do
      [[ -z "$door" ]] && continue
      local modified activity
      modified="$(printf "%s" "$door" | jq -r '.modified // ""')"
      if is_stalled "$modified"; then
        activity="$(time_ago "$modified")"
        items+=("$(printf "%s" "$door" | jq -c --arg activity "$activity" '. + {activity: $activity}')")
      fi
    done < <(printf "%s" "$doors" | jq -c '.[]?')

    if ((${#items[@]} == 0)); then
      printf '[]\n'
    else
      printf "%s\n" "${items[@]}" | jq -s '.'
    fi
    return 0
  fi

  ui_title "Stalled Doors"

  if [[ "$doors" == "[]" || -z "$doors" ]]; then
    ui_info "No doors found."
    return 0
  fi

  local found=0
  while IFS= read -r door; do
    local name
    name=$(echo "$door" | jq -r '.name')
    local modified
    modified=$(echo "$door" | jq -r '.modified')
    local activity
    activity=$(time_ago "$modified")

    if is_stalled "$modified"; then
      echo "- $name ($activity)"
      found=1
    fi
  done < <(echo "$doors" | jq -r '.[] | @json')

  if ((found == 0)); then
    ui_ok "No stalled doors!"
  fi
}

