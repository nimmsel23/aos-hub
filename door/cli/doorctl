phase_count() {
  local phase="${1:?}"
  if ! have_task || ! command -v jq >/dev/null 2>&1; then
    printf "?"
    return 0
  fi
  local out count
  out="$("$TASK_BIN" "+$phase" status:pending export 2>/dev/null || true)"
  count="$(printf "%s" "$out" | jq 'length' 2>/dev/null || echo '?')"
  printf "%s" "$count"
}

hotlist_index_path() {
  printf "%s/Door/1-Potential/hotlist_index.json" "$VAULT_DIR"
}

hotlist_load_index() {
  require_jq || return 1
  local path
  path="$(hotlist_index_path)"

  if [[ ! -f "$path" ]]; then
    printf '{"items":[]}\n'
    return 0
  fi

  jq -c '
    if type == "array" then
      {items: .}
    elif type == "object" then
      . + {items: (.items // [])}
    else
      {items: []}
    end
  ' "$path"
}

hotlist_save_index() {
  require_jq || return 1
  local json="${1:?}"
  local path tmp
  path="$(hotlist_index_path)"
  mkdir -p "$(dirname "$path")"
  tmp="$(mktemp /tmp/doorctl-hotlist.XXXXXX.json)"
  printf "%s\n" "$json" | jq '.' > "$tmp"
  mv "$tmp" "$path"
}

hotlist_list_json() {
  local mode="${1:-active}"
  local data items
  data="$(hotlist_load_index)"

  case "$mode" in
    all)
      printf "%s\n" "$data" | jq '
        [(.items // [])[] | . as $i | .]
      '
      ;;
    active|open)
      printf "%s\n" "$data" | jq '
        [(.items // [])[]
         | select((.status // "active") as $s | ($s == "active" or $s == "new"))
        ]
      '
      ;;
    promoted|plan)
      printf "%s\n" "$data" | jq '
        [(.items // [])[]
         | select((.status // "") == "promoted" or (.phase // "") == "plan")
        ]
      '
      ;;
    *)
      ui_err "Unknown hotlist json mode: $mode (use all|active|promoted)"
      return 2
      ;;
  esac
}

hotlist_enumerated_json() {
  local mode="${1:-all}"
  hotlist_list_json "$mode" | jq '
    to_entries
    | map(.value + {_hot_index0: .key, hot_index: (.key + 1)})
  '
}

hotlist_select_entry_json() {
  local selector="${1:?}"
  require_jq || return 1
  local data
  data="$(hotlist_enumerated_json all)"

  if [[ "$selector" =~ ^[0-9]+$ ]]; then
    printf "%s\n" "$data" | jq -c --argjson idx "$selector" '
      map(select(.hot_index == $idx)) | .[0] // empty
    '
    return 0
  fi

  printf "%s\n" "$data" | jq -c --arg s "$selector" '
    map(select(
      (.tw_uuid // "" | startswith($s))
      or (.task_uuid // "" | startswith($s))
      or (.id // "" | startswith($s))
      or (.idea // "" == $s)
      or (.title // "" == $s)
      or (.door_name // "" == $s)
      or (.file // "" == $s)
      or (.md_name // "" == $s)
      or ((.file // "") | endswith("/" + $s))
    )) | .[0] // empty
  '
}

slugify_door_name() {
  local raw="${1:-}"
  raw="$(printf "%s" "$raw" | tr '[:upper:]' '[:lower:]')"
  raw="$(printf "%s" "$raw" | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
  [[ -n "$raw" ]] || raw="door"
  printf "%s" "$raw"
}

yaml_quote() {
  local s="${1:-}"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf "\"%s\"" "$s"
}

iso_now() {
  date -Iseconds
}

sync_hot_task_selection() {
  local tw_uuid="${1:-}"
  local door_name="${2:-}"
  [[ -n "$tw_uuid" ]] || return 0
  have_task || return 0
  # Door War is represented by task priority on the HotList task itself.
  # Activation must not create a synthetic plan lane in Taskwarrior.
  "$TASK_BIN" rc.hooks=0 "$tw_uuid" modify "door_name:$door_name" >/dev/null 2>&1 || true
}

scope_priority_filter_for_mode() {
  local mode="${1:-}"
  case "$mode" in
    h|high) echo "priority:H" ;;
    m|medium) echo "priority:M" ;;
    l|low) echo "priority:L" ;;
    *) echo "" ;;
  esac
}

