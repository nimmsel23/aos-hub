#!/usr/bin/env bash
# doorctl - Door Task Management CLI
# Sources logic from door/lib/* for reusability

set -euo pipefail

DOORCTL_VERSION="2.2.1"
DOORCTL_OUTPUT_FORMAT="text"

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
DOOR_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
ROOT_DIR="$(cd "$DOOR_DIR/.." && pwd)"

# Load global env
DOORCTL_PRESET_AOS_VAULT_DIR="${AOS_VAULT_DIR-}"
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/lib/aos-env.sh"
aos_env_load "" "$ROOT_DIR" || true
if [[ -n "${DOORCTL_PRESET_AOS_VAULT_DIR:-}" ]]; then
  AOS_VAULT_DIR="$DOORCTL_PRESET_AOS_VAULT_DIR"
fi

# Load UI helpers
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/ctl-lib.sh"

# Load door libs
# shellcheck disable=SC1091
source "$DOOR_DIR/lib/door_data.sh"
# shellcheck disable=SC1091
source "$DOOR_DIR/lib/door_phase.sh"
# shellcheck disable=SC1091
source "$DOOR_DIR/lib/door_health.sh"
# shellcheck disable=SC1091
source "$DOOR_DIR/lib/door_format.sh"

# Config
VAULT_DIR="${AOS_VAULT_DIR:-$HOME/AlphaOS-Vault}"
STALLED_DAYS="${AOS_DOOR_STALLED_DAYS:-7}"
ATTENTION_DAYS="${AOS_DOOR_ATTENTION_DAYS:-3}"
TASK_BIN="${TASK_BIN:-task}"
HOT_PY="$DOOR_DIR/python-potential/hot.py"
HOT_TO_MD_SH="$DOOR_DIR/hot_to_md.sh"
CREATE_WARSTACK_SH="$DOOR_DIR/create_warstack.sh"
DOOR_FILE_WATCHER_SH="$DOOR_DIR/door_file_watcher.sh"
DOOR_LIFECYCLE_SH="$DOOR_DIR/door_lifecycle.sh"
DOOR_CURRENT_FILE="${AOS_DOOR_CURRENT_FILE:-$HOME/.aos/door.current}"
DOOR_PRODUCTION_DIR="${AOS_DOOR_PRODUCTION_DIR:-$VAULT_DIR/Door/3-Production}"

ensure_door_state_dir() {
  local dir
  dir="$(dirname "$DOOR_CURRENT_FILE")"
  mkdir -p "$dir"
}

door_current_get() {
  if [[ -f "$DOOR_CURRENT_FILE" ]]; then
    cat "$DOOR_CURRENT_FILE"
  fi
}

door_current_set() {
  local value="${1:?}"
  ensure_door_state_dir
  printf "%s\n" "$value" >"$DOOR_CURRENT_FILE"
}

door_current_clear() {
  if [[ -f "$DOOR_CURRENT_FILE" ]]; then
    rm -f "$DOOR_CURRENT_FILE"
  fi
}

door_stack_file_for() {
  local door_name="${1:?}"
  local dir="${DOOR_PRODUCTION_DIR}"
  [[ -d "$dir" ]] || return 1
  find "$dir" -maxdepth 1 -type f -name "STACK_*.md" 2>/dev/null \
    | while IFS= read -r f; do
        local base
        base="$(basename "$f")"
        if printf "%s" "$base" | grep -qi -- "$door_name"; then
          printf "%s\n" "$f"
          return 0
        fi
      done
  return 1
}

#───────────────────────────────────────────────────────────────────────────────
# Helpers / Flow Views
#───────────────────────────────────────────────────────────────────────────────

have_task() {
  command -v "$TASK_BIN" >/dev/null 2>&1
}

have_jq() {
  command -v jq >/dev/null 2>&1
}

json_mode() {
  [[ "$DOORCTL_OUTPUT_FORMAT" == "json" ]]
}

require_jq() {
  if have_jq; then
    return 0
  fi
  ui_err "jq is required for this command/output mode"
  return 1
}

require_task() {
  if have_task; then
    return 0
  fi
  ui_err "Taskwarrior not found: $TASK_BIN"
  return 1
}

require_exec_script() {
  local file="${1:?}"
  local label="${2:-script}"
  if [[ -x "$file" ]]; then
    return 0
  fi
  ui_err "$label not found or not executable: $file"
  return 1
}

select_editor() {
  if command -v micro >/dev/null 2>&1; then
    printf "micro"
  elif command -v nano >/dev/null 2>&1; then
    printf "nano"
  else
    printf "%s" "${EDITOR:-nano}"
  fi
}

warstack_path() {
  local door_name="${1:?}"
  local slug
  slug="$(slugify_door_name "$door_name")"
  local primary legacy
  primary="${DOOR_PRODUCTION_DIR}/STACK_${slug}.md"
  legacy="${VAULT_DIR}/Door/War-Stacks/${door_name}.md"
  if [[ -f "$primary" ]]; then
    printf "%s\n" "$primary"
    return 0
  fi
  if [[ -f "$legacy" ]]; then
    printf "%s\n" "$legacy"
    return 0
  fi
  # Prefer canonical 3-Production location for new stacks.
  printf "%s\n" "$primary"
}

note_path() {
  local door_name="${1:?}"
  printf "%s/Door/notes/%s.md" "$VAULT_DIR" "$door_name"
}

