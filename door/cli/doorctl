  shift || true

  case "$sub" in
    focus|today|"")
      cmd_focus "$@"
      ;;
    hitlist|hits)
      if [[ "$sub" == "hits" ]]; then
        cmd_hits "$@"
      else
        cmd_hitlist "$@"
      fi
      ;;
    next)
      cmd_next "$@"
      ;;
    done)
      cmd_done "$@"
      ;;
    edit)
      cmd_edit "$@"
      ;;
    open)
      cmd_open "$@"
      ;;
    war|warstack)
      cmd_warstack "$@"
      ;;
    automate)
      [[ $# -ge 1 ]] || { ui_err "Usage: doorctl production automate <war-stack-file.md>"; return 1; }
      require_exec_script "$CREATE_WARSTACK_SH" "create_warstack.sh" || return 1
      "$CREATE_WARSTACK_SH" "$@"
      ;;
    watch)
      require_exec_script "$DOOR_FILE_WATCHER_SH" "door_file_watcher.sh" || return 1
      "$DOOR_FILE_WATCHER_SH" "$@"
      ;;
    report)
      cmd_phase_report production "${1:-pending}"
      ;;
    pending|completed|deleted|waiting|all)
      cmd_phase_report production "$sub"
      ;;
    help|-h|--help)
      cat <<'EOF'
doorctl production

Production = Hit execution / progress sync (Chapter 29)

