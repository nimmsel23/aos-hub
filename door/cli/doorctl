# Render one compact dashboard snapshot. This function is intentionally pure-ish:
# it prints a full "frame" based on current data, and does not prompt.
dashboard_render_snapshot() {
  local doors_json='[]'
  local health_json='{"summary":{"healthy":0,"attention":0,"stalled":0,"total":0},"doors":[]}'
  local hot_json='[]'

  # We keep collection defensive so the dashboard still opens even when one
  # dependency (task/jq/hotlist file) is temporarily unavailable.
  if have_jq; then
    hot_json="$(hotlist_enumerated_json active 2>/dev/null || echo '[]')"
    if have_task; then
      doors_json="$(get_doors 2>/dev/null || echo '[]')"
      health_json="$(build_health_json "$doors_json" 2>/dev/null || echo "$health_json")"
    fi
  fi

  ui_title "Door Dashboard"
  printf "Counts (pending): potential=%s  plan=%s  production=%s  profit=%s\n" \
    "$(phase_count potential)" \
    "$(phase_count plan)" \
    "$(phase_count production)" \
    "$(phase_count profit)"

  if have_jq; then
    # Health summary stays compact here; detailed per-door diagnostics live in
    # `doorctl health`.
    printf "Health: doors=%s  healthy=%s  attention=%s  stalled=%s\n" \
      "$(printf "%s" "$health_json" | jq -r '.summary.total // 0' 2>/dev/null || echo 0)" \
      "$(printf "%s" "$health_json" | jq -r '.summary.healthy // 0' 2>/dev/null || echo 0)" \
      "$(printf "%s" "$health_json" | jq -r '.summary.attention // 0' 2>/dev/null || echo 0)" \
      "$(printf "%s" "$health_json" | jq -r '.summary.stalled // 0' 2>/dev/null || echo 0)"
  else
    ui_warn "jq missing: dashboard summaries limited"
  fi

  echo
  # Make the 4 Door phases visible as filesystem "anchors" right in the dashboard.
  # This mirrors the user's real vault workflow (1-/2-/3-/4- folders) and reduces
  # context-switching when deciding where something belongs next.
  ui_info "Door Phase Folders"
  local door_root="$VAULT_DIR/Door"
  printf "  1-Potential  %s%s\n" "$door_root/1-Potential" "$( [[ -d "$door_root/1-Potential" ]] && printf '' || printf '  (missing)' )"
  printf "  2-Plan       %s%s\n" "$door_root/2-Plan" "$( [[ -d "$door_root/2-Plan" ]] && printf '' || printf '  (missing)' )"
  printf "  3-Production %s%s\n" "$door_root/3-Production" "$( [[ -d "$door_root/3-Production" ]] && printf '' || printf '  (missing)' )"
  printf "  4-Profit     %s%s\n" "$door_root/4-Profit" "$( [[ -d "$door_root/4-Profit" ]] && printf '' || printf '  (missing)' )"

  echo
  ui_info "Hot List (active, top 8)"
  if ! have_jq; then
    printf "  jq required for hotlist preview\n"
  elif [[ "$(printf "%s" "$hot_json" | jq 'length' 2>/dev/null || echo 0)" == "0" ]]; then
    printf "  No active Hot List entries (add with: doorctl hot \"Idea ...\")\n"
  else
    printf "%s" "$hot_json" | jq -r '
      .[:8][] |
      [
        ("#" + ((.hot_index // 0)|tostring)),
        ((.idea // .title // "Untitled") | tostring | gsub("[\\r\\n]+";" ") | .[0:72]),
        ((.status // "active") | tostring),
        ((.tw_uuid // "") | tostring | if length>0 then .[0:8] else "-" end)
      ] | @tsv
    ' | while IFS=$'\t' read -r idx idea status tw; do
      printf "  %-4s %-72s  %-9s %s\n" "$idx" "$idea" "$status" "$tw"
    done
  fi

  echo
  ui_info "Focus (Top 7 pending Door tasks)"
  if have_task; then
    "$TASK_BIN" "(door_name.not: or +door)" "(status:pending or status:waiting)" limit:7 2>/dev/null || true
  else
    printf "  Taskwarrior not found\n"
  fi

  echo
  ui_info "Door Chapters (Blueprint Reader)"
  printf "  Press [c] to open chapter list / reader (Door chapters 25-31)\n"
  printf "  Tip: [C] opens the ALPHA_OS Door chapter variant when available\n"

  echo
  ui_info "Hotkeys"
  printf "  [m] menu  [h] hot UI  [a] add hot  [o] open hot  [w] plan  [l] list doors\n"
  printf "  [v] review [f] focus  [c] chapters [C] alphaos chapter  [r]/[Enter] refresh  [q] quit\n"
}

# Door blueprint chapter paths mirror the HQ API's Door chapter feed, but are local
# CLI helpers so the dashboard can offer an offline reader without requiring index-node.
door_chapter_paths() {
  local source="${1:-blueprints}"
  local base="$VAULT_DIR"

  case "$source" in
    alphaos)
      printf "%s\n" "$base/ALPHA_OS/ALPHA_OS - THE DOOR.md"
      ;;
    blueprints|*)
      printf "%s\n" \
        "$base/AlphaOS-blueprints/25 - Door.md" \
        "$base/AlphaOS-blueprints/26 - Possibilities.md" \
        "$base/AlphaOS-blueprints/27 - Door War.md" \
        "$base/AlphaOS-blueprints/28 - War Stack.md" \
        "$base/AlphaOS-blueprints/29 - Production.md" \
        "$base/AlphaOS-blueprints/30 - Profit.md" \
        "$base/AlphaOS-blueprints/31 - Door Summary.md"
      ;;
  esac
}

# Compact chapter list for the dashboard. Each line is "index<TAB>path<TAB>title".
door_chapter_catalog() {
  local source="${1:-blueprints}"
  local i=0
  while IFS= read -r p; do
    [[ -z "$p" ]] && continue
    [[ -f "$p" ]] || continue
    i=$((i + 1))
    printf "%s\t%s\t%s\n" "$i" "$p" "$(basename "$p" .md)"
  done < <(door_chapter_paths "$source")
}

# Resolve one chapter row by numeric index from `door_chapter_catalog`.
# Prints the same TSV shape as the catalog (`index<TAB>path<TAB>title`).
#
# We intentionally do not early-break the loop because `doorctl` runs with
# `set -o pipefail`, and an early consumer exit can trigger noisy SIGPIPE
# warnings in the producer on some shells/process-substitution paths.
door_chapter_row_by_index() {
  local source="${1:?}"
  local wanted="${2:?}"
  local row=""

  while IFS=$'\t' read -r idx path title; do
    if [[ "$idx" == "$wanted" ]]; then
      row="$(printf "%s\t%s\t%s" "$idx" "$path" "$title")"
    fi
  done < <(door_chapter_catalog "$source")

  [[ -n "$row" ]] || return 1
  printf "%s\n" "$row"
}

# Minimal markdown/text reader used by the dashboard. Preference order:
# glow -> bat -> less -> cat. It returns to the dashboard after the pager exits.
door_read_file() {
  local path="${1:?}"
  [[ -f "$path" ]] || { ui_err "File not found: $path"; return 1; }

  if command -v glow >/dev/null 2>&1; then
    glow -p "$path"
  elif command -v bat >/dev/null 2>&1; then
    bat --style=plain "$path"
  elif command -v less >/dev/null 2>&1; then
    less -R "$path"
  else
    cat "$path"
  fi
}

# Interactive chapter reader entrypoint for the dashboard. It is intentionally
# simple: choose by number, render, return to list, then back to dashboard.
cmd_dashboard_chapters() {
  local source="${1:-blueprints}"
  if ! ctl_can_prompt; then
    ui_info "Door chapters (non-interactive)"
    door_chapter_catalog "$source" | while IFS=$'\t' read -r idx path title; do
      printf "  [%s] %s (%s)\n" "$idx" "$title" "$path"
    done
    return 0
  fi

  while true; do
    printf '\033c'
    ui_title "Door Chapters Reader"
    printf "Source: %s\n\n" "$source"

    local any=0
    door_chapter_catalog "$source" | while IFS=$'\t' read -r idx path title; do
      any=1
      printf "  [%s] %s\n" "$idx" "$title"
      printf "      %s\n" "$path"
    done

    # The while above runs in a subshell in bash when piped. Recompute cheaply for
    # existence checks so the UI stays correct.
    local count=0
    count="$(door_chapter_catalog "$source" | wc -l | tr -d ' ')"
    if [[ "$count" == "0" ]]; then
      ui_warn "No Door chapters found in $VAULT_DIR (expected blueprints 25-31 / ALPHA_OS door file)"
      printf "\nPress Enter to return..."
      read -r _ || true
      return 0
    fi

    printf "\nChoose chapter number, [s] switch source, [q] back: "
    local pick=""
    read -r pick || return 0

    case "$pick" in
      q|Q|"")
        return 0
        ;;
      s|S)
        if [[ "$source" == "blueprints" ]]; then
          source="alphaos"
        else
          source="blueprints"
        fi
        continue
        ;;
    esac

    if [[ ! "$pick" =~ ^[0-9]+$ ]]; then
      ui_pause
      continue
    fi

    # Avoid `awk ... exit` on a pipeline here because with `pipefail` enabled it
    # can surface SIGPIPE warnings from the producer (`door_chapter_catalog`).
    local selected_path=""
    while IFS=$'\t' read -r idx path _title; do
      if [[ "$idx" == "$pick" ]]; then
        selected_path="$path"
      fi
    done < <(door_chapter_catalog "$source")
    if [[ -z "$selected_path" ]]; then
      ui_warn "No chapter with number: $pick"
      ui_pause
      continue
    fi

    printf '\033c'
    ui_title "Reader: $(basename "$selected_path" .md)"
    printf "Path: %s\n\n" "$selected_path"
    door_read_file "$selected_path" || true
    echo
    printf "Press Enter to return to chapter list..."
    read -r _ || true
  done
}

# Public CLI command wrapper for the dashboard chapter reader/list.
# Keeps the reader reusable outside the dashboard hotkey loop (`doorctl chapters`,
# `door c`) and provides a simple JSON listing mode for scripting.
cmd_chapters() {
  # Supported forms:
  #   doorctl chapters
  #   doorctl chapters alphaos
  #   doorctl chapters 3
  #   doorctl chapters 3 alphaos
  #   doorctl chapters open 3 [blueprints|alphaos]
  # `door c 3` maps into this and opens the chapter immediately.
  local mode="${1:-}"
  local source="blueprints"
  local chapter_idx=""

  case "$mode" in
    "" )
      ;;
    help|-h|--help)
      cat <<'EOF'
doorctl chapters

Usage:
  doorctl chapters                      # list / interactive reader (blueprints)
  doorctl chapters blueprints           # list / interactive reader (blueprints)
  doorctl chapters alphaos              # list / interactive reader (ALPHA_OS source)
  doorctl chapters <index>              # open chapter by number (blueprints)
  doorctl chapters <index> <source>     # open chapter by number
  doorctl chapters open <index> [source]

Examples:
  doorctl chapters
  doorctl chapters 3
  doorctl chapters open 1 alphaos
  doorctl --json chapters
EOF
      return 0
      ;;
    open|show|read)
      chapter_idx="${2:-}"
      source="${3:-blueprints}"
      ;;
    alpha)
      source="alphaos"
      ;;
    alphaos|blueprints)
      source="$mode"
      ;;
    *)
      if [[ "$mode" =~ ^[0-9]+$ ]]; then
        chapter_idx="$mode"
        source="${2:-blueprints}"
      else
        ui_err "Unknown chapters mode/source: $mode"
        ui_info "Use: doorctl chapters [blueprints|alphaos|<index>|open <index> [source]]"
        return 2
      fi
      ;;
  esac

  case "$source" in
    blueprints|alphaos) ;;
    alpha) source="alphaos" ;;
    *)
      ui_err "Unknown chapter source: $source (use blueprints|alphaos)"
      return 2
      ;;
  esac

  if json_mode; then
    require_jq || return 1

    if [[ -n "$chapter_idx" ]]; then
      local row idx path title
      if ! row="$(door_chapter_row_by_index "$source" "$chapter_idx")"; then
        ui_err "No chapter with number: $chapter_idx (source: $source)"
        return 1
      fi
      IFS=$'\t' read -r idx path title <<< "$row"
      jq -n \
        --arg source "$source" \
        --argjson index "$idx" \
        --arg path "$path" \
        --arg title "$title" \
        '{source:$source, chapter:{index:$index, path:$path, title:$title}}'
    else
      door_chapter_catalog "$source" | jq -R -s --arg source "$source" '
        split("\n")
        | map(select(length > 0))
        | map(split("\t"))
        | {
            source: $source,
            chapters: map({
              index: (.[0] | tonumber),
              path: .[1],
              title: .[2]
            })
          }
      '
    fi
    return 0
  fi

  if [[ -n "$chapter_idx" ]]; then
    local row idx path title
    if ! row="$(door_chapter_row_by_index "$source" "$chapter_idx")"; then
      ui_err "No chapter with number: $chapter_idx (source: $source)"
      return 1
    fi
    IFS=$'\t' read -r idx path title <<< "$row"
    if ctl_can_prompt; then
      printf '\033c'
    fi
    ui_title "Reader: $title"
    printf "Source: %s\n" "$source"
    printf "Path: %s\n\n" "$path"
    door_read_file "$path"
    return $?
  fi

  cmd_dashboard_chapters "$source"
}

# Dashboard command:
# - JSON mode returns a structured snapshot
# - non-TTY prints a one-shot snapshot
# - TTY runs a fullscreen loop with single-key navigation
cmd_dashboard() {
  if json_mode; then
    require_jq || return 1
    local doors_json='[]'
    local health_json='{"summary":{"healthy":0,"attention":0,"stalled":0,"total":0},"doors":[]}'
    local hot_json='[]'
    local focus_json='[]'

    hot_json="$(hotlist_enumerated_json active 2>/dev/null || echo '[]')"
    if have_task; then
      doors_json="$(get_doors 2>/dev/null || echo '[]')"
      health_json="$(build_health_json "$doors_json" 2>/dev/null || echo "$health_json")"
      focus_json="$("$TASK_BIN" "(door_name.not: or +door)" "(status:pending or status:waiting)" limit:7 export 2>/dev/null || echo '[]')"
    fi

    jq -n \
      --arg version "$DOORCTL_VERSION" \
      --arg potential "$(phase_count potential)" \
      --arg plan "$(phase_count plan)" \
      --arg production "$(phase_count production)" \
      --arg profit "$(phase_count profit)" \
      --argjson health "$health_json" \
      --argjson hotlist "$hot_json" \
      --argjson focus "$focus_json" \
      '{
        version: $version,
        counts: {
          potential: $potential,
          plan: $plan,
          production: $production,
          profit: $profit
        },
        health: $health,
        hotlist: $hotlist,
        focus: $focus
      }'
    return 0
  fi

  if ! ctl_can_prompt; then
    dashboard_render_snapshot
    return 0
  fi

  while true; do
    # Fullscreen feel: clear on every frame so the dashboard "owns" the terminal.
    printf '\033c'
    dashboard_render_snapshot

    local key=""
    IFS= read -r -s -n 1 key || return 0

    case "$key" in
      ""|$'\n'|$'\r'|r|R)
        continue
        ;;
      q|Q)
        return 0
        ;;
      m|M)
        cmd_menu || true
        ;;
      h|H)
        cmd_hot_ui || true
        ;;
      a|A)
        local idea=""
        printf "\nIdea: "
        read -r idea || return 0
        [[ -n "${idea// }" ]] && cmd_hotlist add "$idea" || true
        ui_pause
        ;;
      o|O)
        local ref=""
        printf "\nHot task number: "
        read -r ref || return 0
        [[ -n "${ref// }" ]] && cmd_hotlist open "$ref" || true
        ui_pause
        ;;
      w|W)
        cmd_plan list || true
        ui_pause
        ;;
      l|L)
        cmd_list || true
        ui_pause
        ;;
      v|V)
        cmd_review || true
        ui_pause
        ;;
      f|F)
        cmd_focus || true
        ui_pause
        ;;
      c)
        cmd_dashboard_chapters blueprints || true
        ;;
      C)
        cmd_dashboard_chapters alphaos || true
        ;;
      *)
        # Unknown keys are ignored to keep navigation "zero-friction".
        :
        ;;
    esac
  done
}

