show_help() {
  if json_mode; then
    require_jq || return 1
    local commands_json
    commands_json="$(
      print_command_catalog \
        | jq -R 'select(length > 0) | split("\t") | {name: .[0], usage: .[1], summary: .[2]}' \
        | jq -s '.'
    )"
    jq -n \
      --arg version "$DOORCTL_VERSION" \
      --arg usage 'doorctl [--json] <command> [args...]' \
      --argjson commands "$commands_json" \
      '{
        name: "doorctl",
        version: $version,
        usage: $usage,
        global_flags: [{flag:"--json", summary:"Emit JSON for supported commands"}],
        commands: $commands
      }'
    return 0
  fi

  cat <<'EOF'
doorctl v2.2.1 - Door Task Management System

Usage:
  doorctl [--json] <command> [args...]

Commands:
  potential               Phase 1 frontdoor (Hot List / Possibilities)
  plan                    Phase 2 frontdoor (Door War / prioritization)
  production              Phase 3 frontdoor (War Stack / execution)
  profit                  Phase 4 frontdoor (Review / achieved & done)
                          Use: <phase> report [status] for Taskwarrior phase report
  dashboard               Compact door dashboard (hotlist + focus + health)
  list                    List all active doors with status
  show <door>             Show detail view for specific door
  hot [subcmd]            Phase 1 alias: Hot List frontdoor (TTY UI by default)
  hotlist [subcmd]        Phase 1 alias: Potential/Hot List flow (list/open/add)
  chapters [source]       Door chapter reader/list (blueprints|alphaos)
  doorwar [subcmd]        Compatibility alias for Door War selection from HotList
  warstack <door> [...]   War Stack view/edit (or production view if no door)
  review                  Compact phase review + health + focus
  doctor                  Check dependencies + vault/task readiness
  commands                List command catalog (supports --json)
  menu                    Interactive terminal menu
  scope [door] [mode]     Door-name scoped task view (mode: all|today|focus|week|done|h|m|l)
  hits [door] [status]    List hits for door (default: pending)
  next [door]             Show next hit to work on
  done <uuid>             Mark hit as completed
  edit <uuid>             Edit hit in editor (nano/micro/$EDITOR)
  open <uuid>             Open task with taskopen
  hitlist                 Show all pending hits across all doors
  focus                   Show today's focus (top 7 door tasks)
  health                  Check door health (stalled, needs attention)
  stalled                 List stalled doors only
  war <door> [show|edit]  View/edit war stack (with glow/bat/cat)
  note <door>             Edit door notes
  current [door|clear]    Get/set active Door (writes ~/.aos/door.current)
  ctx [open|start|stop|restart|status|logs|menu]

  version                 Show version
  help                    Show this help

Examples:
  doorctl list
  doorctl --json list
  doorctl dashboard
  doorctl chapters
  doorctl chapters alphaos
  doorctl hot
  doorctl hot "Idea ..."
  doorctl hotlist json active
  doorctl plan activate 1
  doorctl --json plan activate 1
  doorctl potential
  doorctl potential report
  doorctl plan activate 1
  doorctl production focus
  doorctl profit review
  doorctl scope Vitaltrainer today
  doorctl scope --current focus
  doorctl scope Vitaltrainer h
  doorctl --json review
  doorctl doctor
  doorctl hotlist
  doorctl hotlist add "Idea ..."
  doorctl plan
  doorctl production
  doorctl review
  doorctl menu
  doorctl show Ausbildung
  doorctl hits Ausbildung
  doorctl next
  doorctl done 123abc
  doorctl edit 123abc
  doorctl open 123abc
  doorctl war Ausbildung
  doorctl war Ausbildung edit
  doorctl note Ausbildung
  doorctl health
  doorctl current Ausbildung
  doorctl ctx open

Config (env vars):
  AOS_VAULT_DIR           Vault location (default: ~/AlphaOS-Vault)
  AOS_DOOR_STALLED_DAYS   Days before door is stalled (default: 7)
  AOS_DOOR_ATTENTION_DAYS Days before door needs attention (default: 3)
  AOS_DOOR_CURRENT_FILE   Active Door file (default: ~/.aos/door.current)
  TASK_BIN                Taskwarrior binary (default: task)
  EDITOR                  Preferred editor (default: nano)

Optional tools:
  micro                   Modern terminal editor (preferred)
  nano                    Simple editor (fallback)
  taskopen                Open tasks with external tools
  glow                    Beautiful markdown rendering
  bat                     Pretty file viewer

Notes:
  - Requires Taskwarrior with door_name UDA
  - Door War lives on HotList tasks via built-in priority (`prio:H/M/L`)
  - War Stack and Profit notes open through taskopen
  - door_name UDA is primary; +door/+hit/+strike/+profit remain supported
  - Uses task export for data
  - Logic in: door/lib/*.sh (reusable by Index Node)
  - JSON mode works for: list/show/review/doctor/commands/scope/hits/next/hitlist/focus/health/stalled
EOF
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        DOORCTL_OUTPUT_FORMAT="json"
        shift
        ;;
      --)
        shift
        break
        ;;
      --help)
        show_help
        return 0
        ;;
      --version)
        if json_mode; then
          require_jq || return 1
          jq -n --arg version "$DOORCTL_VERSION" '{name:"doorctl", version:$version}'
        else
          echo "doorctl v$DOORCTL_VERSION"
        fi
        return 0
        ;;
      -*)
        ui_err "Unknown global option: $1"
        show_help
        return 2
        ;;
      *)
        break
        ;;
    esac
  done

  # Default entrypoint behavior:
  # - JSON mode: help (safe / machine-friendly)
  # - Interactive TTY: dashboard (fast situational overview)
  # - Non-interactive text: help
  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then
    if json_mode; then
      cmd="help"
    elif ctl_can_prompt; then
      cmd="dashboard"
    else
      cmd="help"
    fi
  else
    shift || true
  fi

  case "$cmd" in
    dashboard|dash) cmd_dashboard ;;
    menu) cmd_menu ;;
    list|ls) cmd_list ;;
    show) cmd_show "$@" ;;
    hot) cmd_hot "$@" ;;
    hotlist) cmd_hotlist "$@" ;;
    chapters|chapter) cmd_chapters "$@" ;;
    doorwar) cmd_doorwar "$@" ;;
    warstack) cmd_warstack "$@" ;;
    current) cmd_current "$@" ;;
    review) cmd_review ;;
    doctor) cmd_doctor ;;
    commands|cmds) cmd_commands ;;
    potential) cmd_potential "$@" ;;
    plan) cmd_plan "$@" ;;
    production) cmd_production "$@" ;;
    profit) cmd_profit "$@" ;;
    scope) cmd_scope "$@" ;;
    hits) cmd_hits "$@" ;;
    next) cmd_next "$@" ;;
    done) cmd_done "$@" ;;
    edit) cmd_edit "$@" ;;
    open) cmd_open "$@" ;;
    hitlist|all) cmd_hitlist ;;
    focus|today) cmd_focus ;;
    health) cmd_health ;;
    stalled) cmd_stalled ;;
    war) cmd_war "$@" ;;
    note|notes) cmd_note "$@" ;;
    ctx) cmd_ctx "${1:-}" ;;
    version)
      if json_mode; then
        require_jq || return 1
        jq -n --arg version "$DOORCTL_VERSION" '{name:"doorctl", version:$version}'
      else
        echo "doorctl v$DOORCTL_VERSION"
      fi
      ;;
    help|-h|--help) show_help ;;
    *)
      ui_err "Unknown command: $cmd"
      show_help
      exit 2
      ;;
  esac
}

main "$@"
