cmd_doctor() {
  local task_ok=false
  local jq_ok=false
  local python_ok=false
  local hot_py_ok=false
  local vault_ok=false
  local door_dir_ok=false
  local war_dir_ok=false
  local notes_dir_ok=false
  local task_export_ok=false
  local doors_detected="?"

  have_task && task_ok=true
  have_jq && jq_ok=true
  command -v python3 >/dev/null 2>&1 && python_ok=true
  [[ -f "$HOT_PY" ]] && hot_py_ok=true
  [[ -d "$VAULT_DIR" ]] && vault_ok=true
  [[ -d "$VAULT_DIR/Door" ]] && door_dir_ok=true
  [[ -d "$VAULT_DIR/Door/War-Stacks" ]] && war_dir_ok=true
  [[ -d "$VAULT_DIR/Door/notes" ]] && notes_dir_ok=true

  if [[ "$task_ok" == true ]]; then
    if "$TASK_BIN" export >/dev/null 2>&1; then
      task_export_ok=true
    fi
  fi

  if [[ "$task_ok" == true && "$jq_ok" == true ]]; then
    doors_detected="$(get_door_count 2>/dev/null || echo '?')"
  fi

  local ready=false
  if [[ "$task_ok" == true && "$jq_ok" == true && "$task_export_ok" == true && "$vault_ok" == true ]]; then
    ready=true
  fi

  if json_mode; then
    require_jq || return 1
    jq -n \
      --arg version "$DOORCTL_VERSION" \
      --arg task_bin "$TASK_BIN" \
      --arg vault_dir "$VAULT_DIR" \
      --arg hot_py "$HOT_PY" \
      --arg doors_detected "$doors_detected" \
      --argjson ready "$ready" \
      --argjson task_ok "$task_ok" \
      --argjson jq_ok "$jq_ok" \
      --argjson python_ok "$python_ok" \
      --argjson hot_py_ok "$hot_py_ok" \
      --argjson vault_ok "$vault_ok" \
      --argjson door_dir_ok "$door_dir_ok" \
      --argjson war_dir_ok "$war_dir_ok" \
      --argjson notes_dir_ok "$notes_dir_ok" \
      --argjson task_export_ok "$task_export_ok" \
      '{
        version: $version,
        ready: $ready,
        task_bin: $task_bin,
        vault_dir: $vault_dir,
        hot_py: $hot_py,
        doors_detected: $doors_detected,
        checks: {
          task_bin: $task_ok,
          jq: $jq_ok,
          python3: $python_ok,
          hot_py: $hot_py_ok,
          vault_dir: $vault_ok,
          door_dir: $door_dir_ok,
          war_stacks_dir: $war_dir_ok,
          notes_dir: $notes_dir_ok,
          task_export: $task_export_ok
        }
      }'
    return 0
  fi

  ui_title "doorctl Doctor"
  [[ "$task_ok" == true ]] && ui_ok "Taskwarrior: $TASK_BIN" || ui_err "Taskwarrior missing: $TASK_BIN"
  [[ "$jq_ok" == true ]] && ui_ok "jq: installed" || ui_err "jq: missing (required for door dashboards/json)"
  [[ "$python_ok" == true ]] && ui_ok "python3: installed" || ui_warn "python3: missing (hotlist helper unavailable)"
  [[ "$hot_py_ok" == true ]] && ui_ok "Hot helper: $HOT_PY" || ui_warn "Hot helper missing: $HOT_PY"
  [[ "$vault_ok" == true ]] && ui_ok "Vault: $VAULT_DIR" || ui_err "Vault missing: $VAULT_DIR"
  [[ "$door_dir_ok" == true ]] && ui_ok "Door dir: $VAULT_DIR/Door" || ui_warn "Door dir missing: $VAULT_DIR/Door"
  [[ "$war_dir_ok" == true ]] && ui_ok "War Stacks dir: $VAULT_DIR/Door/War-Stacks" || ui_warn "War Stacks dir missing: $VAULT_DIR/Door/War-Stacks"
  [[ "$notes_dir_ok" == true ]] && ui_ok "Notes dir: $VAULT_DIR/Door/notes" || ui_warn "Notes dir missing: $VAULT_DIR/Door/notes"
  [[ "$task_export_ok" == true ]] && ui_ok "Task export: ok" || ui_err "Task export: failed"
  printf "Doors detected: %s\n" "$doors_detected"
  if [[ "$ready" == true ]]; then
    ui_ok "doorctl is ready"
  else
    ui_warn "doorctl is not fully ready (see checks above)"
  fi
}

