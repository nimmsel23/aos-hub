cmd_hotlist_json() {
  local mode="${1:-active}"
  require_jq || return 1
  local items_json
  items_json="$(hotlist_enumerated_json "$mode")"

  if json_mode; then
    printf "%s\n" "$items_json"
    return 0
  fi

  ui_title "Hot List JSON ($mode)"
  if [[ "$(printf "%s" "$items_json" | jq 'length')" == "0" ]]; then
    ui_info "No hotlist entries in mode: $mode"
    return 0
  fi

  printf "%s\n" "$items_json" | jq -r '
    .[] | [
      (.hot_index|tostring),
      (.status // "active"),
      (.phase // "potential"),
      (.door_name // "-"),
      (.idea // .title // "-")
    ] | @tsv
  ' | while IFS=$'\t' read -r idx status phase door idea; do
    printf "  [%s] %-10s %-10s %-18s %s\n" "$idx" "$status" "$phase" "$door" "$idea"
  done
}

cmd_doorwar_activate() {
  local selector="${1:-}"
  shift || true
  local requested_door_name=""
  local force=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force="--force" ;;
      *)
        if [[ -z "$requested_door_name" ]]; then
          requested_door_name="$1"
        else
          ui_err "Unexpected argument: $1"
          return 2
        fi
        ;;
    esac
    shift || true
  done

  [[ -n "$selector" ]] || {
    ui_err "Usage: doorctl doorwar activate <hot-index|tw_uuid|idea|file> [door-name]"
    return 1
  }

  require_jq || return 1
  local entry
  entry="$(hotlist_select_entry_json "$selector")"
  if [[ -z "$entry" ]]; then
    ui_err "Hot List entry not found for selector: $selector"
    return 1
  fi

  local current_status
  current_status="$(printf "%s" "$entry" | jq -r '.status // "active"')"
  if [[ "$current_status" == "promoted" && "$force" != "--force" ]]; then
    ui_warn "Hot List entry already promoted. Use --force to regenerate the War Stack."
  fi

  local idea tw_uuid hot_file hot_index0 hot_index selected_at hot_item_id
  idea="$(printf "%s" "$entry" | jq -r '.idea // .title // ""')"
  tw_uuid="$(printf "%s" "$entry" | jq -r '.tw_uuid // .task_uuid // ""')"
  hot_file="$(printf "%s" "$entry" | jq -r '.file // .md_name // .md_url // ""')"
  hot_index0="$(printf "%s" "$entry" | jq -r '._hot_index0')"
  hot_index="$(printf "%s" "$entry" | jq -r '.hot_index')"
  hot_item_id="$(printf "%s" "$entry" | jq -r '.id // ""')"
  selected_at="$(iso_now)"

  local door_name
  if [[ -n "$requested_door_name" ]]; then
    door_name="$requested_door_name"
  else
    door_name="$(printf "%s" "$entry" | jq -r '.door_name // ""')"
    [[ -n "$door_name" && "$door_name" != "null" ]] || door_name="$(slugify_door_name "$idea")"
  fi

  local warstack_file
  warstack_file="$(warstack_path "$door_name")"
  mkdir -p "$(dirname "$warstack_file")"

  if [[ -f "$warstack_file" && "$force" != "--force" ]]; then
    ui_err "War Stack already exists: $warstack_file"
    ui_info "Use: doorctl doorwar activate $selector \"$door_name\" --force"
    return 1
  fi

  render_warstack_from_hotlist_template \
    "$door_name" "$idea" "$hot_index" "$tw_uuid" "$hot_file" "$selected_at" "$hot_item_id" > "$warstack_file"

  sync_hot_task_selection "$tw_uuid" "$door_name"
  door_current_set "$door_name"

  local updated_index
  updated_index="$(
    hotlist_load_index | jq -c \
      --argjson idx "$hot_index0" \
      --arg status "promoted" \
      --arg phase "production" \
      --arg door_name "$door_name" \
      --arg warstack_file "$warstack_file" \
      --arg promoted_at "$selected_at" '
      .items[$idx].status = $status
      | .items[$idx].phase = $phase
      | .items[$idx].door_name = $door_name
      | .items[$idx].warstack_file = $warstack_file
      | .items[$idx].promoted_at = $promoted_at
    '
  )"
  hotlist_save_index "$updated_index"

  if json_mode; then
    jq -n \
      --arg selector "$selector" \
      --arg door_name "$door_name" \
      --arg warstack_file "$warstack_file" \
      --arg hot_index "$hot_index" \
      --arg promoted_at "$selected_at" \
      '{ok:true, action:"doorwar.activate", selector:$selector, door_name:$door_name, warstack_file:$warstack_file, hot_index:($hot_index|tonumber), promoted_at:$promoted_at}'
    return 0
  fi

  ui_ok "Activated Door from Hot List"
  printf "Door: %s\n" "$door_name"
  printf "Source Hot List entry: #%s\n" "$hot_index"
  printf "War Stack: %s\n" "$warstack_file"
  ui_info "Next: doorctl war \"$door_name\" edit"
}

cmd_hotlist() {
  local sub="${1:-list}"
  shift || true

  case "$sub" in
    json)
      cmd_hotlist_json "${1:-active}"
      ;;
    list|show)
      if json_mode; then
        cmd_hotlist_json active
      elif [[ -f "$HOT_PY" ]] && command -v python3 >/dev/null 2>&1; then
        python3 "$HOT_PY" list
      else
        cmd_phase_report potential pending
      fi
      ;;
    open)
      if [[ -f "$HOT_PY" ]] && command -v python3 >/dev/null 2>&1; then
        python3 "$HOT_PY" open "$@"
      else
        ui_err "hot open requires $HOT_PY"
        return 1
      fi
      ;;
    add)
      [[ $# -gt 0 ]] || { ui_err "Usage: doorctl hotlist add <idea...>"; return 1; }
      if [[ -f "$HOT_PY" ]] && command -v python3 >/dev/null 2>&1; then
        python3 "$HOT_PY" "$@"
      else
        ui_err "hot add requires $HOT_PY"
        return 1
      fi
      ;;
    help|-h|--help)
      cat <<'EOF'
doorctl hotlist

Usage:
  doorctl hotlist [list]
  doorctl hotlist json [active|all|promoted]
  doorctl hotlist open <task-number>
  doorctl hotlist add <idea...>
EOF
      ;;
    *)
      ui_err "Unknown hotlist command: $sub"
      return 2
      ;;
  esac
}

cmd_hot_ui() {
  if ! ctl_can_prompt; then
    cmd_hotlist list
    return $?
  fi

  while true; do
    printf '\033c'
    ui_title "Door Hot List"
    cmd_hotlist list || true
    printf "\n[A]dd idea  [O]pen entry  [R]efresh  [Q]uit\n"

    local choice=""
    read -r -p "> " choice || return 0
    choice="${choice,,}"

    case "$choice" in
      ""|r|refresh) ;;
      q|quit|exit) return 0 ;;
      a|add)
        local idea=""
        read -r -p "Idea: " idea || return 0
        if [[ -z "${idea// }" ]]; then
          read -r -p "No idea entered. Press Enter..." _ || true
          continue
        fi
        cmd_hotlist add "$idea" || true
        read -r -p "Press Enter..." _ || true
        ;;
      o|open)
        local ref=""
        read -r -p "Task number: " ref || return 0
        if [[ -z "${ref// }" ]]; then
          read -r -p "No task number entered. Press Enter..." _ || true
          continue
        fi
        cmd_hotlist open "$ref" || true
        read -r -p "Press Enter..." _ || true
        ;;
      *)
        read -r -p "Unknown command. Press Enter..." _ || true
        ;;
    esac
  done
}

cmd_hot() {
  local sub="${1:-}"
  if [[ $# -eq 0 ]]; then
    cmd_hot_ui
    return $?
