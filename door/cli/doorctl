cmd_show() {
  local door_name="$1"
  [[ -z "$door_name" ]] && { ui_err "Usage: doorctl show <door-name>"; exit 1; }

  require_task || return 1
  require_jq || return 1

  local tasks
  tasks="$(get_door_tasks "$door_name" 2>/dev/null || echo '[]')"

  if [[ "$tasks" == "[]" || -z "$tasks" ]]; then
    ui_err "Door not found: $door_name"
    return 1
  fi

  # Door metadata
  local meta
  meta=$(get_door_metadata "$door_name")

  local count
  count=$(echo "$meta" | jq -r '.count')
  local done
  done=$(echo "$meta" | jq -r '.done')
  local pending
  pending=$(echo "$meta" | jq -r '.pending')
  local project
  project=$(echo "$meta" | jq -r '.project // "N/A"')
  local tags
  tags=$(echo "$meta" | jq -r '.tags | join(", ")')
  local phase
  phase=$(get_door_phase "$(echo "$meta" | jq -r '.tags')")

  if json_mode; then
    jq -n \
      --arg door "$door_name" \
      --arg phase "$phase" \
      --arg warstack "$(warstack_path "$door_name")" \
      --arg note "$(note_path "$door_name")" \
      --argjson meta "$meta" \
      --argjson tasks "$tasks" \
      '{
        door: $door,
        phase: $phase,
        meta: $meta,
        tasks: $tasks,
        paths: { warstack: $warstack, note: $note }
      }'
    return 0
  fi

  ui_title "Door: $door_name"

  echo "Phase: $(format_phase "$phase")"
  echo "Project: $project"
  echo "Tags: $tags"
  echo "Hits: $count total, $done done, $pending pending"
  echo

  # Progress bar
  if ((count > 0)); then
    local pct=$((done * 100 / count))
    printf "Progress: ["
    draw_progress_bar "$done" "$count" 20
    printf "] %d%%\n\n" "$pct"
  fi

  # Task lists
  ui_info "Pending Hits:"
  echo "$tasks" | jq -r '.[] | select(.status == "pending") | @json' | while IFS= read -r task; do
    format_task_item "$task" "🔲"
  done

  echo
  ui_info "Completed Hits:"
  echo "$tasks" | jq -r '.[] | select(.status == "completed") | @json' | while IFS= read -r task; do
    format_task_item "$task" "✅"
  done
}

cmd_scope() {
  local door_name=""
  local mode="all"
  local mode_lc=""
  local arg1="${1:-}"

  case "$arg1" in
    --current|-c)
      door_name="$(door_current_get || true)"
      shift || true
      ;;
    all|today|focus|week|done|h|m|l|high|medium|low|"")
      ;;
    *)
      door_name="$arg1"
      shift || true
      ;;
  esac

  if [[ -z "$door_name" ]]; then
    door_name="$(door_current_get || true)"
  fi
  [[ -n "$door_name" ]] || { ui_err "Usage: doorctl scope [door-name|--current] [all|today|focus|week|done|h|m|l]"; return 1; }

  mode="${1:-all}"
  mode_lc="$(printf "%s" "$mode" | tr '[:upper:]' '[:lower:]')"
  require_task || return 1

  local -a query
  local priority_filter=""
  case "$mode_lc" in
    all)
      query=("door_name:$door_name" "(status:pending or status:waiting)")
      ;;
    today)
      query=("door_name:$door_name" "(status:pending or status:waiting)" "(due.before:tomorrow or scheduled.before:tomorrow)")
      ;;
    week)
      query=("door_name:$door_name" "(status:pending or status:waiting)" "((due.after:sow and due.before:eow+1day) or (scheduled.after:sow and scheduled.before:eow+1day))")
      ;;
    focus)
      query=("door_name:$door_name" "(status:pending or status:waiting)")
      ;;
    done|review)
      query=("door_name:$door_name" "status:completed" "end.after:today-7days")
      ;;
    h|high|m|medium|l|low)
      priority_filter="$(scope_priority_filter_for_mode "$mode_lc")"
      [[ -n "$priority_filter" ]] || { ui_err "Unknown priority scope: $mode"; return 2; }
      query=("door_name:$door_name" "(status:pending or status:waiting)" "$priority_filter")
      ;;
    *)
      ui_err "Unknown scope mode: $mode (use all|today|focus|week|done|h|m|l)"
      return 2
      ;;
  esac

  if json_mode; then
    require_jq || return 1
    local out
    out="$("$TASK_BIN" "${query[@]}" export 2>/dev/null || echo '[]')"
    if [[ "$mode_lc" == "focus" ]]; then
      printf "%s\n" "$out" | jq 'sort_by((.urgency // 0)) | reverse | .[:7]'
      return 0
    fi
    printf "%s\n" "$out"
    return 0
  fi

  ui_title "Door Scope: $door_name ($mode)"
  if [[ "$mode_lc" == "focus" ]]; then
    "$TASK_BIN" "${query[@]}" limit:7 2>/dev/null || true
    return 0
  fi
  "$TASK_BIN" "${query[@]}"
}

