#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
WORK_DIR="$ROOT_DIR/work"
mkdir -p "$WORK_DIR"

week_key() { date +%G-W%V; }
hot_file() { printf '%s\n' "$WORK_DIR/hot-list.md"; }
war_dir() { printf '%s\n' "$WORK_DIR/door-war"; }
# Weekly Door War file stores the chosen Quadrant-2 Door.
war_file() { printf '%s\n' "$(war_dir)/$(week_key).md"; }

slugify() {
  printf '%s' "$*" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

door_dir() {
  local slug="$1"
  printf '%s\n' "$WORK_DIR/$slug"
}

door_file() {
  local slug="$1"
  printf '%s\n' "$(door_dir "$slug")/door.md"
}

stack_file() {
  local door_slug="$1"
  local stack_slug="$2"
  printf '%s\n' "$(door_dir "$door_slug")/war/$stack_slug.md"
}

usage() {
  cat <<'EOF'
door/gtd - terminal DOOR script (Potential / Plan / Production / Profit)

Usage:
  door/gtd hot add <text...>
  door/gtd hot list
  door/gtd new <door-name...>              # create Door (from Hot List candidate)
  door/gtd list
  door/gtd open <door-slug>
  door/gtd war set <door-slug> [q2-note...]
  door/gtd war show [YYYY-Www]
  door/gtd stack <door-slug> <stack-name...>
  door/gtd hit <door-slug> <stack-slug> <text...>
  door/gtd hit done <door-slug> <stack-slug> <pattern>
  door/gtd profit <door-slug>
  door/gtd next
EOF
}

cmd_hot_add() {
  [[ $# -gt 0 ]] || { echo "hot text required" >&2; exit 1; }
  local file
  file="$(hot_file)"
  mkdir -p "$(dirname "$file")"
  [[ -f "$file" ]] || printf '# Hot List (Potential)\n\n' >"$file"
  printf -- '- [%s] %s\n' "$(date +"%F %H:%M")" "$*" >>"$file"
  printf '%s\n' "$file"
}

cmd_hot_list() {
  local file
  file="$(hot_file)"
  [[ -f "$file" ]] || { echo "no hot list yet"; return 0; }
  cat "$file"
}

cmd_new() {
  [[ $# -gt 0 ]] || { echo "door name required" >&2; exit 1; }
  local name="$*"
  local slug
  slug="$(slugify "$name")"
  local dir file
  dir="$(door_dir "$slug")"
  file="$(door_file "$slug")"
  mkdir -p "$dir"
  if [[ -f "$file" ]]; then
    printf '%s\n' "$file"
    return 0
  fi
  cat >"$file" <<EOF
---
type: door
name: "$name"
slug: "$slug"
status: potential
created: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
updated: $(date +%F)
---

# $name (Door)

## Potential
- [ ] Define outcome

## Plan
- [ ] Door War decision (Quadrant 2)
- [ ] Build War Stack

## Production
- [ ] 4 Hits x Mon-Fri execution

## Profit
- [ ] Achieved & Done review

## Next Actions
- [ ] 
EOF
  printf '%s\n' "$file"
}

cmd_list() {
  find "$WORK_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort
}

cmd_open() {
  [[ $# -ge 1 ]] || { echo "door slug required" >&2; exit 1; }
  local slug="$1"
  local file
  file="$(door_file "$slug")"
  [[ -f "$file" ]] || { echo "not found: $file" >&2; exit 1; }
  "${EDITOR:-nano}" "$file"
}

cmd_todo() {
  [[ $# -ge 2 ]] || { echo "usage: door/gtd todo <door-slug> <text...>" >&2; exit 1; }
  local slug="$1"; shift
  local file
  file="$(door_file "$slug")"
  [[ -f "$file" ]] || { echo "not found: $file" >&2; exit 1; }
  printf -- '- [ ] %s\n' "$*" >>"$file"
  printf '%s\n' "$file"
}

cmd_stack() {
  [[ $# -ge 2 ]] || { echo "usage: door/gtd stack <door-slug> <stack-name...>" >&2; exit 1; }
  local door_slug="$1"; shift
  local name="$*"
  local sslug
  sslug="$(slugify "$name")"
  local file
  file="$(stack_file "$door_slug" "$sslug")"
  mkdir -p "$(dirname "$file")"
  if [[ ! -f "$file" ]]; then
    cat >"$file" <<EOF
---
type: war-stack
door: "$door_slug"
name: "$name"
slug: "$sslug"
created: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
updated: $(date +%F)
---

# $name

## Door
- Domino Door: 
- Trigger: 
- Narrative: 
- Validation: 
- Impact on Opening: 
- Consequences of Inaction: 

## Hits
### Hit 1
- Fact:
- Obstacle:
- Strike:
- Responsibility:

### Hit 2
- Fact:
- Obstacle:
- Strike:
- Responsibility:

### Hit 3
- Fact:
- Obstacle:
- Strike:
- Responsibility:

### Hit 4
- Fact:
- Obstacle:
- Strike:
- Responsibility:

## Notes
- Insights:
- Lessons Learned:
EOF
  fi
  printf '%s\n' "$file"
}

cmd_hit() {
  if [[ "${1:-}" == "done" ]]; then
    shift
    [[ $# -ge 3 ]] || { echo "usage: door/gtd hit done <door-slug> <stack-slug> <pattern>" >&2; exit 1; }
    local door_slug="$1" stack_slug="$2" pat="$3"
    local file tmp
    file="$(stack_file "$door_slug" "$stack_slug")"
    [[ -f "$file" ]] || { echo "not found: $file" >&2; exit 1; }
    tmp="$(mktemp)"
    awk -v p="$pat" '
      !done && $0 ~ /^- \[ \]/ && index(tolower($0), tolower(p)) { sub(/^- \[ \]/, "- [x]"); done=1 }
      { print }
      END { if (!done) exit 2 }
    ' "$file" >"$tmp" || { rm -f "$tmp"; echo "pattern not found"; exit 1; }
    mv "$tmp" "$file"
    printf '%s\n' "$file"
    return 0
  fi
  [[ $# -ge 3 ]] || { echo "usage: door/gtd hit <door-slug> <stack-slug> <text...>" >&2; exit 1; }
  local door_slug="$1"
  local stack_slug="$2"
  shift 2
  local file
  file="$(stack_file "$door_slug" "$stack_slug")"
  [[ -f "$file" ]] || { echo "not found: $file" >&2; exit 1; }
  printf -- '- [ ] %s\n' "$*" >>"$file"
  printf '%s\n' "$file"
}

cmd_war_set() {
  [[ $# -ge 1 ]] || { echo "usage: door/gtd war set <door-slug> [q2-note...]" >&2; exit 1; }
  local door_slug="$1"; shift
  local note="${*:-Quadrant 2 choice for this week}"
  local file
  file="$(war_file)"
  mkdir -p "$(war_dir)"
  cat >"$file" <<EOF
---
type: door-war
week: $(week_key)
selected_door: $door_slug
created: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
---

# Door War $(week_key)

## Chosen Door (Quadrant 2)
- $door_slug

## Why This Door
- $note
EOF
  printf '%s\n' "$file"
}

cmd_war_show() {
  local wk="${1:-$(week_key)}"
  local file="$(war_dir)/$wk.md"
  [[ -f "$file" ]] || { echo "not found: $file" >&2; exit 1; }
  cat "$file"
}

cmd_profit() {
  [[ $# -ge 1 ]] || { echo "usage: door/gtd profit <door-slug>" >&2; exit 1; }
  local slug="$1"
  local dir
  dir="$(door_dir "$slug")"
  [[ -d "$dir" ]] || { echo "not found: $dir" >&2; exit 1; }
  local hits_done hits_open
  # Lightweight Profit review: count checked vs open items across Door + stacks.
  hits_done=$(find "$dir" -type f -name '*.md' -print0 2>/dev/null | xargs -0 awk '/^- \[x\]/ {c++} END{print c+0}' 2>/dev/null || echo 0)
  hits_open=$(find "$dir" -type f -name '*.md' -print0 2>/dev/null | xargs -0 awk '/^- \[ \]/ {c++} END{print c+0}' 2>/dev/null || echo 0)
  printf 'door=%s week=%s achieved=%s open=%s\n' "$slug" "$(week_key)" "$hits_done" "$hits_open"
  printf 'profit question: did you open the Door? did you hit the targets?\n'
}

cmd_next() {
  find "$WORK_DIR" -type f -name '*.md' 2>/dev/null | sort | while IFS= read -r f; do
    awk -v file="$f" '/^- \[ \] / { print file ": " $0 }' "$f"
  done
}

case "${1:-}" in
  hot)
    shift
    case "${1:-}" in
      add) shift; cmd_hot_add "$@" ;;
      list|"") shift || true; cmd_hot_list ;;
      *) usage; exit 1 ;;
    esac
    ;;
  new) shift; cmd_new "$@" ;;
  list) shift; cmd_list ;;
  open) shift; cmd_open "$@" ;;
  war)
    shift
    case "${1:-}" in
      set) shift; cmd_war_set "$@" ;;
      show|"") shift || true; cmd_war_show "${1:-}" ;;
      *) usage; exit 1 ;;
    esac
    ;;
  todo) shift; cmd_todo "$@" ;;
  stack) shift; cmd_stack "$@" ;;
  hit) shift; cmd_hit "$@" ;;
  profit) shift; cmd_profit "$@" ;;
  next) shift; cmd_next ;;
  help|--help|-h|"") usage ;;
  *) usage; exit 1 ;;
esac
