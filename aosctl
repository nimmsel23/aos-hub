dashboard_http_row() {
  local name="$1"
  local url="$2"
  if have curl && curl --max-time 2 -fsS "$url" >/dev/null 2>&1; then
    case "$name" in
      Index) DASH_HEALTH_INDEX=ok ;;
      Bridge) DASH_HEALTH_BRIDGE=ok ;;
    esac
    msg "  ${name}: $(aosctl_chip ok)"
  else
    case "$name" in
      Index) DASH_HEALTH_INDEX=err ;;
      Bridge) DASH_HEALTH_BRIDGE=err ;;
    esac
    msg "  ${name}: $(aosctl_chip err)"
  fi
}

dashboard_unit_row() {
  local label="$1"
  local unit="$2"
  local scope="${3:-user}"
  if ! have systemctl; then
    msg "  ${label}: systemctl missing"
    return 0
  fi
  local enabled active
  if [[ "$scope" == "system" ]]; then
    enabled="$(systemctl is-enabled "$unit" 2>/dev/null || true)"
    active="$(systemctl is-active "$unit" 2>/dev/null || true)"
  else
    enabled="$(systemctl --user is-enabled "$unit" 2>/dev/null || true)"
    active="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
  fi
  [[ -z "$enabled" ]] && enabled="-"
  [[ -z "$active" ]] && active="-"
  local state="warn"
  if [[ "$unit" == *.timer ]]; then
    if [[ "$enabled" == "not-found" ]]; then
      state="err"
    elif [[ "$active" == "active" ]]; then
      state="ok"
    elif [[ "$enabled" == "enabled" && "$active" == "inactive" ]]; then
      state="warn"
    fi
  else
    if [[ "$active" == "active" ]]; then
      state="ok"
    elif [[ "$enabled" == "not-found" || "$active" == "failed" ]]; then
      state="err"
    fi
  fi
  if [[ "$state" == "err" ]]; then
    if [[ "$label" == "Index" && "${DASH_HEALTH_INDEX:-err}" == "ok" ]]; then
      state="warn"
      msg "  ${label}: $(aosctl_chip "$state") (${scope}:${active}/${enabled}, HTTP reachable)"
      return 0
    fi
    if [[ "$label" == "Bridge" && "${DASH_HEALTH_BRIDGE:-err}" == "ok" ]]; then
      state="warn"
      msg "  ${label}: $(aosctl_chip "$state") (${scope}:${active}/${enabled}, HTTP reachable)"
      return 0
    fi
  fi
  msg "  ${label}: $(aosctl_chip "$state") (${scope}:${active}/${enabled})"
}

legacy_user_unit_notice() {
  local unit="$1"
  local label="$2"
  if ! have systemctl; then
    return 0
  fi
  if ! systemctl --user show-environment >/dev/null 2>&1; then
    return 0
  fi
  local active
  active="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
  if [[ "$active" == "active" ]]; then
    msg "  ${label}: $(aosctl_chip warn) (${unit} active in user scope)"
  fi
}

user_unit_active_state() {
  local unit="$1"
  if ! have systemctl; then
    printf "unknown\n"
    return 0
  fi
  if ! systemctl --user show-environment >/dev/null 2>&1; then
    printf "unknown\n"
    return 0
  fi
  local active
  active="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
  [[ -n "$active" ]] || active="unknown"
  printf "%s\n" "$active"
}

scope_guard_check() {
  local mode="${1:-warn}"   # warn|strict
  local issues=0
  local prod dev legacy
  local prod_active dev_active legacy_active

  msg "Scope guardrails:"

  prod="aos-index.service"; dev="aos-index-dev.service"; legacy="alphaos-index.service"
  prod_active="$(systemctl is-active "$prod" 2>/dev/null || true)"
  dev_active="$(user_unit_active_state "$dev")"
  legacy_active="$(user_unit_active_state "$legacy")"
  msg "  index  prod=${prod_active:-unknown} dev=${dev_active:-unknown} legacy=${legacy_active:-unknown}"
  if [[ "$prod_active" == "active" && "$dev_active" == "active" ]]; then
    issues=$((issues + 1))
    msg "    $(aosctl_chip err) parallel run (production + dev)"
  fi
  if [[ "$legacy_active" == "active" ]]; then
    issues=$((issues + 1))
    msg "    $(aosctl_chip warn) legacy unit active: $legacy"
  fi

  prod="aos-router.service"; dev="aos-router-dev.service"; legacy="alphaos-router.service"
  prod_active="$(systemctl is-active "$prod" 2>/dev/null || true)"
  dev_active="$(user_unit_active_state "$dev")"
  legacy_active="$(user_unit_active_state "$legacy")"
  msg "  router prod=${prod_active:-unknown} dev=${dev_active:-unknown} legacy=${legacy_active:-unknown}"
  if [[ "$prod_active" == "active" && "$dev_active" == "active" ]]; then
    issues=$((issues + 1))
    msg "    $(aosctl_chip err) parallel run (production + dev)"
  fi
  if [[ "$legacy_active" == "active" ]]; then
    issues=$((issues + 1))
    msg "    $(aosctl_chip warn) legacy unit active: $legacy"
  fi

  prod="aos-bridge.service"; dev="aos-bridge-dev.service"; legacy="aos-bridge.service"
  prod_active="$(systemctl is-active "$prod" 2>/dev/null || true)"
  dev_active="$(user_unit_active_state "$dev")"
  legacy_active="$(user_unit_active_state "$legacy")"
  msg "  bridge prod=${prod_active:-unknown} dev=${dev_active:-unknown} legacy-user=${legacy_active:-unknown}"
  if [[ "$prod_active" == "active" && "$dev_active" == "active" ]]; then
    issues=$((issues + 1))
    msg "    $(aosctl_chip err) parallel run (production + dev)"
  fi
  if [[ "$legacy_active" == "active" ]]; then
    issues=$((issues + 1))
    msg "    $(aosctl_chip warn) legacy user bridge active: $legacy"
  fi

  if [[ "$mode" == "strict" && "$issues" -gt 0 ]]; then
    return 2
  fi
  return 0
}

production_unit_summary() {
  local unit="$1"
  local enabled active state
  if ! have systemctl; then
    printf "warn|-|-"
    return 0
  fi
  enabled="$(systemctl is-enabled "$unit" 2>/dev/null || true)"
  active="$(systemctl is-active "$unit" 2>/dev/null || true)"
  [[ -z "$enabled" ]] && enabled="-"
  [[ -z "$active" ]] && active="-"
  state="warn"
  if [[ "$unit" == *.timer ]]; then
    if [[ "$enabled" == "not-found" ]]; then
      state="err"
    elif [[ "$active" == "active" ]]; then
      state="ok"
    fi
  else
    if [[ "$active" == "active" ]]; then
      state="ok"
    elif [[ "$enabled" == "not-found" || "$active" == "failed" ]]; then
      state="err"
    fi
  fi
  printf "%s|%s|%s" "$state" "$active" "$enabled"
}

render_production_units_compact() {
  local state active enabled
  msg "=== Production Units (system) ==="

  IFS='|' read -r state active enabled <<<"$(production_unit_summary "aos-index.service")"
  msg "  Index: $(aosctl_chip "$state") (aos-index.service, $active/$enabled)"

  IFS='|' read -r state active enabled <<<"$(production_unit_summary "aos-bridge.service")"
  msg "  Bridge: $(aosctl_chip "$state") (aos-bridge.service, $active/$enabled)"

  IFS='|' read -r state active enabled <<<"$(production_unit_summary "aos-router.service")"
  msg "  Router: $(aosctl_chip "$state") (aos-router.service, $active/$enabled)"

  IFS='|' read -r state active enabled <<<"$(production_unit_summary "aos-hub-backup-daily.timer")"
  msg "  Daily Timer: $(aosctl_chip "$state") (aos-hub-backup-daily.timer, $active/$enabled)"

  IFS='|' read -r state active enabled <<<"$(production_unit_summary "aos-hub-backup-weekly.timer")"
  msg "  Weekly Timer: $(aosctl_chip "$state") (aos-hub-backup-weekly.timer, $active/$enabled)"
}

