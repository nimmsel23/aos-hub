  if [[ -n "$ENVCTL" ]]; then
    msg "  envctl: $($ENVCTL version 2>/dev/null || echo 'unknown')"
  else
    msg "  envctl: not installed"
  fi

  if [[ -n "$ALIASCTL" ]]; then
    msg "  alias:  $($ALIASCTL version 2>/dev/null || echo 'unknown')"
  else
    msg "  alias:  not installed"
  fi

  if [[ -n "$CORE4CTL" ]]; then
    msg "  core4:  $CORE4CTL"
  else
    msg "  core4:  not installed"
  fi

  msg ""
}

dashboard_http_row() {
  local name="$1"
  local url="$2"
  if have curl && curl --max-time 2 -fsS "$url" >/dev/null 2>&1; then
    case "$name" in
      Index) DASH_HEALTH_INDEX=ok ;;
      Bridge) DASH_HEALTH_BRIDGE=ok ;;
    esac
    msg "  ${name}: $(aosctl_chip ok)"
  else
    case "$name" in
      Index) DASH_HEALTH_INDEX=err ;;
      Bridge) DASH_HEALTH_BRIDGE=err ;;
    esac
    msg "  ${name}: $(aosctl_chip err)"
