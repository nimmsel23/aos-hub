}

dashboard_rg_chip() {
  local state="${1:-err}" # ok|err
  if [[ "$state" == "ok" ]]; then
    aosctl_color "1;32" "●"
  else
    aosctl_color "1;31" "●"
  fi
}

unit_active_state() {
  local unit="$1"
  local scope="${2:-system}"
  if ! have systemctl; then
    printf "unknown\n"
    return 0
  fi
  if [[ "$scope" == "user" ]]; then
    if ! systemctl --user show-environment >/dev/null 2>&1; then
      printf "unknown\n"
      return 0
    fi
    local active
    active="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
    [[ -n "$active" ]] || active="unknown"
    printf "%s\n" "$active"
    return 0
  fi
  local active
  active="$(systemctl is-active "$unit" 2>/dev/null || true)"
  [[ -n "$active" ]] || active="unknown"
  printf "%s\n" "$active"
}

unit_runtime_state() {
  # Returns one of: running | active-nonrunning | inactive | failed | not-found | unknown
  local unit="$1"
  local scope="${2:-system}"
  if ! have systemctl; then
    printf "unknown\n"
    return 0
  fi

  local cmd=(systemctl)
  if [[ "$scope" == "user" ]]; then
    if ! systemctl --user show-environment >/dev/null 2>&1; then
      printf "unknown\n"
      return 0
    fi
    cmd=(systemctl --user)
  fi

  local load active sub
  load="$("${cmd[@]}" show "$unit" -p LoadState --value 2>/dev/null || true)"
  active="$("${cmd[@]}" show "$unit" -p ActiveState --value 2>/dev/null || true)"
  sub="$("${cmd[@]}" show "$unit" -p SubState --value 2>/dev/null || true)"

  [[ -n "$load" ]] || load="unknown"
  [[ -n "$active" ]] || active="unknown"
  [[ -n "$sub" ]] || sub="unknown"

  if [[ "$load" == "not-found" ]]; then
    printf "not-found\n"
    return 0
  fi
  if [[ "$active" == "active" && ( "$sub" == "running" || "$sub" == "listening" ) ]]; then
    printf "running\n"
    return 0
  fi
  if [[ "$active" == "active" ]]; then
    printf "active-nonrunning\n"
    return 0
  fi
  if [[ "$active" == "inactive" || "$active" == "failed" ]]; then
    printf "%s\n" "$active"
    return 0
  fi
  printf "unknown\n"
}

unit_show_triplet() {
  # unit_show_triplet <scope:system|user> <unit>
  local scope="$1"
  local unit="$2"
  if ! have systemctl; then
    printf "load=unknown active=unknown sub=unknown\n"
    return 0
  fi

  local cmd=(systemctl)
  if [[ "$scope" == "user" ]]; then
    if ! systemctl --user show-environment >/dev/null 2>&1; then
      printf "load=unknown active=unknown sub=unknown\n"
      return 0
    fi
    cmd=(systemctl --user)
  fi

  local show_out show_rc
  set +e
  show_out="$("${cmd[@]}" show "$unit" -p LoadState -p ActiveState -p SubState 2>&1)"
  show_rc=$?
  set -e
  if [[ "$show_rc" -ne 0 ]]; then
    local err_short
    err_short="$(printf "%s" "$show_out" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-120)"
    printf "load=unknown active=unknown sub=unknown err=%s\n" "${err_short:-show-failed}"
    return 0
  fi

  local load active sub
  load="$(printf "%s\n" "$show_out" | sed -n 's/^LoadState=//p' | head -n1)"
  active="$(printf "%s\n" "$show_out" | sed -n 's/^ActiveState=//p' | head -n1)"
  sub="$(printf "%s\n" "$show_out" | sed -n 's/^SubState=//p' | head -n1)"
  [[ -n "$load" ]] || load="unknown"
  [[ -n "$active" ]] || active="unknown"
  [[ -n "$sub" ]] || sub="unknown"
  printf "load=%s active=%s sub=%s\n" "$load" "$active" "$sub"
}

dashboard_service_facts_row() {
  # dashboard_service_facts_row <label> <system-unit> <user-unit>
  local label="$1"
  local system_unit="$2"
  local user_unit="$3"
  local system_triplet user_triplet system_state user_state mode chip_state
  system_triplet="$(unit_show_triplet system "$system_unit")"
  user_triplet="$(unit_show_triplet user "$user_unit")"
  system_state="$(unit_runtime_state "$system_unit" system)"
  user_state="$(unit_runtime_state "$user_unit" user)"

  mode="inactive"
  chip_state="err"
  if [[ "$system_state" == "running" && "$user_state" == "running" ]]; then
    mode="conflict(system+user)"
    chip_state="err"
  elif [[ "$system_state" == "running" ]]; then
    mode="system-only"
    chip_state="ok"
  elif [[ "$user_state" == "running" ]]; then
    mode="user-only"
    chip_state="ok"
  fi

  msg "  ${label}:"
  msg "    runtime $(dashboard_rg_chip "$chip_state") mode=${mode}"
  msg "    system(${system_unit}) ${system_triplet}"
  msg "    user(${user_unit})   ${user_triplet}"
}

dashboard_unit_fact() {
  # dashboard_unit_fact <label> <scope:system|user> <unit>
  local label="$1"
  local scope="$2"
  local unit="$3"
  local triplet state
  triplet="$(unit_show_triplet "$scope" "$unit")"
  state="err"
  [[ "$triplet" == *"active=active"* ]] && state="ok"
  msg "  ${label}: $(dashboard_rg_chip "$state")  ${scope}:${unit} ${triplet}"
}

dashboard_service_result_fact() {
  # dashboard_service_result_fact <label> <scope:system|user> <unit>
  local label="$1"
  local scope="$2"
  local unit="$3"
  if ! have systemctl; then
    msg "  ${label}: $(dashboard_rg_chip err)  systemctl missing"
    return 0
  fi
  local cmd=(systemctl)
  if [[ "$scope" == "user" ]]; then
    if ! systemctl --user show-environment >/dev/null 2>&1; then
      msg "  ${label}: $(dashboard_rg_chip err)  user bus unavailable"
      return 0
    fi
    cmd=(systemctl --user)
  fi
  local out rc
  set +e
  out="$("${cmd[@]}" show "$unit" -p LoadState -p ActiveState -p SubState -p Result -p ExecMainStatus 2>/dev/null)"
  rc=$?
  set -e
  if [[ "$rc" -ne 0 || -z "$out" ]]; then
    msg "  ${label}: $(dashboard_rg_chip err)  ${scope}:${unit} unavailable"
    return 0
  fi
  local load active sub result status
  load="$(printf "%s\n" "$out" | sed -n 's/^LoadState=//p' | head -n1)"
  active="$(printf "%s\n" "$out" | sed -n 's/^ActiveState=//p' | head -n1)"
  sub="$(printf "%s\n" "$out" | sed -n 's/^SubState=//p' | head -n1)"
  result="$(printf "%s\n" "$out" | sed -n 's/^Result=//p' | head -n1)"
  status="$(printf "%s\n" "$out" | sed -n 's/^ExecMainStatus=//p' | head -n1)"
  [[ -n "$load" ]] || load="unknown"
  [[ -n "$active" ]] || active="unknown"
  [[ -n "$sub" ]] || sub="unknown"
  [[ -n "$result" ]] || result="unknown"
  [[ -n "$status" ]] || status="unknown"
  local chip="err"
  if [[ "$active" == "active" || "$result" == "success" ]]; then
    chip="ok"
  fi
  msg "  ${label}: $(dashboard_rg_chip "$chip")  ${scope}:${unit} load=${load} active=${active} sub=${sub} result=${result} status=${status}"
}

http_probe_fact() {
  # http_probe_fact <label> <url>
  local label="$1"
  local url="$2"
  if ! have curl; then
    msg "  ${label}: $(dashboard_rg_chip err)  curl missing  url=${url}"
    return 0
  fi
  local code rc
  set +e
  code="$(curl --max-time 4 -sS -o /dev/null -w "%{http_code}" "$url" 2>/dev/null)"
  rc=$?
  set -e
  local state="err"
  if [[ "$rc" -eq 0 && "$code" != "000" ]]; then
    state="ok"
  fi
  msg "  ${label}: $(dashboard_rg_chip "$state")  code=${code:-000} rc=${rc}  url=${url}"
}

tailscale_self_dns_name() {
  if ! have tailscale; then
    return 1
  fi
  if have jq; then
    tailscale status --json 2>/dev/null | jq -r '.Self.DNSName // empty | sub("\\.$"; "")' | head -n 1
    return 0
  fi
  tailscale status --json 2>/dev/null | sed -n 's/^[[:space:]]*"DNSName": "\([^"]*\)\.$/\1/p' | head -n 1
}

