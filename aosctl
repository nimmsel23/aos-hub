  msg "  Bridge: $(aosctl_chip "$state") (aos-bridge.service, $active/$enabled)"

  IFS='|' read -r state active enabled <<<"$(production_unit_summary "aos-router.service")"
  msg "  Router: $(aosctl_chip "$state") (aos-router.service, $active/$enabled)"

  IFS='|' read -r state active enabled <<<"$(production_unit_summary "aos-hub-backup-daily.timer")"
  msg "  Daily Timer: $(aosctl_chip "$state") (aos-hub-backup-daily.timer, $active/$enabled)"

  IFS='|' read -r state active enabled <<<"$(production_unit_summary "aos-hub-backup-weekly.timer")"
  msg "  Weekly Timer: $(aosctl_chip "$state") (aos-hub-backup-weekly.timer, $active/$enabled)"
}

render_dashboard_once() {
  if [[ "${AOS_NO_CLEAR:-0}" != "1" && -t 1 ]]; then
    clear
  fi
  ui_title "αOS Dashboard"
  msg "Updated: $(date '+%Y-%m-%d %H:%M:%S')"
  msg ""

  msg "=== Service Facts ==="
  dashboard_service_facts_row "Index" "aos-index.service" "aos-index-dev.service"
  dashboard_service_facts_row "Bridge" "aos-bridge.service" "aos-bridge.service"
  dashboard_service_facts_row "Router" "aos-router.service" "aos-router-dev.service"
  msg ""

  msg "=== Probe Facts ==="
  local index_local="${AOS_INDEX_HEALTH_URL:-http://127.0.0.1:8799/health}"
  local bridge_local="${AOS_BRIDGE_HEALTH_URL:-http://127.0.0.1:8080/health}"
  http_probe_fact "index.local" "$index_local"
  http_probe_fact "bridge.local" "$bridge_local"
  local ts_dns=""
  ts_dns="$(tailscale_self_dns_name || true)"
  if [[ -n "$ts_dns" ]]; then
    http_probe_fact "index.tailnet" "https://${ts_dns}/health"
    http_probe_fact "bridge.tailnet" "https://${ts_dns}/bridge/health"
  else
    msg "  tailnet: $(dashboard_rg_chip err)  tailscale dns unavailable"
  fi
  msg ""

  msg "=== Sync Facts ==="
  msg "  policy: hub_root daily push is REQUIRED (canonical)"
  msg "  policy: dokumente regular push is REQUIRED"
  msg "  policy: vault daily push is REQUIRED"
  local rclone_cfg="${AOS_RCLONE_CONFIG:-$HOME/.config/rclone/rclone.conf}"
  local rclone_bin="<missing>"
  local rclone_ver="<unknown>"
  if have rclone; then
    rclone_bin="$(command -v rclone)"
    rclone_ver="$(rclone --version 2>/dev/null | head -n1 || echo "<unknown>")"
  fi
  msg "  rclone_bin: $rclone_bin"
  msg "  rclone_version: $rclone_ver"
  msg "  rclone_config: $rclone_cfg ($( [[ -f "$rclone_cfg" ]] && echo present || echo missing ))"
  msg "  required_timers:"
  dashboard_unit_fact "hub.daily.timer" "system" "aos-hub-backup-daily.timer"
  dashboard_service_result_fact "hub.daily.service" "system" "aos-hub-backup-daily.service"
  dashboard_unit_fact "hub.live.timer" "user" "aos-sync@aos-hub.timer"
  dashboard_unit_fact "vault.push.timer" "user" "vaultctl-push.timer"
  dashboard_service_result_fact "vault.push.service" "user" "vaultctl-push.service"
  dashboard_unit_fact "vault.monitor.timer" "user" "vaultctl-push-monitor.timer"

  local vaultctl_bin="${SCRIPT_DIR}/scripts/sync-utils/vaultctl"
  if [[ -x "$vaultctl_bin" ]]; then
    local vault_status rc
    set +e
    vault_status="$("$vaultctl_bin" status 2>&1)"
    rc=$?
    set -e
    if [[ "$rc" -eq 0 ]]; then
      msg "  vaultctl.status (required): $(dashboard_rg_chip ok)"
      printf "%s\n" "$vault_status" \
        | sed -n -E '/^(local:|remote:|push:|monitor:|last-success:|last-result:|progress:)/p' \
        | sed 's/^/    /'
    else
      msg "  vaultctl.status (required): $(dashboard_rg_chip err)  rc=${rc}"
      msg "    $vault_status"
    fi
  else
    msg "  vaultctl.status (required): $(dashboard_rg_chip err)  missing ($vaultctl_bin)"
  fi

  local -a legacy_sync_timers=()
  if have systemctl && systemctl --user show-environment >/dev/null 2>&1; then
    mapfile -t legacy_sync_timers < <(systemctl --user list-unit-files "aos-sync@*.timer" --no-legend --no-pager 2>/dev/null | awk '{print $1}' | grep -E 'aos-sync@(BODY|BUSINESS)\.timer' | sort)
  fi
  if (( ${#legacy_sync_timers[@]} > 0 )); then
    msg "  legacy_sync_timers_detected:"
    local t
    for t in "${legacy_sync_timers[@]}"; do
      dashboard_unit_fact "legacy" "user" "$t"
    done
  fi

  local vault_root="${AOS_VAULT_ROOT:-${AOS_RCLONE_LOCAL:-${AOS_VAULT_DIR:-$HOME/vault}}}"
  local dokumente_root="${AOS_DOMAIN_LOCAL_BASE:-$HOME/Dokumente}"
  local hub_root="${AOS_AOS_HUB_LOCAL_PATH:-$HOME/aos-hub}"
  msg "  vault_root: $vault_root ($( [[ -d "$vault_root" ]] && echo present || echo missing ))"
  msg "  dokumente_root: $dokumente_root ($( [[ -d "$dokumente_root" ]] && echo present || echo missing ))"
  msg "  hub_root: $hub_root ($( [[ -d "$hub_root" ]] && echo present || echo missing ))"
}

run_dashboard() {
  local mode="${1:-once}"
  local interval="${2:-180}"

  case "$mode" in
    once|"")
      render_dashboard_once
      ;;
    watch|--watch|-w)
      [[ "$interval" =~ ^[0-9]+$ ]] || die "Usage: aosctl dashboard [watch [seconds]]"
      (( interval > 0 )) || interval=180
      while true; do
        if [[ "${AOS_NO_CLEAR:-0}" != "1" && -t 1 ]]; then
          clear
        fi
        render_dashboard_once || true
        if [[ ! -t 0 || ! -t 1 ]]; then
          break
        fi
        msg ""
        msg "Refresh ${interval}s | Ctrl-C to quit"
        sleep "$interval"
      done
      ;;
    *)
      if [[ "$mode" =~ ^[0-9]+$ ]]; then
        run_dashboard watch "$mode"
      else
        die "Usage: aosctl dashboard [watch [seconds]]"
      fi
      ;;
  esac
}

_status_unit_line() {
  # _status_unit_line <label> <unit> <scope:system|user> [note]
  local label="$1" unit="$2" scope="${3:-system}" note="${4:-}"
  local active enabled chip
  if [[ "$scope" == "system" ]]; then
    active="$(systemctl is-active "$unit" 2>/dev/null || true)"
    enabled="$(systemctl is-enabled "$unit" 2>/dev/null || true)"
  else
    active="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
    enabled="$(systemctl --user is-enabled "$unit" 2>/dev/null || true)"
  fi
  [[ -z "$active" ]]  && active="-"
  [[ -z "$enabled" ]] && enabled="-"
  case "$active" in
    active)                        chip="$(aosctl_chip ok)" ;;
    activating|deactivating)       chip="$(aosctl_chip warn)" ;;
    failed)                        chip="$(aosctl_chip err)" ;;
    inactive|dead|-)               chip="$(aosctl_chip warn)" ;;
    *)                             chip="$(aosctl_chip err)" ;;
  esac
  local suffix="$active"
  [[ "$enabled" != "enabled" && "$enabled" != "-" ]] && suffix="$active/$enabled"
  [[ -n "$note" ]] && suffix="$suffix — $note"
  printf "  %-26s [%s] %s\n" "$label" "$chip" "$suffix"
}

_status_timer_line() {
  local unit="$1" scope="${2:-system}"
  local active next
  if [[ "$scope" == "system" ]]; then
    active="$(systemctl is-active "$unit" 2>/dev/null || true)"
    next="$(systemctl show "$unit" -p NextElapseUSecRealtime --value 2>/dev/null | head -1 || true)"
  else
    active="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
    next="$(systemctl --user show "$unit" -p NextElapseUSecRealtime --value 2>/dev/null | head -1 || true)"
  fi
  [[ -z "$active" ]] && return 0
  [[ "$active" == "inactive" ]] && return 0
  local chip
  [[ "$active" == "active" ]] && chip="$(aosctl_chip ok)" || chip="$(aosctl_chip warn)"
  printf "  %-46s [%s]\n" "$unit" "$chip"
}

_status_port_probe() {
  local port="$1"
  local path="${2:-/health}"
  local code
  code="$(curl -sS -o /dev/null -m 2 -w "%{http_code}" "http://127.0.0.1:${port}${path}" 2>/dev/null || true)"
  [[ -n "$code" && "$code" != "000" ]] && printf "%s" "$code" || printf "-"
}

_status_dual_unit_line() {
  # _status_dual_unit_line <label> <unit> <port> [path]
  local label="$1" unit="$2" port="$3" path="${4:-/health}"
  local sys_active user_active code
  sys_active="$(systemctl is-active "$unit" 2>/dev/null || true)"
  user_active="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
  [[ -n "$sys_active" ]] || sys_active="-"
  [[ -n "$user_active" ]] || user_active="-"
  if [[ "$port" == "0" || "$port" == "-" ]]; then
    code="-"
  else
    code="$(_status_port_probe "$port" "$path")"
  fi

  local chip_state="warn"
  if [[ "$sys_active" == "active" && "$user_active" == "active" ]]; then
    chip_state="err"
  elif [[ "$sys_active" == "active" || "$user_active" == "active" ]]; then
    chip_state="ok"
  elif [[ "$code" != "-" ]]; then
    chip_state="warn"
  fi

  printf "  %-22s [%s] unit=%s sys=%-8s user=%-8s port=%-5s http=%s\n" \
    "$label" "$(aosctl_chip "$chip_state")" "$unit" "$sys_active" "$user_active" "$port" "$code"
}

_status_split_unit_line() {
  # _status_split_unit_line <label> <system-unit> <user-unit> <port> [path]
  local label="$1" sys_unit="$2" user_unit="$3" port="$4" path="${5:-/health}"
  local sys_active user_active code
  sys_active="$(systemctl is-active "$sys_unit" 2>/dev/null || true)"
  user_active="$(systemctl --user is-active "$user_unit" 2>/dev/null || true)"
  [[ -n "$sys_active" ]] || sys_active="-"
  [[ -n "$user_active" ]] || user_active="-"
  if [[ "$port" == "0" || "$port" == "-" ]]; then
    code="-"
  else
    code="$(_status_port_probe "$port" "$path")"
  fi

  local chip_state="warn"
  if [[ "$sys_active" == "active" && "$user_active" == "active" ]]; then
    chip_state="err"
  elif [[ "$sys_active" == "active" || "$user_active" == "active" ]]; then
    chip_state="ok"
  elif [[ "$code" != "-" ]]; then
    chip_state="warn"
  fi

  printf "  %-22s [%s] sys=%-24s(%-8s) user=%-24s(%-8s) port=%-5s http=%s\n" \
    "$label" "$(aosctl_chip "$chip_state")" "$sys_unit" "$sys_active" "$user_unit" "$user_active" "$port" "$code"
}

_index_deploy_drift() {
  local prod_dir="/opt/aos/index"
  local repo_dir="${SCRIPT_DIR}/index-node"

  if [[ -L "$prod_dir" ]]; then
    local target
    target="$(readlink -f "$prod_dir" 2>/dev/null || true)"
    printf "  /opt/aos/index → %s  [%s] symlink\n" "$target" "$(aosctl_chip ok)"
    # Check PWA drift
    local pwa_dir="${AOS_PWA_DIR:-/opt/aos/pwa}"
    if [[ -d "$pwa_dir" ]]; then
      local pwa_count
      pwa_count="$(find "$pwa_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)"
      printf "  /opt/aos/pwa   (%s apps)  [%s]\n" "$pwa_count" "$(aosctl_chip ok)"
    else
      printf "  /opt/aos/pwa   [%s] missing — run: aosctl hub deploy pwa\n" "$(aosctl_chip warn)"
    fi
    return 0
  fi

  local prod_file="$prod_dir/server.js"
  local repo_file="$repo_dir/server.js"
  if [[ ! -f "$prod_file" || ! -f "$repo_file" ]]; then
    return 0
  fi
  local prod_ts repo_ts prod_sz repo_sz
  prod_ts="$(date -r "$prod_file" '+%Y-%m-%d %H:%M' 2>/dev/null || true)"
  repo_ts="$(date -r "$repo_file" '+%Y-%m-%d %H:%M' 2>/dev/null || true)"
  prod_sz="$(stat -c%s "$prod_file" 2>/dev/null || true)"
  repo_sz="$(stat -c%s "$repo_file" 2>/dev/null || true)"
  local drift_chip
  if [[ "$prod_ts" == "$repo_ts" && "$prod_sz" == "$repo_sz" ]]; then
    drift_chip="$(aosctl_chip ok)"
    printf "  prod  %-12s %6s bytes  [%s] in sync\n" "$prod_ts" "$prod_sz" "$drift_chip"
  else
    drift_chip="$(aosctl_chip warn)"
    printf "  prod  %-12s %6s bytes\n" "$prod_ts" "$prod_sz"
    printf "  repo  %-12s %6s bytes  [%s] STALE — run: aosctl hub deploy\n" "$repo_ts" "$repo_sz" "$drift_chip"
  fi
}

aosctl_probe_exec_quiet() {
  local timeout_sec="${AOSCTL_STATUS_PROBE_TIMEOUT:-1}"
  local rc=0
  set +e
  if have timeout; then
    timeout "${timeout_sec}s" "$@" >/dev/null 2>&1
    rc=$?
  else
    "$@" >/dev/null 2>&1
    rc=$?
  fi
  set -e
  return "$rc"
}

aosctl_status_probe_line() {
  local label="$1"
  local path="$2"
  local probe_desc="$3"
  shift 3 || true

  if [[ -z "$path" ]]; then
    printf "  %-12s [%s]  missing\n" "$label" "$(aosctl_chip err)"
    return 0
  fi
  if [[ ! -x "$path" ]]; then
    printf "  %-12s [%s]  not executable: %s\n" "$label" "$(aosctl_chip warn)" "$path"
    return 0
  fi

  local chip note
  if aosctl_probe_exec_quiet "$path" "$@"; then
    chip="$(aosctl_chip ok)"
    note="$probe_desc"
  else
    local rc=$?
    case "$rc" in
      124|137)
        chip="$(aosctl_chip warn)"
        note="probe timeout (${probe_desc})"
        ;;
      *)
        chip="$(aosctl_chip warn)"
        note="probe failed rc=$rc (${probe_desc})"
        ;;
    esac
  fi

  printf "  %-12s [%s]  %s\n" "$label" "$chip" "$note"
}

run_status() {
  local verbose=0
  for arg in "$@"; do
    case "$arg" in
      -v|--verbose) verbose=1 ;;
    esac
  done

  msg "αOS Status — $(date '+%Y-%m-%d %H:%M')"
  msg ""

  # ── Core Services (system + user + localhost) ────────────────
  msg "── Core Services (system + user + localhost) ──────────────────"
  _status_split_unit_line "index" "aos-index.service" "aos-index-dev.service" "8799" "/health"
  _status_split_unit_line "bridge" "aos-bridge.service" "aos-bridge.service" "8080" "/health"
  _status_split_unit_line "router" "aos-router.service" "aos-router-dev.service" "0" "/"
  msg ""

  # ── Centre Runtimes (ctx + ports) ────────────────────────────
  msg "── Centre Runtimes (ctx + ports) ─────────────────────────────"
  _status_dual_unit_line "core4 ctx"   "aos-pwa-core4-ctx.service"   "8781"
  _status_dual_unit_line "fire ctx"    "aos-pwa-fire-ctx.service"    "8782"
  _status_dual_unit_line "focus ctx"   "aos-pwa-focus-ctx.service"   "8783"
  _status_dual_unit_line "frame ctx"   "aos-pwa-frame-ctx.service"   "8784"
  _status_dual_unit_line "freedom ctx" "aos-pwa-freedom-ctx.service" "8785"
  _status_dual_unit_line "door ctx"    "aos-doorctx.service"         "8786"
  _status_dual_unit_line "game ctx"    "aos-pwa-game-ctx.service"    "8787"
  _status_dual_unit_line "fitness ctx" "aos-fitnessctx.service"      "8788"
  _status_dual_unit_line "memoirs ctx" "aos-pwa-memoirs-ctx.service" "8790"
  msg ""

  # ── Index: Prod vs Repo (deploy drift) ────────────────────────
  if [[ -f "/opt/aos/index/server.js" ]]; then
    msg "── Index Deploy Drift ─────────────────────────────────────────"
    _index_deploy_drift
    msg ""
  fi

  # ── Sync Timers ───────────────────────────────────────────────
  local _sync_shown=0
  msg "── Sync Timers ────────────────────────────────────────────────"
  # system: aos-* backup/live timers
  while IFS= read -r unit; do
    [[ -n "$unit" ]] || continue
    _status_timer_line "$unit" "system"
    _sync_shown=$((_sync_shown + 1))
  done < <(systemctl list-units --all --no-legend 2>/dev/null \
    | awk '{print $1}' | grep "^aos-.*\.timer$" | sort)
  # user: aos-sync@* + aos-hub-push + alphaos sync-related
  while IFS= read -r unit; do
    [[ -n "$unit" ]] || continue
    local _ua; _ua="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
    [[ -z "$_ua" || "$_ua" == "inactive" ]] && continue
    _status_timer_line "$unit" "user"
    _sync_shown=$((_sync_shown + 1))
  done < <(systemctl --user list-units --all --no-legend 2>/dev/null \
    | awk '{print $1}' \
    | grep -E "^(aos-sync@|aos-hub-push|alphaos-vault-sync|alphaos-safe-rclone|alphaos-dokumente)" \
    | grep "\.timer$" | sort)
  [[ "$_sync_shown" -eq 0 ]] && msg "  (none active)"
  msg ""

  # ── Vault Push Stack ──────────────────────────────────────────
  msg "── Vault Push Stack (user) ────────────────────────────────────"
  _status_unit_line "vaultctl push timer"   "vaultctl-push.timer" "user"
  _status_unit_line "vaultctl push service" "vaultctl-push.service" "user"
  _status_unit_line "vault monitor timer"   "vaultctl-push-monitor.timer" "user"
  _status_unit_line "vault monitor svc"     "vaultctl-push-monitor.service" "user"
  msg ""

  # ── Other Legacy Timers (user: alphaos-*, non-sync) ───────────
  local _legacy_shown=0
  msg "── Other Timers (user: alphaos-*) ─────────────────────────────"
  while IFS= read -r unit; do
    [[ -n "$unit" ]] || continue
    [[ "$unit" =~ alphaos-vault-sync|alphaos-safe-rclone|alphaos-dokumente ]] && continue
    local _ua; _ua="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
    [[ -z "$_ua" || "$_ua" == "inactive" || "$_ua" == "dead" ]] && continue
    if [[ "$unit" == *.timer ]]; then
      _status_timer_line "$unit" "user"
    else
      _status_unit_line "$unit" "$unit" "user"
    fi
    _legacy_shown=$((_legacy_shown + 1))
  done < <(systemctl --user list-units --all --no-legend 2>/dev/null \
    | awk '{print $1}' | grep "^alphaos-" | grep -v "\.mount$" | sort)
  [[ "$_legacy_shown" -eq 0 ]] && msg "  (none active)"
  msg ""

  # ── CTL availability (one line each) ─────────────────────────
  msg "── CTL Tools ──────────────────────────────────────────────────"
  local ctl_ok ctl_chip
  for ctl_entry in \
    "indexctl:$INDEXCTL" \
    "routerctl:$ROUTERCTL" \
    "bridgectl:$BRIDGECTL" \
    "syncctl:$SYNCCTL" \
    "gitctl:$GITCTL" \
    "backupctl:$BACKUPCTL" \
    "mountctl:$MOUNTCTL" \
    "hookctl:$HOOKCTL" \
    "doorctl:$DOORCTL" \
    "gamectl:$GAMECTL" \
    "voicectl:$VOICECTL" \
    "firectl:$FIRECTL_BIN" \
    "tentctl:$TENTCTL" \
    "gasctl:$GASCTL" \
    "core4ctl:$CORE4CTL" \
    "envctl:$ENVCTL" \
    "aliasctl:$ALIASCTL"
  do
    local ctl_name="${ctl_entry%%:*}"
    local ctl_path="${ctl_entry#*:}"
    if [[ -n "$ctl_path" && -x "$ctl_path" ]]; then
      ctl_chip="$(aosctl_chip ok)"
    elif [[ -n "$ctl_path" ]]; then
      ctl_chip="$(aosctl_chip warn)"  # resolved but not executable
    else
      ctl_chip="$(aosctl_chip err)"
    fi
    printf "  %-12s [%s]  %s\n" "$ctl_name" "$ctl_chip" "${ctl_path:-not found}"
  done
  msg ""

  # ── Script Layer (frontdoors / wrapped CLIs) ─────────────────
  msg "── Script Layer (frontdoors / wrapped CLIs) ───────────────────"
  aosctl_status_probe_line "hubctl"      "$HUBCTL"      "--help" --help
  aosctl_status_probe_line "bridgectl"   "$BRIDGECTL"   "health" health
  aosctl_status_probe_line "routerctl"   "$ROUTERCTL"   "status" status
  aosctl_status_probe_line "nodectl"     "$NODECTL"     "--help" --help
  aosctl_status_probe_line "syncctl"     "$SYNCCTL"     "summary" summary
  aosctl_status_probe_line "gamectl"     "$GAMECTL"     "--help" --help
  aosctl_status_probe_line "doorctl"     "$DOORCTL"     "review" review
  aosctl_status_probe_line "voicectl"    "$VOICECTL"    "stats" stats
  aosctl_status_probe_line "firectl"     "$FIRECTL_BIN" "--help" --help
  aosctl_status_probe_line "mobileappctl" "$MOBILEAPPCTL" "--help" --help
  msg ""
  msg "  (details: aosctl menu  or  aosctl <component> status)"
}

