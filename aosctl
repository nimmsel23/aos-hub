env_file_has_key() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 1
  awk -F= -v k="$key" '
    $0 !~ /^[[:space:]]*#/ {
      kk=$1
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", kk)
      if (kk == k) { found=1; exit 0 }
    }
    END { exit found ? 0 : 1 }
  ' "$file"
}

pick_user_unit_file() {
  local cand=""
  local first_nonempty=""
  for cand in "$@"; do
    [[ -n "$cand" ]] || continue
    if [[ -z "$first_nonempty" ]]; then
      first_nonempty="$cand"
    fi
    if [[ -f "$HOME/.config/systemd/user/$cand" ]]; then
      printf "%s\n" "$cand"
      return 0
    fi
  done
  printf "%s\n" "$first_nonempty"
}

env_file_get_value() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 1
  awk -F= -v k="$key" '
    $0 !~ /^[[:space:]]*#/ {
      kk=$1
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", kk)
      if (kk == k) {
        vv=substr($0, index($0, "=")+1)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", vv)
        print vv
        exit 0
      }
    }
  ' "$file"
}

env_example_has_key() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 1
  awk -F= -v k="$key" '
    {
      line=$0
      sub(/^[[:space:]]*#?[[:space:]]*/, "", line)
      split(line, parts, "=")
      kk=parts[1]
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", kk)
      if (kk == k) { found=1; exit 0 }
    }
    END { exit found ? 0 : 1 }
  ' "$file"
}

env_var_nonempty() {
  local key="$1"
  [[ -n "${!key:-}" ]]
}

