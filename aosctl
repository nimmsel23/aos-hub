run_dashboard() {
  local mode="${1:-once}"
  local interval="${2:-10}"

  show_menu_with_picker() {
    local picker="$1"
    case "$picker" in
      gum|fzf) ;;
      *) die "Unknown picker: $picker (expected gum|fzf)" ;;
    esac
    (
      CTL_CHOOSE_PREFER="$picker"
      show_menu
    )
  }

  dashboard_hotkey_dispatch() {
    local key="$1"
    case "$key" in
      q|Q)
        return 99
        ;;
      m|M)
        show_menu || true
        ;;
      g|G)
        show_menu_with_picker gum || true
        ;;
      f|F)
        show_menu_with_picker fzf || true
        ;;
      s|S)
        run_status || true
        ;;
      d|D)
        run_doctor || true
        ;;
      p|P)
        run_ping || true
        ;;
      h|H|\?)
        show_help
        ;;
      *)
        return 0
        ;;
    esac
    ctl_pause_return
    return 0
  }

  case "$mode" in
    once|"")
      render_dashboard_once
      ;;
    watch|--watch|-w)
      [[ "$interval" =~ ^[0-9]+$ ]] || die "Usage: aosctl dashboard [watch [seconds]]"
      (( interval > 0 )) || interval=10
      while true; do
        render_dashboard_once
        if [[ ! -t 0 || ! -t 1 ]]; then
          break
        fi
        msg ""
        msg "Refresh ${interval}s | hotkeys: [m]enu [g]um [f]zf [s]tatus [d]octor [p]ing [h]elp [q]uit"
        local key=""
        if ctl_read_key_timed "$interval" key; then
          echo ""
          if ! dashboard_hotkey_dispatch "$key"; then
            rc=$?
            if [[ "$rc" -eq 99 ]]; then
              break
            fi
          fi
          if [[ "${key:-}" == "q" || "${key:-}" == "Q" ]]; then
            break
          fi
        fi
      done
      ;;
    *)
      if [[ "$mode" =~ ^[0-9]+$ ]]; then
        run_dashboard watch "$mode"
      else
        die "Usage: aosctl dashboard [watch [seconds]]"
      fi
      ;;
  esac
}

_status_unit_line() {
  # _status_unit_line <label> <unit> <scope:system|user> [note]
  local label="$1" unit="$2" scope="${3:-system}" note="${4:-}"
  local active enabled chip
  if [[ "$scope" == "system" ]]; then
    active="$(systemctl is-active "$unit" 2>/dev/null || true)"
    enabled="$(systemctl is-enabled "$unit" 2>/dev/null || true)"
  else
    active="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
    enabled="$(systemctl --user is-enabled "$unit" 2>/dev/null || true)"
  fi
  [[ -z "$active" ]]  && active="-"
  [[ -z "$enabled" ]] && enabled="-"
  case "$active" in
    active)                        chip="$(aosctl_chip ok)" ;;
    activating|deactivating)       chip="$(aosctl_chip warn)" ;;
    failed)                        chip="$(aosctl_chip err)" ;;
    inactive|dead|-)               chip="$(aosctl_chip warn)" ;;
    *)                             chip="$(aosctl_chip err)" ;;
  esac
  local suffix="$active"
  [[ "$enabled" != "enabled" && "$enabled" != "-" ]] && suffix="$active/$enabled"
  [[ -n "$note" ]] && suffix="$suffix — $note"
  printf "  %-26s [%s] %s\n" "$label" "$chip" "$suffix"
}

_status_timer_line() {
  local unit="$1" scope="${2:-system}"
  local active next
  if [[ "$scope" == "system" ]]; then
    active="$(systemctl is-active "$unit" 2>/dev/null || true)"
    next="$(systemctl show "$unit" -p NextElapseUSecRealtime --value 2>/dev/null | head -1 || true)"
  else
    active="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
    next="$(systemctl --user show "$unit" -p NextElapseUSecRealtime --value 2>/dev/null | head -1 || true)"
  fi
  [[ -z "$active" ]] && return 0
  [[ "$active" == "inactive" ]] && return 0
  local chip
  [[ "$active" == "active" ]] && chip="$(aosctl_chip ok)" || chip="$(aosctl_chip warn)"
  printf "  %-46s [%s]\n" "$unit" "$chip"
}

_index_deploy_drift() {
  local prod_file="/opt/aos/index/server.js"
  local repo_file="${SCRIPT_DIR}/index-node/server.js"
  if [[ ! -f "$prod_file" || ! -f "$repo_file" ]]; then
    return 0
  fi
  local prod_ts repo_ts prod_sz repo_sz
  prod_ts="$(date -r "$prod_file" '+%Y-%m-%d %H:%M' 2>/dev/null || true)"
  repo_ts="$(date -r "$repo_file" '+%Y-%m-%d %H:%M' 2>/dev/null || true)"
  prod_sz="$(stat -c%s "$prod_file" 2>/dev/null || true)"
  repo_sz="$(stat -c%s "$repo_file" 2>/dev/null || true)"
  local drift_chip
  if [[ "$prod_ts" == "$repo_ts" && "$prod_sz" == "$repo_sz" ]]; then
    drift_chip="$(aosctl_chip ok)"
    printf "  prod  %-12s %6s bytes  [%s] in sync\n" "$prod_ts" "$prod_sz" "$drift_chip"
  else
    drift_chip="$(aosctl_chip warn)"
    printf "  prod  %-12s %6s bytes\n" "$prod_ts" "$prod_sz"
    printf "  repo  %-12s %6s bytes  [%s] STALE — run: aosctl hub deploy\n" "$repo_ts" "$repo_sz" "$drift_chip"
  fi
}

run_status() {
  local verbose=0
  for arg in "$@"; do
    case "$arg" in
      -v|--verbose) verbose=1 ;;
    esac
  done

  msg "αOS Status — $(date '+%Y-%m-%d %H:%M')"
  msg ""

  # ── Core Services (system scope, aos-*) ───────────────────────
  msg "── Core Services (system: aos-*) ─────────────────────────────"
  _status_unit_line "Index      (aos-index)"  "aos-index.service"  "system"
  _status_unit_line "Bridge     (aos-bridge)" "aos-bridge.service" "system"
  _status_unit_line "Router     (aos-router)" "aos-router.service" "system"
  msg ""

  # ── Dev Units (user scope, aos-*) ─────────────────────────────
  local dev_index_active dev_bridge_active dev_router_active
  dev_index_active="$(systemctl --user is-active "aos-index-dev.service"  2>/dev/null || true)"
  dev_bridge_active="$(systemctl --user is-active "aos-bridge-dev.service" 2>/dev/null || true)"
  dev_router_active="$(systemctl --user is-active "aos-router-dev.service" 2>/dev/null || true)"

  if [[ "$dev_index_active" == "active" || "$dev_bridge_active" == "active" || "$dev_router_active" == "active" ]]; then
    msg "── Dev Units (user: aos-*-dev) ────────────────────────────────"
    [[ "$dev_index_active"  != "inactive" && -n "$dev_index_active"  ]] && _status_unit_line "Index-dev  (user)" "aos-index-dev.service"  "user"
    [[ "$dev_bridge_active" != "inactive" && -n "$dev_bridge_active" ]] && _status_unit_line "Bridge-dev (user)" "aos-bridge-dev.service" "user"
    [[ "$dev_router_active" != "inactive" && -n "$dev_router_active" ]] && _status_unit_line "Router-dev (user)" "aos-router-dev.service" "user"

    local prod_idx_active
    prod_idx_active="$(systemctl is-active "aos-index.service" 2>/dev/null || true)"
    if [[ "$prod_idx_active" == "active" && "$dev_index_active" == "active" ]]; then
      msg "  $(aosctl_chip err) PORT CONFLICT: prod + dev both on port — run: aosctl hub deploy"
    fi
    msg ""
  fi

  # ── Index: Prod vs Repo (deploy drift) ────────────────────────
  if [[ -f "/opt/aos/index/server.js" ]]; then
    msg "── Index Deploy Drift ─────────────────────────────────────────"
    _index_deploy_drift
    msg ""
  fi

  # ── Sync Timers ───────────────────────────────────────────────
  local _sync_shown=0
  msg "── Sync Timers ────────────────────────────────────────────────"
  # system: aos-* backup/live timers
  while IFS= read -r unit; do
    [[ -n "$unit" ]] || continue
    _status_timer_line "$unit" "system"
    _sync_shown=$((_sync_shown + 1))
  done < <(systemctl list-units --all --no-legend 2>/dev/null \
    | awk '{print $1}' | grep "^aos-.*\.timer$" | sort)
  # user: aos-sync@* + aos-hub-live + alphaos sync-related
  while IFS= read -r unit; do
    [[ -n "$unit" ]] || continue
    local _ua; _ua="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
    [[ -z "$_ua" || "$_ua" == "inactive" ]] && continue
    _status_timer_line "$unit" "user"
    _sync_shown=$((_sync_shown + 1))
  done < <(systemctl --user list-units --all --no-legend 2>/dev/null \
    | awk '{print $1}' \
    | grep -E "^(aos-sync@|aos-hub-live|alphaos-vault-sync|alphaos-safe-rclone|alphaos-dokumente)" \
    | grep "\.timer$" | sort)
  [[ "$_sync_shown" -eq 0 ]] && msg "  (none active)"
  msg ""

  # ── Other Legacy Timers (user: alphaos-*, non-sync) ───────────
  local _legacy_shown=0
  msg "── Other Timers (user: alphaos-*) ─────────────────────────────"
  while IFS= read -r unit; do
    [[ -n "$unit" ]] || continue
    [[ "$unit" =~ alphaos-vault-sync|alphaos-safe-rclone|alphaos-dokumente ]] && continue
    local _ua; _ua="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
    [[ -z "$_ua" || "$_ua" == "inactive" || "$_ua" == "dead" ]] && continue
    if [[ "$unit" == *.timer ]]; then
      _status_timer_line "$unit" "user"
    else
      _status_unit_line "$unit" "$unit" "user"
    fi
    _legacy_shown=$((_legacy_shown + 1))
  done < <(systemctl --user list-units --all --no-legend 2>/dev/null \
    | awk '{print $1}' | grep "^alphaos-" | grep -v "\.mount$" | sort)
  [[ "$_legacy_shown" -eq 0 ]] && msg "  (none active)"
  msg ""

  # ── CTL availability (one line each) ─────────────────────────
  msg "── CTL Tools ──────────────────────────────────────────────────"
  local ctl_ok ctl_chip
  for ctl_entry in \
    "indexctl:$INDEXCTL" \
    "routerctl:$ROUTERCTL" \
    "bridgectl:$BRIDGECTL" \
    "syncctl:$SYNCCTL" \
    "gitctl:$GITCTL" \
    "backupctl:$BACKUPCTL" \
    "mountctl:$MOUNTCTL" \
    "hookctl:$HOOKCTL" \
    "doorctl:$DOORCTL" \
    "gamectl:$GAMECTL" \
    "voicectl:$VOICECTL" \
    "firectl:$FIRECTL_BIN" \
    "tentctl:$TENTCTL" \
    "gasctl:$GASCTL" \
    "core4ctl:$CORE4CTL" \
    "envctl:$ENVCTL" \
    "aliasctl:$ALIASCTL"
  do
    local ctl_name="${ctl_entry%%:*}"
    local ctl_path="${ctl_entry#*:}"
    if [[ -n "$ctl_path" && -x "$ctl_path" ]]; then
      ctl_chip="$(aosctl_chip ok)"
    elif [[ -n "$ctl_path" ]]; then
      ctl_chip="$(aosctl_chip warn)"  # resolved but not executable
    else
      ctl_chip="$(aosctl_chip err)"
    fi
    printf "  %-12s [%s]  %s\n" "$ctl_name" "$ctl_chip" "${ctl_path:-not found}"
  done
  msg ""
  msg "  (details: aosctl menu  or  aosctl <component> status)"
}

