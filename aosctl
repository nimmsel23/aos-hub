  local pwa_src="$src/public/pwa"
  local pwa_dst="${AOS_PWA_DIR:-/opt/aos/pwa}"

  [[ -d "$pwa_src" ]] || die "PWA source not found: $pwa_src"
  [[ -d "$pwa_dst" ]] || die "PWA dest not found: $pwa_dst (run: sudo mkdir -p $pwa_dst && sudo chown \$USER $pwa_dst)"

  if [[ -n "$target" ]]; then
    # Single PWA deploy (e.g. pwa:core4)
    [[ -d "$pwa_src/$target" ]] || die "PWA not found: $pwa_src/$target"
    msg "  pwa/$target: $pwa_src/$target/ → $pwa_dst/$target/"
    if [[ "$dry_run" == "1" ]]; then return 0; fi
    rsync -a --delete "$pwa_src/$target/" "$pwa_dst/$target/"
    msg "[$(aosctl_chip ok)] pwa/$target synced"
  else
    # All PWAs
    msg "  pwa: $pwa_src/ → $pwa_dst/"
    if [[ "$dry_run" == "1" ]]; then return 0; fi
    rsync -a --delete "$pwa_src/" "$pwa_dst/"
    msg "[$(aosctl_chip ok)] All PWAs synced"
  fi
}

_deploy_restart() {
  local service="$1" dry_run="$2"
  msg "  svc: sudo systemctl restart $service"
  if [[ "$dry_run" == "1" ]]; then return 0; fi
  sudo systemctl restart "$service"
  sleep 1
  local active
  active="$(systemctl is-active "$service" 2>/dev/null || true)"
  if [[ "$active" == "active" ]]; then
    msg "[$(aosctl_chip ok)] $service restarted and active"
  else
    msg "[$(aosctl_chip err)] $service status: $active"
    msg "  → check: sudo journalctl -u $service -n 30"
    return 1
  fi
}

index_deploy_cmd() {
  local src="${AOS_INDEX_DEPLOY_SRC:-$SCRIPT_DIR/index-node}"
  local dst="${AOS_INDEX_DEPLOY_DST:-/opt/aos/index}"
  local service="aos-index.service"
  local dry_run=0
  local subcmd=""

  for arg in "$@"; do
    case "$arg" in
      --dry-run|-n) dry_run=1 ;;
      --src=*) src="${arg#--src=}" ;;
      --dst=*) dst="${arg#--dst=}" ;;
      pwa:*) subcmd="$arg" ;;
      pwa|backend) subcmd="$arg" ;;
      -h|--help|help)
        cat <<'__DEPLOY_HELP__'
aosctl hub deploy — Split deployment (symlink backend + independent PWA)

Usage:
  aosctl hub deploy              # full: rsync PWAs + restart service
  aosctl hub deploy pwa          # rsync all PWAs (no restart)
  aosctl hub deploy pwa:NAME     # rsync single PWA, e.g. pwa:core4 (no restart)
  aosctl hub deploy backend      # restart service only (symlink = no copy needed)
  aosctl hub deploy --dry-run    # preview mode (combinable with above)
__DEPLOY_HELP__
        return 0
        ;;
      *) die "Unknown deploy arg: $arg (try: aosctl hub deploy help)" ;;
    esac
  done

  [[ -d "$src" ]] || die "Source not found: $src"

  msg "Index Deploy"
  msg "  src : $src"
  msg "  dst : $dst ($([ -L "$dst" ] && echo "symlink" || echo "directory"))"
  msg "  svc : $service"
  [[ "$dry_run" == "1" ]] && msg "  mode: DRY RUN"
  msg ""

  case "$subcmd" in
    pwa:*)
      local pwa_name="${subcmd#pwa:}"
      _deploy_pwa "$src" "$dst" "$dry_run" "$pwa_name"
      ;;
    pwa)
      _deploy_pwa "$src" "$dst" "$dry_run"
      ;;
    backend)
      _deploy_restart "$service" "$dry_run"
      ;;
    "")
      # Full deploy: PWAs + restart
      _deploy_pwa "$src" "$dst" "$dry_run"
      [[ "$dry_run" != "1" ]] && msg ""
      _deploy_restart "$service" "$dry_run"
      ;;
  esac
}

centre_cmd() {
  local action="${1:-}"
  shift || true

  [[ -x "$AOS_CENTRES" ]] || die "aos-centres not found at: $AOS_CENTRES"

  case "$action" in
    add)
      if [[ $# -lt 2 ]]; then
        die "Usage: aosctl centre add <title> <link> [cmd]"
      fi
      "$AOS_CENTRES" add "$@"
      ;;
    open|boot|list|init)
      "$AOS_CENTRES" "$action" "$@"
      ;;
    *)
      die "Unknown centre action: $action"
      ;;
  esac
}

bot_cmd() {
  local action="${1:-}"
  shift || true

  case "$action" in
    send)
      local bot="${1:-}"
      shift || true
      [[ -n "$bot" ]] || die "Usage: aosctl bot send <bot> <text>"
      [[ $# -gt 0 ]] || die "Usage: aosctl bot send <bot> <text>"

      local bot_upper
      bot_upper="$(printf "%s" "$bot" | tr '[:lower:]' '[:upper:]')"

      local webhook=""
      local chat_id=""
      local user_id=""
      if [[ "$bot" == "hq" ]]; then
        webhook="${AOS_GAS_WEBHOOK_URL:-}"
        chat_id="${AOS_GAS_CHAT_ID:-}"
        user_id="${AOS_GAS_USER_ID:-}"
      else
        webhook="$(eval "printf '%s' \"\${AOS_${bot_upper}_WEBHOOK_URL:-}\"")"
        chat_id="$(eval "printf '%s' \"\${AOS_${bot_upper}_CHAT_ID:-}\"")"
        user_id="$(eval "printf '%s' \"\${AOS_${bot_upper}_USER_ID:-}\"")"
      fi

      [[ -n "$webhook" ]] || die "Missing webhook URL for bot '$bot' (set AOS_${bot_upper}_WEBHOOK_URL or AOS_GAS_WEBHOOK_URL for hq)"

      local bridge_url="${AOS_BRIDGE_URL:-http://127.0.0.1:8080/bridge}"
      bridge_url="${bridge_url%/}"
      local endpoint="${bridge_url}/telegram/send"

      local token_header="${AOS_BRIDGE_TOKEN_HEADER:-X-Bridge-Token}"
      local token="${AOS_BRIDGE_TOKEN:-}"

      local text="$*"
      local payload
      payload="$(AOS_TELE_TEXT="$text" AOS_TELE_CHAT_ID="$chat_id" AOS_TELE_USER_ID="$user_id" AOS_TELE_WEBHOOK_URL="$webhook" \
        python3 - <<'PY'
import json
import os

payload = {
    "text": os.environ.get("AOS_TELE_TEXT", ""),
    "chat_id": os.environ.get("AOS_TELE_CHAT_ID", ""),
    "user_id": os.environ.get("AOS_TELE_USER_ID", ""),
    "webhook_url": os.environ.get("AOS_TELE_WEBHOOK_URL", ""),
}
print(json.dumps(payload))
PY
      )"

      if [[ -n "$token" ]]; then
        curl -sS -X POST "$endpoint" \
          -H "Content-Type: application/json" \
          -H "$token_header: $token" \
          -d "$payload"
      else
        curl -sS -X POST "$endpoint" \
          -H "Content-Type: application/json" \
          -d "$payload"
      fi
      echo ""
      ;;
    *)
      die "Usage: aosctl bot send <bot> <text>"
      ;;
  esac
}

main() {
  if [[ $# -eq 0 ]]; then
    run_dashboard "${AOSCTL_DASHBOARD_INTERVAL:-180}"
    exit 0
  fi

  local cmd="$1"
  shift || true

  case "$cmd" in
    menu) show_menu ;;
    gum) (
      CTL_CHOOSE_PREFER="gum"
      show_menu
    ) ;;
    fzf) (
      CTL_CHOOSE_PREFER="fzf"
      show_menu
    ) ;;
    dashboard|dash) run_dashboard "$@" ;;
    status) run_status ;;
    ping) run_ping ;;
    help|-h|--help) show_help ;;
    version|-v|--version) show_version ;;
    doctor|doc) run_doctor ;;
    centre|centres|center|centers) centre_cmd "$@" ;;
    hub|index|router|bridge|core4|core4ctl|vault|sync|git|backup|mount|hook|hooks|door|doorctl|game|gamectl|voice|voicectl|firectl|tent|tentctl|gas|gasctl|env|alias) route_component "$cmd" "$@" ;;
    fire) fire_cmd "$@" ;;
    fruits) fruits_cmd "$@" ;;
    creatorking) creatorking_cmd "$@" ;;
    bot) bot_cmd "$@" ;;
    *)
      ui_err "Unknown command: $cmd"
      msg ""
      msg "Run 'aosctl help' for usage"
      exit 1
      ;;
  esac
}

main "$@"
