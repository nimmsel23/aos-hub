# ~/.config/fish/aliases.fish
#zentrale alias datei mit bash zsh und fish
source ~/.aliases.sh

# System-Aliase
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias cfg='/usr/bin/git --git-dir=/home/alpha/.dotfiles --work-tree=/home/alpha'
alias sm='~/bin/session-manager.fish'

# AI-Tools
alias claude='firefox --new-window https://claude.ai'
alias cla='firefox --new-window https://claude.ai'
alias chatgpt='firefox --new-window https://chatgpt.com'
alias gpt='firefox --new-window https://chatgpt.com'
alias grok='firefox --new-window https://grok.com'

# Social Media & Kommunikation
alias youtube='firefox --new-window https://youtube.com'
alias reddit='firefox https://reddit.com'
alias whatsapp='firefox --new-window https://web.whatsapp.com'
alias wa='firefox --new-window https://web.whatsapp.com'
alias wapp='firefox --new-window https://web.whatsapp.com'
alias notion='firefox --new-window https://notion.so'

# Produktivität
alias gmail='firefox https://gmail.com'
alias drive='firefox https://drive.google.com'
alias trello='firefox https://trello.com'
alias proton= 'firefox https://protonmail.com'
# Entertainment & Info
alias netflix='firefox https://netflix.com'
alias spotify='firefox https://open.spotify.com'
alias wikipedia='firefox https://wikipedia.org'
alias maps='firefox https://maps.google.com'

# Entwicklung
alias github='firefox https://github.com'
alias stackoverflow='firefox https://stackoverflow.com'

# Suche
alias google='firefox "https://google.com/search?q="'
alias wiki='firefox "https://en.wikipedia.org/wiki/"'
