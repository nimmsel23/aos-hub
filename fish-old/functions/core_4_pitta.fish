function core4-pitta
    echo "=== CORE4 PITTA STACK – $(date +'%Y-%m-%d') ==="

    echo "\n🌅 MORGEN (06:00–10:00)"
    echo "- Snake Juice: 2g Kalium / 1g Natron / 0.5g Salz in 0.7l Wasser"
    echo "- 5g Kreatin"
    echo "- Training (nüchtern), danach kalt duschen"
    echo "- Frühstück: 2 Eier oder Overnight-Oats mit Chia, Kurkuma, Zimt"
    echo "- Stack: Ashwagandha, D3+K2 (5000 IE), Zink, Kollagen (10g), Glycin (1–2g), Moringa"

    echo "\n☀️ MITTAG (12:00–16:00)"
    echo "- Mittagessen: Basmatireis + Gemüse + Avocado + Speck oder Fisch"
    echo "- Optional: Brahmi, Passionsblume"

    echo "\n🌇 ABEND (18:00–22:00)"
    echo "- Abendessen (leicht, warm): Hirse + Gemüse + Eier oder Kollagen-Shake"
    echo "- Stack: Magnesiumkomplex (2 Kapseln), Brahmi, Mulungu, Passionsblume (Tee)"
    echo "- 3g Glycin als Einschlafhilfe"

    echo "\n📆 Supplement-Zyklus:"
    echo "- Ashwagandha: täglich morgens, 4–6 Wochen Zyklus"
    echo "- Tongkat Ali: 3–5×/Woche als Tee"
    echo "- Mulungu / Passionsblume: max. 2×/Woche bei Bedarf"
    echo "- Zink: 25mg täglich, morgens oder abends (nicht mit Eisen)"
    echo "- Kreatin: täglich 5g"
    echo "- Magnesium: täglich abends"
    echo "- Vitamin D+K2: täglich morgens"
    echo "- Glycin: täglich 2–3g, abends"
end
