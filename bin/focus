#!/usr/bin/env python3
import typer
from datetime import date
import os
import calendar

app = typer.Typer(help="Alpha OS – FOCUS MAP: Monthly Mission zur Erreichung deiner Freedom Vision.")

DOMAINS = ["Body", "Being", "Balance", "Business"]
DOMAIN_ICONS = {"Body": "🔴", "Being": "🔵", "Balance": "🟡", "Business": "🟢"}
DOMAIN_SUBS = {
    "Body": "Fitness + Fuel",
    "Being": "Meditation + Memoirs",
    "Balance": "Partner + Posterity",
    "Business": "Discover + Declare"
}

QUESTIONS = {
    "outcome": "Was soll am Ende dieses Monats erreicht sein? (klar, messbar)",
    "habits": "Welche Habits willst du etablieren? (kommagetrennt)",
    "routines": "Welche Routines willst du etablieren? (kommagetrennt)",
    "additions": "Was brauchst du? (Tools, Resources, Knowledge - kommagetrennt)",
    "eliminations": "Was muss weg? (Habits, Patterns, Obstacles - kommagetrennt)"
}

def get_month_info():
    """Get current month and year."""
    today = date.today()
    month_name = calendar.month_name[today.month]
    year = today.year
    return month_name, year, today.month

def get_week_numbers(month, year):
    """Get ISO week numbers for a given month."""
    import datetime
    first_day = datetime.date(year, month, 1)
    last_day = datetime.date(year, month, calendar.monthrange(year, month)[1])

    weeks = []
    current = first_day
    while current <= last_day:
        week_num = current.isocalendar()[1]
        if week_num not in weeks:
            weeks.append(week_num)
        current += datetime.timedelta(days=7)

    return weeks[:4]  # Max 4 weeks

def write_to_markdown(month_name, year, mission, results, filename):
    """Write Focus Map to markdown."""
    weeks = get_week_numbers(date.today().month, year)

    with open(filename, "w") as f:
        f.write(f"# 🎯 FOCUS MAP | {month_name.upper()} {year}\n\n")
        f.write(f"**Monat:** {month_name} {year}\n")
        f.write(f"**Status:** Monthly Mission\n")
        f.write(f"**Parent:** [[FREEDOM_MAP_[Domain]]] - Annual Freedom Game\n")
        f.write(f"**Review:** Weekly im General's Tent\n\n")
        f.write("---\n\n")

        f.write("## 📋 MONTHLY MISSION\n\n")
        f.write("**From Freedom Map:**\n")
        f.write("[Welches Quarterly Milestone wird diesen Monat angegangen?]\n\n")
        f.write(f"**This Month's Focus:**\n{mission}\n\n")
        f.write("---\n\n")

        for domain in DOMAINS:
            icon = DOMAIN_ICONS[domain]
            sub = DOMAIN_SUBS[domain]
            f.write(f"## {icon} {domain.upper()} ({sub})\n\n")

            data = results[domain]
            f.write(f"### Monthly Outcome:\n{data['outcome']}\n\n")

            f.write("### Habits to Build:\n")
            for habit in data['habits'].split(',') if data['habits'] else []:
                f.write(f"- {habit.strip()}\n")
            f.write("\n")

            f.write("### Routines to Establish:\n")
            for routine in data['routines'].split(',') if data['routines'] else []:
                f.write(f"- {routine.strip()}\n")
            f.write("\n")

            f.write("### Additions:\n")
            f.write("[Was braucht es? Tools, Resources, Knowledge?]\n")
            for add in data['additions'].split(',') if data['additions'] else []:
                f.write(f"- {add.strip()}\n")
            f.write("\n")

            f.write("### Eliminations:\n")
            f.write("[Was muss weg? Habits, Patterns, Obstacles?]\n")
            for elim in data['eliminations'].split(',') if data['eliminations'] else []:
                f.write(f"- {elim.strip()}\n")
            f.write("\n---\n\n")

        f.write("## 🗓️ WEEKLY BREAKDOWN\n\n")
        for i, week_num in enumerate(weeks, 1):
            f.write(f"**Week {i} (KW {week_num}):**\n")
            f.write("- Primary Focus:\n\n")
        f.write("---\n\n")

        f.write("## 📊 TRACKING & COURSE CORRECTION\n\n")
        f.write("**Review Cadence:** Weekly (General's Tent)\n\n")
        for i in range(1, 5):
            f.write(f"**Week {i} Review:**\n")
            f.write("- Status: On Track / Off Track\n")
            f.write("- Adjustments:\n\n")
        f.write("---\n\n")

        f.write("## 🔗 LINKS\n\n")
        f.write("- **Freedom Maps:** [[FREEDOM_MAP_Body]], [[FREEDOM_MAP_Being]], [[FREEDOM_MAP_Balance]], [[FREEDOM_MAP_Business]]\n")
        f.write("- **Fire Maps:** Weekly Wars für diesen Monat\n")
        f.write("- **THE GAME MOC:** [[📖 MOC - THE GAME]]\n\n")
        f.write("---\n\n")
        f.write('**🜂 "A month is long enough to make significant progress yet short enough to keep things real and immediate."** - Elliott Hulse\n')

    print(f"\n✅ Focus Map gespeichert in {filename}")

@app.command()
def focus():
    """Create Focus Map for current month."""
    month_name, year, month = get_month_info()

    typer.echo(f"\n🎯 FOCUS MAP – Monthly Mission für {month_name} {year}\n")
    typer.echo("Elliott: 'A month is long enough to make significant progress yet short enough to keep things real.'\n")

    mission = typer.prompt("Was ist die EINE große Sache die diesen Monat erreicht werden muss?")

    results = {}
    for domain in DOMAINS:
        icon = DOMAIN_ICONS[domain]
        sub = DOMAIN_SUBS[domain]
        typer.echo(f"\n{icon} === {domain.upper()} ({sub}) ===\n")

        answers = {}
        for key, question in QUESTIONS.items():
            answer = typer.prompt(question)
            answers[key] = answer

        results[domain] = answers

    # Save to markdown
    folder = os.path.expanduser("~/.aos/focus")
    os.makedirs(folder, exist_ok=True)
    filename = os.path.join(folder, f"FOCUS_MAP_{month_name}_{year}.md")

    write_to_markdown(month_name, year, mission, results, filename)

    typer.echo("\n✅ Focus Map abgeschlossen!")
    typer.echo(f"📍 Review wöchentlich im General's Tent")
    typer.echo(f"📍 Erstelle jetzt Fire Maps für jede Woche: fire")

if __name__ == "__main__":
    app()
